<article>
  <header class="prose article-hero">
    <div class="caption"><a href="{{ section.url }}">← <span data-bocchi-i18n="theme.bocchi-mono.articleBackPrefix">{{ text.articleBackPrefix }}</span> {{ section.name }}</a>{% if item.hasArticleTime %} · <bocchi-time class="article-time" data-bocchi-article-time data-bocchi-time="{{ item.time.payloadJson }}" role="button" tabindex="0" aria-expanded="false"><span class="article-time__label" data-bocchi-time-label data-bocchi-i18n="{{ item.time.active.labelKey }}">{{ item.time.active.label }}</span> <time class="article-time__value" data-bocchi-time-value datetime="{{ item.time.active.iso }}">{{ item.time.active.display }}</time> <span class="article-time__zone" data-bocchi-time-offset>{{ item.time.active.timeZoneLabel }}</span></bocchi-time>{% endif %}{% if item.meta %} · {{ item.meta }}{% endif %}</div>
    <h1 class="display article-display">{{ item.title }}</h1>
  </header>

  {% if item.isTranslation %}
  <aside class="prose translation-notice" data-bocchi-translation-notice>
    <span>
      <span data-bocchi-i18n="content.translationNotice">{{ text.translationNotice }}</span>
      {% if item.sourceLanguageName %}<span class="translation-notice__source">{{ item.sourceLanguageName }}</span>{% endif %}
    </span>
    {% if item.hasSourceAlternate %}
    <a class="arrow-link" href="{{ item.sourceAlternate.url }}" data-bocchi-language-link="{{ item.sourceAlternate.language }}" data-bocchi-i18n="content.viewOriginal">{{ text.viewOriginal }}</a>
    {% endif %}
  </aside>
  {% endif %}

  {% if item.hasCover %}
  <figure class="content media-cover"><img src="{{ item.cover.path }}" alt="{{ item.cover.alt }}"></figure>
  {% endif %}

  <section class="prose prose-body">{{ item.html | html }}</section>

  {% if item.hasTags or item.hasStack or item.hasLinks %}
  <section class="prose article-taxonomy">
    {% if item.hasTags %}<div class="tag-line">{% for tag in item.tags %}<span class="tag-text">{{ tag }}</span>{% endfor %}</div>{% endif %}
    {% if item.hasStack %}<div class="tag-line">{% for tag in item.stack %}<span class="tag-text">{{ tag }}</span>{% endfor %}</div>{% endif %}
    {% if item.hasLinks %}<div class="article-links">{% for link in item.links %}<a class="arrow-link" href="{{ link.url }}">{{ link.label }} <span class="arrow">→</span></a>{% endfor %}</div>{% endif %}
  </section>
  {% endif %}

  <nav class="content article-nav" aria-label="Adjacent content">
    {% if hasPrevious %}<a href="{{ previous.url }}"><span class="caption">← <span data-bocchi-i18n="common.previous">{{ text.previous }}</span></span><strong>{{ previous.title }}</strong></a>{% endif %}
    {% if hasNext %}<a href="{{ next.url }}"><span class="caption"><span data-bocchi-i18n="common.next">{{ text.next }}</span> →</span><strong>{{ next.title }}</strong></a>{% endif %}
  </nav>
</article>
