<section class="hero container not-found">
  <div class="meta caption">{{ hero.number }}</div>
  <h1 class="display">{{ hero.title }}</h1>
  <p class="hero-subtitle" data-bocchi-i18n="{{ hero.descriptionKey }}">{{ hero.description }}</p>
  <div class="meta-line">
    <a class="arrow-link" href="/" data-bocchi-i18n="common.backHome">{{ text.backHome }}</a>
  </div>
</section>
