        {
          "key": "home.featuredWorks",
          "type": "number",
          "title": "首页作品数量",
          "default": 4
        },
        {
          "key": "home.recentNotes",
          "type": "number",
          "title": "首页短文数量",
          "default": 3
        },
        {
          "key": "home.showFriends",
          "type": "boolean",
          "title": "首页显示友链",
          "default": true
        }
      ]
    },
    {
      "id": "reading",
      "title": "阅读",
      "fields": [
        {
          "key": "reading.showUpdatedAt",
          "type": "boolean",
          "title": "显示更新时间",
          "default": true
        }
      ]
    }
