      "title": "视觉",
      "fields": [
        {
          "key": "visual.accentColor",
          "type": "color",
          "title": "Accent color",
          "default": "#E85D3A"
        }
      ]
    },
    {
      "id": "home",
      "title": "首页",
      "fields": [
        {
          "key": "home.featuredPosts",
          "type": "number",
          "title": "首页文章数量",
          "default": 5
