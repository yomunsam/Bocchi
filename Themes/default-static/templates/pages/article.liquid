<article>
  <header class="prose article-hero">
    <div class="caption"><a href="{{ section.url }}">← <span data-bocchi-i18n="theme.defaultStatic.articleBackPrefix">{{ text.articleBackPrefix }}</span> {{ section.name }}</a>{% if item.date %} · {{ item.date }}{% endif %}{% if item.meta %} · {{ item.meta }}{% endif %}</div>
    <h1 class="display article-display">{{ item.title }}</h1>
    {% if item.summary %}<p class="lead">{{ item.summary }}</p>{% endif %}
  </header>

  {% if item.hasCover %}
  <figure class="content media-cover"><img src="{{ item.cover.path }}" alt="{{ item.cover.alt }}"></figure>
  {% endif %}

  <section class="prose prose-body">{{ item.html | html }}</section>

  {% if item.hasTags or item.hasStack or item.hasLinks %}
  <section class="prose article-taxonomy">
    {% if item.hasTags %}<div class="tag-line">{% for tag in item.tags %}<span class="tag-text">{{ tag }}</span>{% endfor %}</div>{% endif %}
    {% if item.hasStack %}<div class="tag-line">{% for tag in item.stack %}<span class="tag-text">{{ tag }}</span>{% endfor %}</div>{% endif %}
    {% if item.hasLinks %}<div class="article-links">{% for link in item.links %}<a class="arrow-link" href="{{ link.url }}">{{ link.label }} <span class="arrow">→</span></a>{% endfor %}</div>{% endif %}
  </section>
  {% endif %}

  <nav class="content article-nav" aria-label="Adjacent content">
    {% if hasPrevious %}<a href="{{ previous.url }}"><span class="caption">← <span data-bocchi-i18n="common.previous">{{ text.previous }}</span></span><strong>{{ previous.title }}</strong></a>{% endif %}
    {% if hasNext %}<a href="{{ next.url }}"><span class="caption"><span data-bocchi-i18n="common.next">{{ text.next }}</span> →</span><strong>{{ next.title }}</strong></a>{% endif %}
  </nav>
</article>
