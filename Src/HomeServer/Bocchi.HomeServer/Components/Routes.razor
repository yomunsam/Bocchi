@inject DashboardLocalizationService I18n

<Router AppAssembly="typeof(Program).Assembly" NotFoundPage="typeof(Pages.NotFound)">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)">
            <NotAuthorized>
                @* HTTP 级 AdminGate 已负责真实跳转；这里兜住 interactive navigation 的短暂未授权状态。 *@
                <LayoutView Layout="typeof(Layout.AuthLayout)">
                    <section class="mx-auto grid min-h-[60vh] max-w-xl place-items-center text-center">
                        <div class="grid gap-4 rounded-bocchi-xl bg-bocchi-surface p-8 shadow-bocchi-soft">
                            <h1 class="m-0 text-2xl font-semibold text-bocchi-text">Bocchi</h1>
                            <p class="m-0 text-sm leading-6 text-bocchi-muted">@I18n["auth.redirecting"]</p>
                        </div>
                    </section>
                </LayoutView>
            </NotAuthorized>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>
