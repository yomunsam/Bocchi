@page "/Admin/Content/Edit"
@using Bocchi.ContentModel
@using Bocchi.Workspace.Scanning
@using Bocchi.Workspace.State
@using Bocchi.HomeServer.Services
@using Bocchi.HomeServer.Services.Ai
@inject ContentEditingService Editor
@inject EditorDraftService Drafts
@inject CategoryTreeService Categories
@inject Bocchi.Workspace.Content.MarkdownPipeline Markdown
@inject ContentScanner Scanner
@inject IContentStateStore Store
@inject ThemeSettingsService ThemeSettings
@inject SiteProfileSettingsService SiteProfile
@inject DashboardAiClient Ai
@inject DashboardLocalizationService I18n
@inject TimeProvider Time
@inject NavigationManager Nav

<PageTitle>@EditorPageTitle · Bocchi</PageTitle>

<article class="bocchi-shell bocchi-editor-page">
    @if (HasEditorDocument && _error is null)
    {
        <header class="bocchi-editor-commandbar">
            <a class="bocchi-editor-commandbar__back" href="@BackUrl" aria-label='@Text("contentEditor.back.aria")'>
                <Blazicon Svg="Lucide.ArrowLeft" />
            </a>
            <div class="bocchi-editor-commandbar__title">
                <span>@EditorKicker</span>
                <h1>@EditorHeading</h1>
            </div>
            <div class="bocchi-editor-commandbar__actions">
                <BocchiStatusPill Tone="@(_saved ? "success" : IsDirty ? "warning" : "info")">@EditorStateLabel</BocchiStatusPill>
                @if (IsUnsavedDraft)
                {
                    <button type="button" @onclick="SaveDraftAsync" disabled="@_busy">
                        <Blazicon Svg="Lucide.Save" />
                        @(_busy ? Text("contentEditor.action.saving") : Text("contentEditor.action.saveDraft"))
                    </button>
                    <button type="button" class="secondary" @onclick="PublishAsync" disabled="@_busy">
                        <Blazicon Svg="Lucide.Send" />
                        @Text("contentEditor.action.publish")
                    </button>
                }
                else if (CurrentStatus == ContentStatus.Published)
                {
                    <button type="button" class="secondary" @onclick="WithdrawAsync" disabled="@_busy">
                        <Blazicon Svg="Lucide.EyeOff" />
                        @Text("contentEditor.action.withdraw")
                    </button>
                    <button type="button" @onclick="SaveAsync" disabled="@_busy">
                        <Blazicon Svg="Lucide.Save" />
                        @(_busy ? Text("contentEditor.action.saving") : Text("contentEditor.action.update"))
                    </button>
                    <button type="button" class="secondary" @onclick="ArchiveAsync" disabled="@_busy">
                        <Blazicon Svg="Lucide.Archive" />
                        @Text("contentEditor.action.archive")
                    </button>
                }
                else if (CurrentStatus == ContentStatus.Archived)
                {
                    <button type="button" @onclick="UpdateArchivedAsync" disabled="@_busy">
                        <Blazicon Svg="Lucide.Save" />
                        @(_busy ? Text("contentEditor.action.saving") : Text("contentEditor.action.update"))
                    </button>
                    <button type="button" class="secondary bocchi-editor-commandbar__danger" @onclick="OpenPermanentDeleteConfirm" disabled="@_busy">
                        <Blazicon Svg="Lucide.Trash2" />
                        @Text("contentEditor.action.permanentDelete")
                    </button>
                }
                else
                {
                    <button type="button" @onclick="SaveAsync" disabled="@_busy">
                        <Blazicon Svg="Lucide.Save" />
                        @(_busy ? Text("contentEditor.action.saving") : Text("contentEditor.action.update"))
                    </button>
                    <button type="button" class="secondary" @onclick="PublishAsync" disabled="@_busy">
                        <Blazicon Svg="Lucide.Send" />
                        @Text("contentEditor.action.publish")
                    </button>
                    <button type="button" class="secondary bocchi-editor-commandbar__danger" @onclick="OpenDraftDeleteConfirm" disabled="@_busy">
                        <Blazicon Svg="Lucide.Trash2" />
                        @Text("contentEditor.action.delete")
                    </button>
                }
            </div>
        </header>
    }
    else
    {
        <header class="bocchi-page-heading">
            <span class="bocchi-page-heading__eyebrow">@EditorKicker</span>
            <h1>@EditorHeading</h1>
            <p>@EditorDescription</p>
        </header>
    }

    @if (!HasEditorDocument && string.IsNullOrWhiteSpace(Path) && string.IsNullOrWhiteSpace(Draft))
    {
        <section class="bocchi-panel" aria-labelledby="pick-file-heading">
            <h2 id="pick-file-heading">@Text("contentEditor.picker.heading")</h2>
            @if (_summaries.Count == 0)
            {
                <BocchiListRow Kicker='@Text("contentEditor.picker.emptyKicker")' Title='@Text("contentEditor.picker.emptyTitle")'>
                    <ChildContent>
                        <p>@Text("contentEditor.picker.emptyBody")</p>
                    </ChildContent>
                    <Action>
                        <a class="bocchi-button secondary" href="/Admin/Content">@Text("contentEditor.picker.openContent")</a>
                    </Action>
                </BocchiListRow>
            }
            else
            {
                @foreach (var item in _summaries)
                {
                    <BocchiListRow Kicker="@item.Kind.ToString()" Title="@(item.Title ?? item.ContentId)">
                        <ChildContent>
                            <p><code>@item.RelativePath</code></p>
                        </ChildContent>
                        <Metadata>
                            <BocchiStatusPill Tone="@StatusTone(item.Status)">@StatusLabel(item.Status)</BocchiStatusPill>
                        </Metadata>
                        <Action>
                            @if (IsMarkdownPath(item.RelativePath))
                            {
                                <a class="bocchi-button secondary" href="@ContentEditingService.EditUrl(item.RelativePath)">@Text("contentEditor.picker.edit")</a>
                            }
                        </Action>
                    </BocchiListRow>
                }
            }
        </section>
    }
    else if (_error is not null)
    {
        <section class="bocchi-panel">
            <h2>@Text("contentEditor.error.heading")</h2>
            <p>@_error</p>
            <a class="bocchi-button secondary" href="@BackUrl">@Text("contentEditor.error.back")</a>
        </section>
    }
    else if (!HasEditorDocument)
    {
        <section class="bocchi-panel">
            <p>@Text("contentEditor.loading")</p>
        </section>
    }
    else
    {
        <div class="bocchi-editor-layout">
            <section class="bocchi-writing-surface" aria-labelledby="writing-heading">
                <section class="bocchi-writing-card" aria-labelledby="writing-heading">
                    @* writing-card 不再重复 kind 与路径：页面顶部的 commandbar kicker 已经包含了这些信息。 *@
                    <label class="bocchi-title-field">
                        <span class="bocchi-visually-hidden">@Text("contentEditor.field.title.aria")</span>
                        <input id="writing-heading"
                               type="text"
                               value="@_title"
                               @oninput="OnTitleInput"
                               placeholder="@TitlePlaceholder" />
                    </label>
                    <label class="bocchi-summary-field">
                        <span>@Text("contentEditor.field.summary")</span>
                        <textarea @bind="_summary"
                                  @bind:event="oninput"
                                  placeholder='@Text("contentEditor.field.summaryPlaceholder")'></textarea>
                    </label>
                    @if (TemplateUnavailable)
                    {
                        <p class="bocchi-template-selector__warning">
                            @FormatText("contentEditor.template.unavailableWarningFormat", _template)
                        </p>
                    }
                </section>

                <BocchiMarkdownEditor ContentKindLabel="@EditorKindLabel"
                                      Title='@Text("contentEditor.body.title")'
                                      Value="@_markdown"
                                      ValueChanged="OnMarkdownChangedAsync"
                                      PreviewHtml="@_previewHtml"
                                      Placeholder='@Text("contentEditor.body.placeholder")'
                                      DefaultViewMode="write" />

                <details class="bocchi-advanced-details">
                    <summary>
                        <span>@Text("contentEditor.advanced.title")</span>
                        <small>@Text("contentEditor.advanced.help")</small>
                    </summary>
                    <textarea class="bocchi-editor-frontmatter"
                              aria-label='@Text("contentEditor.advanced.title")'
                              @bind="_yaml"></textarea>
                </details>
            </section>

            <aside class="bocchi-editor-side" aria-label='@Text("contentEditor.side.aria")'>
                <details class="bocchi-panel bocchi-panel--soft bocchi-publish-panel" open>
                    <summary class="bocchi-editor-details-summary">
                        <span>@Text("contentEditor.status.title")</span>
                        <BocchiStatusPill Tone="@StatusTone(CurrentStatus)">@StatusLabel(CurrentStatus)</BocchiStatusPill>
                    </summary>
                    <dl class="bocchi-meta-list">
                        <div>
                            <dt>@Text("contentEditor.meta.type")</dt>
                            <dd>@EditorKindLabel</dd>
                        </div>
                        <div>
                            <dt>@Text("contentEditor.meta.visibility")</dt>
                            <dd>@StatusLabel(CurrentStatus)</dd>
                        </div>
                        <div>
                            <dt>@Text("contentEditor.meta.location")</dt>
                            <dd>@EditorPathLabel</dd>
                        </div>
                        <div>
                            <dt>@Text("contentEditor.meta.body")</dt>
                            <dd>@MarkdownStats</dd>
                        </div>
                        <div>
                            <dt>@Text("contentEditor.meta.lastSaved")</dt>
                            <dd>@LastSavedLabel</dd>
                        </div>
                    </dl>
                    <p>@DiffSummary</p>
                    @if (!string.IsNullOrWhiteSpace(_saveMessage))
                    {
                        <p class="bocchi-editor-save-message">@_saveMessage</p>
                    }
                </details>

                <details class="bocchi-panel bocchi-editor-inspector" open>
                    <summary class="bocchi-editor-details-summary">
                        <span>@Text("contentEditor.settings.title")</span>
                    </summary>
                    <div class="bocchi-editor-field-stack">
                        <label class="bocchi-editor-field">
                            @Text("contentEditor.field.slug")
                            <span class="bocchi-editor-slug-control">
                                <input type="text"
                                       value="@_slug"
                                       disabled="@(!CanAutoChangeSlug)"
                                       @oninput="OnSlugInput" />
                                @if (CanShowAiSlugButton)
                                {
                                    <button type="button"
                                            class="@AiSlugButtonClass"
                                            title="@AiSlugButtonLabel"
                                            aria-label="@AiSlugButtonLabel"
                                            aria-busy="@_aiSlugBusy"
                                            disabled="@(!CanUseAiSlug)"
                                            @onclick="OpenAiSlugConfirm">
                                        @if (_aiSlugBusy)
                                        {
                                            <Blazicon Svg="Lucide.LoaderCircle" />
                                        }
                                        else
                                        {
                                            <Blazicon Svg="Lucide.Sparkles" />
                                        }
                                    </button>
                                }
                            </span>
                            @if (_aiSlugBusy)
                            {
                                <span class="bocchi-editor-slug-status" aria-live="polite">@Text("contentEditor.slug.generating")</span>
                            }
                        </label>

                        @if (IsPostFile)
                        {
                            <label class="bocchi-editor-field">
                                @Text("contentEditor.field.category")
                                <select @bind="_category">
                                    <option value="">@Text("contentEditor.field.categoryNone")</option>
                                    @if (CategoryUnavailable)
                                    {
                                        <option value="@_category">@FormatText("contentEditor.field.categoryUnavailableFormat", _category)</option>
                                    }
                                    @foreach (var category in _postCategories)
                                    {
                                        <option value="@category.Name">@CategoryOptionLabel(category)</option>
                                    }
                                </select>
                            </label>
                            <label class="bocchi-editor-field">
                                @Text("contentEditor.field.tags")
                                <input type="text"
                                       @bind="_tagsText"
                                       @bind:event="oninput"
                                       placeholder='@Text("contentEditor.field.tagsPlaceholder")' />
                            </label>
                            <label class="bocchi-editor-field">
                                @Text("contentEditor.field.publishedAt")
                                <input type="text"
                                       @bind="_publishedAt"
                                       @bind:event="oninput"
                                       placeholder='@Text("contentEditor.field.publishedAtPlaceholder")' />
                            </label>
                        }

                        @if (IsPageFile)
                        {
                            <label class="bocchi-editor-field">
                                @Text("contentEditor.template.label")
                                <select @bind="_template">
                                    @if (TemplateUnavailable)
                                    {
                                        <option value="@_template">@FormatText("contentEditor.template.unavailableOptionFormat", _template)</option>
                                    }
                                    @foreach (var template in _pageTemplates)
                                    {
                                        <option value="@template.Name">@template.DisplayName</option>
                                    }
                                </select>
                            </label>
                            <label class="bocchi-editor-field">
                                @Text("contentEditor.field.navigationOrder")
                                <input type="number" @bind="_order" />
                            </label>
                            <label class="bocchi-checkbox bocchi-editor-checkbox">
                                <input type="checkbox" @bind="_showInNavigation" />
                                @Text("contentEditor.field.showInNavigation")
                            </label>
                        }
                    </div>
                </details>

                <details class="bocchi-panel bocchi-editor-ai" open>
                    <summary class="bocchi-editor-details-summary">
                        <span>@Text("contentEditor.ai.title")</span>
                    </summary>
                    @if (_aiAvailabilityChecked && !_aiAvailability.HasAvailableProvider)
                    {
                        <p class="bocchi-editor-ai__empty">@Text("contentEditor.ai.unavailable")</p>
                    }
                </details>
            </aside>
        </div>
    }
</article>

<BocchiDialog Open="@_showAiSlugConfirm"
              Title='@Text("contentEditor.ai.confirm.title")'
              PrimaryText='@(_aiSlugBusy ? Text("contentEditor.ai.confirm.primaryBusy") : Text("contentEditor.action.continue"))'
              SecondaryText='@Text("contentEditor.action.cancel")'
              PrimaryDisabled="@_aiSlugBusy"
              CloseOnBackdrop="true"
              OnPrimary="GenerateAiSlugAsync"
              OnSecondary="CancelAiSlugConfirm"
              OnDismiss="CancelAiSlugConfirm">
    <p>@Text("contentEditor.ai.confirm.body")</p>
</BocchiDialog>

<BocchiDialog Open="@_showAiSlugFailure"
              Title='@Text("contentEditor.ai.failure.title")'
              PrimaryText='@Text("contentEditor.action.acknowledge")'
              CloseOnBackdrop="false"
              OnPrimary="CloseAiSlugFailure">
    <p>@Text("contentEditor.ai.failure.body")</p>
</BocchiDialog>

<BocchiDialog Open="@_showDeleteConfirm"
              Title="@DeleteConfirmTitle"
              PrimaryText="@DeleteConfirmPrimaryText"
              SecondaryText='@Text("contentEditor.action.cancel")'
              PrimaryClass="bocchi-dialog__danger"
              PrimaryDisabled="@_busy"
              CloseOnBackdrop="true"
              OnPrimary="ConfirmDeleteAsync"
              OnSecondary="CloseDeleteConfirm"
              OnDismiss="CloseDeleteConfirm">
    <p>@DeleteConfirmBody</p>
</BocchiDialog>
