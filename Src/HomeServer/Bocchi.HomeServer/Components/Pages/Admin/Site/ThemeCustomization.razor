@page "/Admin/Site/Theme"
@using System.Globalization
@using Bocchi.Generator.Theme
@using Bocchi.GeneratorContract
@inject SiteProfileSettingsService SiteProfileSettings
@inject ThemeSettingsService ThemeSettings
@inject ThemeMigrationService ThemeMigration
@inject LocalizationSettingsService LocalizationSettings
@inject NavigationManager Navigation
@inject DashboardLocalizationService I18n

<PageTitle>@I18n["themeCustomization.page.title"] · Bocchi</PageTitle>

<article class="bocchi-shell bocchi-shell--dashboard bocchi-theme-shell">
    <header class="bocchi-page-intro">
        <span class="bocchi-eyebrow">@I18n["themeCustomization.page.eyebrow"]</span>
        <h1>@I18n["themeCustomization.page.heading"]</h1>
        <p>@I18n["themeCustomization.page.description"]</p>
    </header>

    @if (_customization is null)
    {
        <section class="bocchi-panel">
            <p class="bocchi-theme-muted">@I18n["themeCustomization.loading"]</p>
        </section>
    }
    else
    {
        @* ── Theme 信息条 ── *@
        <div class="bocchi-theme-infobar">
            <div class="bocchi-theme-infobar__identity">
                <strong>@_customization.ThemeName</strong>
                <code>@_customization.ThemeId</code>
            </div>
            <div class="bocchi-theme-infobar__meta">
                <span>@ThemeSourceLabel(_customization.SourceKind)</span>
                @if (!string.IsNullOrWhiteSpace(_customization.Version))
                {
                    <span>v@_customization.Version</span>
                }
            </div>
            <label class="bocchi-theme-infobar__switcher" for="theme-switcher">
                <select
                    id="theme-switcher"
                    value="@_activeThemeId"
                    disabled="@(!CanSwitchTheme)"
                    aria-label='@I18n["themeCustomization.switcher.label"]'
                    aria-describedby="@SwitcherMessageId"
                    @onchange="args => SwitchThemeAsync(args.Value?.ToString() ?? _activeThemeId)">
                    @foreach (var theme in _availableThemes.Where(t => t.IsAvailable))
                    {
                        <option value="@theme.Id" selected="@string.Equals(theme.Id, _activeThemeId, StringComparison.Ordinal)">
                            @theme.Name
                        </option>
                    }
                </select>
            </label>
            @if (!string.IsNullOrWhiteSpace(SwitcherMessageText))
            {
                <p id="theme-switcher-message" class="bocchi-theme-infobar__message">@SwitcherMessageText</p>
            }
        </div>

        @* ── Section Tabs ── *@
        <div class="bocchi-theme-tabs" role="group" aria-label='@I18n["themeCustomization.tabs.aria"]'>
            <button
                type="button"
                class="@TabButtonClass(ConfigTab)"
                aria-pressed="@AriaBool(IsActiveTab(ConfigTab))"
                @onclick="() => SetActiveTab(ConfigTab)">
                <Blazicon Svg="Lucide.SlidersHorizontal" />
                <span>@I18n["themeCustomization.tabs.config"]</span>
            </button>
            <button
                type="button"
                class="@TabButtonClass(TextTab)"
                aria-pressed="@AriaBool(IsActiveTab(TextTab))"
                @onclick="() => SetActiveTab(TextTab)">
                <Blazicon Svg="Lucide.Languages" />
                <span>@I18n["themeCustomization.tabs.text"]</span>
            </button>
            <div class="bocchi-theme-tabs__spacer"></div>
            <button
                type="button"
                class="bocchi-button bocchi-button--primary bocchi-theme-tabs__save"
                disabled="@(!CanSaveChanges)"
                @onclick="SaveChangesAsync">
                <Blazicon Svg="Lucide.Save" />
                <span>@SaveButtonText</span>
            </button>
        </div>

        @* ── 状态行 ── *@
        @if (_configDirty || _themeI18nDirty || _configSaved || _themeI18nSaved || _customization.Diagnostics.Count > 0)
        {
            <div class="bocchi-theme-status-line" aria-live="polite">
                @if (_configDirty || _configSaved || _configMessage is not null)
                {
                    <BocchiStatusPill Tone="@ConfigStatusTone">@ConfigStatusText</BocchiStatusPill>
                }
                @if (_themeI18nDirty || _themeI18nSaved || _themeI18nMessage is not null)
                {
                    <BocchiStatusPill Tone="@ThemeI18nStatusTone">@ThemeI18nStatusText</BocchiStatusPill>
                }
                @foreach (var diagnostic in _customization.Diagnostics)
                {
                    <BocchiStatusPill Tone="@ThemeDiagnosticTone(diagnostic)">@ThemeDiagnosticText(diagnostic)</BocchiStatusPill>
                }
            </div>
        }

        @if (IsActiveTab(ConfigTab))
        {
            @if (_customization.Groups.Count == 0)
            {
                <section class="bocchi-panel bocchi-theme-empty">
                    <Blazicon Svg="Lucide.SlidersHorizontal" />
                    <h2>@I18n["themeCustomization.config.title"]</h2>
                    <p>@I18n["themeCustomization.config.empty"]</p>
                </section>
            }
            else
            {
                var activeConfigGroup = ActiveConfigGroup;

                @* ── Config 分组 pills ── *@
                <div class="bocchi-theme-group-pills" role="group" aria-label='@I18n["themeCustomization.config.groupNavAria"]'>
                    @foreach (var group in _customization.Groups)
                    {
                        <button
                            type="button"
                            class="@ConfigGroupPillClass(group)"
                            aria-pressed="@AriaBool(IsActiveConfigGroup(group))"
                            @onclick="() => SelectConfigGroup(group.Id)">
                            @group.Title
                        </button>
                    }
                </div>

                @* ── Config 字段 ── *@
                @if (activeConfigGroup is not null)
                {
                    <section class="bocchi-panel bocchi-theme-editor-panel" aria-labelledby="theme-config-heading">
                        <div class="bocchi-theme-panel-heading">
                            <h2 id="theme-config-heading">@activeConfigGroup.Title</h2>
                            <span>@string.Format(CultureInfo.CurrentCulture, I18n["themeCustomization.config.activeGroupCountFormat"], activeConfigGroup.Fields.Count)</span>
                        </div>

                        <div class="bocchi-theme-field-list">
                            @foreach (var field in activeConfigGroup.Fields)
                            {
                                @if (field.Type == ThemeConfigFieldType.Group)
                                {
                                    <div class="bocchi-theme-field-group">
                                        <strong>@field.Title</strong>
                                        @if (!string.IsNullOrWhiteSpace(field.Description))
                                        {
                                            <small>@field.Description</small>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <section class="bocchi-theme-field" aria-labelledby="@FieldLabelId(field)">
                                        <div class="bocchi-theme-field__label">
                                            <strong id="@FieldLabelId(field)">@field.Title</strong>
                                            <span class="bocchi-tooltip" tabindex="0" data-bocchi-tooltip="@field.Key" data-bocchi-tooltip-placement="bottom">
                                                <Blazicon Svg="Lucide.KeyRound" />
                                            </span>
                                            @if (UsesInlineColorTextFormat(field))
                                            {
                                                <span class="bocchi-tooltip" tabindex="0" data-bocchi-tooltip="@I18n["themeCustomization.field.inlineColorHelp"]" data-bocchi-tooltip-placement="bottom">
                                                    <Blazicon Svg="Lucide.Palette" />
                                                </span>
                                            }
                                        </div>
                                        <div class="bocchi-theme-field__control">
                                            <div class="bocchi-theme-field__control-row">
                                                @if (field.Type is not ThemeConfigFieldType.LocalizedText and not ThemeConfigFieldType.LocalizedTextList &&
                                                     !string.IsNullOrWhiteSpace(field.DefaultText))
                                                {
                                                    <span class="bocchi-theme-field__control-prefix bocchi-tooltip" tabindex="0" data-bocchi-tooltip="@string.Format(CultureInfo.CurrentCulture, I18n["themeCustomization.field.defaultValueFormat"], field.DefaultText)" data-bocchi-tooltip-placement="bottom">
                                                        <Blazicon Svg="Lucide.Settings2" />
                                                    </span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(field.Description))
                                                {
                                                    <span class="bocchi-theme-field__control-prefix bocchi-tooltip" tabindex="0" data-bocchi-tooltip="@field.Description" data-bocchi-tooltip-placement="bottom">
                                                        <Blazicon Svg="Lucide.Info" />
                                                    </span>
                                                }
                                                @switch (field.Type)
                                                {
                                                    case ThemeConfigFieldType.Boolean:
                                                        <label class="bocchi-theme-switch">
                                                            <input
                                                                type="checkbox"
                                                                role="switch"
                                                                aria-label="@field.Title"
                                                                checked="@GetBooleanValue(field.Key)"
                                                                @onchange="args => SetBooleanValue(field.Key, args)" />
                                                            <span class="bocchi-theme-switch__track" aria-hidden="true">
                                                                <span></span>
                                                            </span>
                                                            <span>@(GetBooleanValue(field.Key) ? I18n["themeCustomization.field.enabled"] : I18n["themeCustomization.field.disabled"])</span>
                                                        </label>
                                                        break;
                                                    case ThemeConfigFieldType.Number:
                                                        <input
                                                            type="number"
                                                            step="any"
                                                            aria-label="@field.Title"
                                                            value="@GetTextValue(field.Key)"
                                                            @oninput="args => SetTextValue(field.Key, args.Value?.ToString())" />
                                                        break;
                                                    case ThemeConfigFieldType.Select:
                                                        <select
                                                            aria-label="@field.Title"
                                                            value="@GetTextValue(field.Key)"
                                                            @onchange="args => SetTextValue(field.Key, args.Value?.ToString())">
                                                            <option value="">@I18n["themeCustomization.field.defaultOption"]</option>
                                                            @foreach (var option in field.Options)
                                                            {
                                                                <option value="@option.Value">@option.Label</option>
                                                            }
                                                        </select>
                                                        break;
                                                    case ThemeConfigFieldType.MultiSelect:
                                                        <div class="bocchi-theme-option-list" role="group" aria-label="@field.Title">
                                                            @foreach (var option in field.Options)
                                                            {
                                                                <label class="bocchi-theme-choice">
                                                                    <input
                                                                        type="checkbox"
                                                                        checked="@IsMultiSelectValueSelected(field.Key, option.Value)"
                                                                        @onchange="args => ToggleMultiSelectValue(field.Key, option.Value, args)" />
                                                                    <span>@option.Label</span>
                                                                </label>
                                                            }
                                                        </div>
                                                        break;
                                                    case ThemeConfigFieldType.LocalizedText:
                                                        <BocchiLocalizedInput Mode="BocchiLocalizedInputMode.SingleLine"
                                                                              Values="LocalizedTextValuesFor(field.Key)"
                                                                              ValuesChanged="dict => OnLocalizedTextChanged(field.Key, dict)"
                                                                              PrimaryLanguageCode="@_primaryLanguageCode"
                                                                              EnabledLanguageCodes="_enabledLanguageCodeList"
                                                                              AvailableLanguages="_availableLanguages"
                                                                              Placeholder="@GetDefaultLocalizedTextValue(field, _primaryLanguageCode)"
                                                                              PlaceholderValues="field.DefaultLocalizedTextValues"
                                                                              AriaLabel="@field.Title" />
                                                        break;
                                                    case ThemeConfigFieldType.LocalizedTextList:
                                                        <BocchiLocalizedInput Mode="BocchiLocalizedInputMode.MultiLine"
                                                                              Values="LocalizedTextListValuesFor(field.Key)"
                                                                              ValuesChanged="dict => OnLocalizedTextListChanged(field.Key, dict)"
                                                                              PrimaryLanguageCode="@_primaryLanguageCode"
                                                                              EnabledLanguageCodes="_enabledLanguageCodeList"
                                                                              AvailableLanguages="_availableLanguages"
                                                                              Placeholder="@GetDefaultLocalizedTextListValue(field, _primaryLanguageCode)"
                                                                              PlaceholderValues="GetDefaultLocalizedTextListPlaceholderValues(field)"
                                                                              Rows="3"
                                                                              AriaLabel="@field.Title" />
                                                        break;
                                                    case ThemeConfigFieldType.Color:
                                                        <div class="bocchi-color-field">
                                                            <input
                                                                type="color"
                                                                aria-label="@field.Title"
                                                                value="@InputColorValue(GetTextValue(field.Key))"
                                                                @oninput="args => SetTextValue(field.Key, args.Value?.ToString())" />
                                                            <input
                                                                type="text"
                                                                aria-label="@field.Title"
                                                                value="@GetTextValue(field.Key)"
                                                                placeholder="@FieldPlaceholder(field)"
                                                                @oninput="args => SetTextValue(field.Key, args.Value?.ToString())" />
                                                        </div>
                                                        break;
                                                    case ThemeConfigFieldType.Url:
                                                        <input
                                                            type="url"
                                                            aria-label="@field.Title"
                                                            value="@GetTextValue(field.Key)"
                                                            placeholder="@FieldPlaceholder(field)"
                                                            @oninput="args => SetTextValue(field.Key, args.Value?.ToString())" />
                                                        break;
                                                    case ThemeConfigFieldType.Image:
                                                    case ThemeConfigFieldType.String:
                                                        <input
                                                            type="text"
                                                            aria-label="@field.Title"
                                                            value="@GetTextValue(field.Key)"
                                                            placeholder="@FieldPlaceholder(field)"
                                                            @oninput="args => SetTextValue(field.Key, args.Value?.ToString())" />
                                                        break;
                                                    default:
                                                        <input
                                                            type="text"
                                                            aria-label="@field.Title"
                                                            value="@GetTextValue(field.Key)"
                                                            placeholder="@FieldPlaceholder(field)"
                                                            @oninput="args => SetTextValue(field.Key, args.Value?.ToString())" />
                                                        break;
                                                }
                                            </div>
                                            @if (!string.IsNullOrWhiteSpace(field.HelpText))
                                            {
                                                <div class="bocchi-theme-field__meta">
                                                    @if (!string.IsNullOrWhiteSpace(field.HelpText))
                                                    {
                                                        <span class="bocchi-tooltip" tabindex="0" data-bocchi-tooltip="@field.HelpText" data-bocchi-tooltip-placement="bottom">
                                                            <Blazicon Svg="Lucide.Info" />
                                                        </span>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </section>
                                }
                            }
                        </div>
                    </section>
                }
            }
        }
        else
        {
            var selectedThemeKey = SelectedThemeI18nKey;

            @* ── Theme 私有文本：key 选择器 + 编辑器 ── *@
            @if (_themeI18nKeys.Count == 0)
            {
                <section class="bocchi-panel bocchi-theme-empty">
                    <Blazicon Svg="Lucide.Languages" />
                    <h2>@I18n["settings.theme.i18nTitle"]</h2>
                    <p>@I18n["settings.theme.i18nEmpty"]</p>
                </section>
            }
            else
            {
                <div class="bocchi-theme-i18n-layout">
                    @* 左侧：可搜索的 key 列表 *@
                    <div class="bocchi-theme-i18n-picker">
                        <label class="bocchi-theme-i18n-picker__search" for="theme-i18n-search">
                            <Blazicon Svg="Lucide.Search" />
                            <input
                                id="theme-i18n-search"
                                type="search"
                                value="@_themeI18nSearch"
                                @oninput="args => SetThemeI18nSearch(args.Value?.ToString())"
                                placeholder='@I18n["settings.theme.i18nSearchPlaceholder"]' />
                        </label>
                        <div class="bocchi-theme-i18n-picker__list" role="group" aria-label='@I18n["themeCustomization.text.keyListAria"]'>
                            @if (FilteredThemeI18nKeys.Count == 0)
                            {
                                <p class="bocchi-theme-i18n-picker__empty">@I18n["settings.theme.i18nNoResults"]</p>
                            }
                            else
                            {
                                @foreach (var key in FilteredThemeI18nKeys)
                                {
                                    <button
                                        type="button"
                                        class="@ThemeI18nKeyPillClass(key)"
                                        aria-pressed="@AriaBool(IsSelectedThemeI18nKey(key))"
                                        @onclick="() => SelectThemeI18nKey(key.Key)">
                                        <code>@key.Key</code>
                                        <small>@key.Title</small>
                                    </button>
                                }
                            }
                        </div>
                    </div>

                    @* 右侧：编辑器 *@
                    @if (selectedThemeKey is not null)
                    {
                        <section class="bocchi-panel bocchi-theme-editor-panel" aria-labelledby="theme-i18n-heading">
                            <div class="bocchi-theme-panel-heading">
                                <div>
                                    <span>@I18n["settings.theme.i18nTitle"]</span>
                                    <h2 id="theme-i18n-heading">@selectedThemeKey.Title</h2>
                                </div>
                                <code>@selectedThemeKey.Key</code>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(selectedThemeKey.Description))
                            {
                                <p class="bocchi-theme-muted">@selectedThemeKey.Description</p>
                            }

                            <BocchiLocalizedInput Mode="BocchiLocalizedInputMode.SingleLine"
                                                  Values="ThemeI18nValuesFor(selectedThemeKey.Key)"
                                                  ValuesChanged="dict => OnThemeI18nValuesChanged(selectedThemeKey.Key, dict)"
                                                  PrimaryLanguageCode="@_primaryLanguageCode"
                                                  EnabledLanguageCodes="_enabledLanguageCodeList"
                                                  AvailableLanguages="_availableLanguages"
                                                  Placeholder="@GetThemeI18nDefaultValue(selectedThemeKey, _primaryLanguageCode)"
                                                  PlaceholderValues="selectedThemeKey.DefaultValues"
                                                  AriaLabel="@selectedThemeKey.Title" />
                        </section>
                    }
                </div>
            }
        }
    }
</article>
