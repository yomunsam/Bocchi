@page "/Admin/Site/Themes"

<PageTitle>@I18n["themeLibrary.page.title"] · Bocchi</PageTitle>

<article class="bocchi-themes-page">
    <header class="bocchi-themes-page__head">
        <h1>@I18n["themeLibrary.page.heading"]</h1>
        <p>@I18n["themeLibrary.page.description"]</p>
    </header>

    @if (_loading)
    {
        <p class="bocchi-themes-page__loading">@I18n["themeLibrary.loading"]</p>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(_pageFeedback))
        {
            <div class="bocchi-themes-feedback bocchi-themes-feedback--@_pageFeedbackTone" role="status">
                @_pageFeedback
            </div>
        }

        @* 当前前台正在使用的主题 *@
        <section class="bocchi-themes-now" aria-labelledby="themes-now-heading">
            <div class="bocchi-themes-now__label" id="themes-now-heading">@I18n["themeLibrary.current.label"]</div>
            <div class="bocchi-themes-now__body">
                <div class="bocchi-themes-now__identity">
                    <span class="bocchi-themes-now__status @($"bocchi-themes-now__status--{(ActiveIsHealthy ? "ok" : "bad")}")" aria-hidden="true"></span>
                    <div class="bocchi-themes-now__copy">
                        <strong>@(ActiveItem?.Name ?? _activeThemeId)</strong>
                        @if (ActiveItem is not null)
                        {
                            <span>@ThemeMetaLine(ActiveItem)</span>
                        }
                    </div>
                </div>
                <a class="bocchi-themes-now__customize" href="/Admin/Site/Theme">
                    <Blazicon Svg="Lucide.SlidersHorizontal" />
                    <span>@I18n["themeLibrary.current.customize"]</span>
                </a>
            </div>
            @if (ActiveItem is not null && !ActiveIsHealthy)
            {
                <p class="bocchi-themes-now__warning">@I18n["themeLibrary.current.status.bad"]</p>
            }
        </section>

        @* 可切换的主题列表 *@
        <section class="bocchi-themes-list" aria-labelledby="themes-list-heading">
            <div class="bocchi-themes-list__head">
                <h2 id="themes-list-heading">@I18n["themeLibrary.list.title"]</h2>
                <p>@I18n["themeLibrary.list.help"]</p>
            </div>

            @if (!_catalog.Any())
            {
                <p class="bocchi-themes-list__empty">@I18n["themeLibrary.list.empty"]</p>
            }
            else
            {
                <div class="bocchi-themes-cards">
                    @foreach (var item in OrderedCatalog)
                    {
                        var isActive = IsActiveTheme(item.Id);
                        <article class="@($"bocchi-themes-card{(isActive ? " bocchi-themes-card--active" : string.Empty)}{(!item.IsAvailable ? " bocchi-themes-card--disabled" : string.Empty)}")">
                            <div class="bocchi-themes-card__main">
                                <div class="bocchi-themes-card__title-row">
                                    <h3>@item.Name</h3>
                                    @if (isActive)
                                    {
                                        <span class="bocchi-themes-card__badge">@I18n["themeLibrary.list.active"]</span>
                                    }
                                    else if (!item.IsAvailable)
                                    {
                                        <span class="bocchi-themes-card__badge bocchi-themes-card__badge--muted">@I18n["themeLibrary.list.unavailable"]</span>
                                    }
                                </div>
                                <p class="bocchi-themes-card__meta">@ThemeMetaLine(item)</p>
                                @if (item.ShadowsInstalledTheme)
                                {
                                    <p class="bocchi-themes-card__note">@I18n["themeLibrary.list.shadowWarning"]</p>
                                }
                                @if (item.Diagnostics.Count > 0)
                                {
                                    <details class="bocchi-themes-card__issues">
                                        <summary>@I18n["themeLibrary.list.diagnostics"]</summary>
                                        <ul>
                                            @foreach (var diagnostic in item.Diagnostics)
                                            {
                                                <li class="@($"bocchi-themes-card__issue bocchi-themes-card__issue--{DiagnosticTone(diagnostic)}")">
                                                    @DiagnosticText(diagnostic)
                                                </li>
                                            }
                                        </ul>
                                    </details>
                                }
                                <details class="bocchi-themes-card__tech">
                                    <summary>@I18n["themeLibrary.list.details"]</summary>
                                    <dl>
                                        <div>
                                            <dt>@I18n["themeLibrary.list.details.id"]</dt>
                                            <dd><code>@item.Id</code></dd>
                                        </div>
                                        <div>
                                            <dt>@I18n["themeLibrary.list.details.root"]</dt>
                                            <dd><code>@item.Root</code></dd>
                                        </div>
                                    </dl>
                                </details>
                            </div>
                            @if (!isActive && item.IsAvailable)
                            {
                                <button type="button"
                                        class="bocchi-themes-card__switch"
                                        disabled="@_activationBusy"
                                        @onclick="() => RequestActivation(item)">
                                    @I18n["themeLibrary.list.switch"]
                                </button>
                            }
                        </article>
                    }
                </div>
            }
        </section>

        @* 安装新主题：默认折叠，不打断「查看 / 切换」主路径 *@
        <details class="bocchi-themes-install">
            <summary class="bocchi-themes-install__toggle">
                <Blazicon Svg="Lucide.Plus" />
                <span>@I18n["themeLibrary.install.title"]</span>
            </summary>
            <div class="bocchi-themes-install__body">
                <p>@I18n["themeLibrary.install.summary"]</p>

                <label class="@UploadDropzoneClass">
                    <InputFile OnChange="InspectUploadAsync"
                               accept=".zip,application/zip"
                               disabled="@_uploadBusy" />
                    <span class="bocchi-themes-install__dropzone-content">
                        <span class="bocchi-themes-install__dropzone-icon" aria-hidden="true">
                            <Blazicon Svg="Lucide.FileArchive" />
                        </span>
                        @if (string.IsNullOrWhiteSpace(_selectedFileName))
                        {
                            <span class="bocchi-themes-install__dropzone-title">@I18n["themeLibrary.install.chooseFile"]</span>
                            <span class="bocchi-themes-install__dropzone-hint">@I18n["themeLibrary.install.dropHint"]</span>
                        }
                        else
                        {
                            <span class="bocchi-themes-install__dropzone-title">@_selectedFileName</span>
                            <span class="bocchi-themes-install__dropzone-hint">@I18n["themeLibrary.install.replaceHint"]</span>
                        }
                        <span class="bocchi-themes-install__dropzone-format">@I18n["themeLibrary.install.hint"]</span>
                    </span>
                </label>

                @if (_uploadBusy)
                {
                    <p class="bocchi-themes-install__busy">@I18n["themeLibrary.install.inspecting"]</p>
                }

                @if (!string.IsNullOrWhiteSpace(_installFeedback))
                {
                    <div class="bocchi-themes-feedback bocchi-themes-feedback--@_installFeedbackTone" role="status">
                        @_installFeedback
                    </div>
                }

                @if (_inspection is not null)
                {
                    <section class="bocchi-themes-review" aria-labelledby="themes-review-heading">
                        <h3 id="themes-review-heading">@I18n["themeLibrary.install.review.title"]</h3>
                        <p class="bocchi-themes-review__name">@(_inspection.Name ?? I18n["themeLibrary.unknown"])</p>
                        <p class="bocchi-themes-review__meta">
                            @(_inspection.ThemeId ?? I18n["themeLibrary.unknown"])
                            @if (!string.IsNullOrWhiteSpace(_inspection.Version))
                            {
                                <span> · @string.Format(System.Globalization.CultureInfo.CurrentCulture, I18n["themeLibrary.versionFormat"], _inspection.Version)</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(_inspection.RunnerKind))
                            {
                                <span> · @RunnerLabel(_inspection.RunnerKind)</span>
                            }
                        </p>
                        @if (_inspection.Diagnostics.Count > 0)
                        {
                            <ul class="bocchi-themes-review__issues">
                                @foreach (var diagnostic in _inspection.Diagnostics)
                                {
                                    <li class="@($"bocchi-themes-card__issue bocchi-themes-card__issue--{DiagnosticTone(diagnostic)}")">
                                        @DiagnosticText(diagnostic)
                                    </li>
                                }
                            </ul>
                        }
                        @if (_inspection.RequiresTrust)
                        {
                            <label class="bocchi-themes-install__trust">
                                <input type="checkbox" @bind="_trustProcessRunner" />
                                <span>@I18n["themeLibrary.install.trustConfirm"]</span>
                            </label>
                        }
                        <button type="button"
                                class="bocchi-themes-install__submit"
                                disabled="@(!CanInstallInspection)"
                                @onclick="InstallInspectionAsync">
                            @InstallActionLabel
                        </button>
                    </section>
                }

                @if (_installResult is not null)
                {
                    <div class="bocchi-themes-install__done">
                        <button type="button"
                                class="bocchi-themes-install__submit"
                                disabled="@_activationBusy"
                                @onclick="ActivateInstalledAsync">
                            @I18n["themeLibrary.install.switchNow"]
                        </button>
                    </div>
                }
            </div>
        </details>

        @if (IsThemeDevelopmentMode)
        {
            <section class="bocchi-themes-dev" aria-labelledby="themes-dev-heading">
                <div class="bocchi-themes-dev__badge">@I18n["themeLibrary.dev.modeBadge"]</div>
                <h2 id="themes-dev-heading">@I18n["themeLibrary.dev.title"]</h2>
                <p>@I18n["themeLibrary.dev.notice"]</p>
                <p class="bocchi-themes-dev__path">@string.Format(System.Globalization.CultureInfo.CurrentCulture, I18n["themeLibrary.dev.pathHint"], DevLinksPath)</p>
                <p>@I18n["themeLibrary.dev.devLinksIntro"]</p>
                <figure class="bocchi-themes-dev__example">
                    <figcaption>@I18n["themeLibrary.dev.exampleCaption"]</figcaption>
                    <pre><code>@DevLinksExampleJson</code></pre>
                </figure>
                <a class="bocchi-themes-dev__docs"
                   href="https://github.com/yomunsam/Bocchi"
                   target="_blank"
                   rel="noopener noreferrer">
                    @I18n["themeLibrary.dev.docsLink"]
                    <Blazicon Svg="Lucide.ExternalLink" aria-hidden="true" />
                </a>
            </section>
        }
    }
</article>

<BocchiDialog Open="@(_pendingTrustThemeId is not null)"
              Title='@I18n["themeLibrary.trust.title"]'
              PrimaryText='@I18n["themeLibrary.trust.confirm"]'
              SecondaryText='@I18n["themeLibrary.trust.cancel"]'
              OnPrimary="ConfirmTrustAndActivateAsync"
              OnSecondary="CancelTrustDialog"
              OnDismiss="CancelTrustDialog">
    <p>@I18n["themeLibrary.trust.body"]</p>
    @if (!string.IsNullOrWhiteSpace(_pendingTrustThemeName))
    {
        <p><strong>@_pendingTrustThemeName</strong></p>
    }
</BocchiDialog>
