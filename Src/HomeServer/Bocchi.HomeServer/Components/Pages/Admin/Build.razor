@page "/Admin/Publish"
@page "/Admin/Publish/{Section}"
@page "/Admin/Publish/{Section}/{PlanId:int}"
@using System.Globalization
@using Bocchi.Generator.Pipeline
@using Bocchi.Generator.State
@using Bocchi.HomeServer.Build
@using Bocchi.HomeServer.Data
@using Bocchi.HomeServer.Services.Git
@using Bocchi.HomeServer.Services.Publishing
@inject BuildOrchestrator Orchestrator
@inject IBuildStateStore Store
@inject DashboardLocalizationService I18n
@inject PublishPlanService PublishPlans
@inject PublishExecutionService PublishExecution
@inject GitProviderConnectionService GitConnections
@inject GitHubDeviceFlowService GitHubFlow

<PageTitle>@CurrentPageTitle · Bocchi</PageTitle>

<article class="bocchi-shell bocchi-publish-shell">
    <header class="bocchi-page-intro">
        <span class="bocchi-eyebrow">@CurrentEyebrow</span>
        <h1>@CurrentHeading</h1>
        <p>@CurrentDescription</p>
    </header>

    @if (IsPublishHomeSection)
    {
        @if (_recent is null || _publishRuns is null || _publishPlans is null)
        {
            <section class="bocchi-panel bocchi-publish-loading">
                <p>@I18n["publish.loading"]</p>
            </section>
        }
        else
        {
            @RenderPublishDashboard()
        }
    }
    else
    {
        <div class="bocchi-publish-layout">
            <BocchiPublishNav ActiveSection="@CurrentSection" />

            <div class="bocchi-publish-stack">
                @if (IsLocalOutputSection)
                {
                    <section class="bocchi-panel bocchi-publish-local-output" aria-labelledby="publish-local-output-heading">
                        <span class="bocchi-publish-local-output__icon" aria-hidden="true">
                            <Blazicon Svg="Lucide.FolderOpen" />
                        </span>
                        <div>
                            <h2 id="publish-local-output-heading">@I18n["publish.localOutput.title"]</h2>
                            <p>@I18n["publish.localOutput.emptyDescription"]</p>
                        </div>
                    </section>
                }
                else if (IsAddPlanSection)
                {
                    @RenderAddPlanWorkbench()
                }
            </div>
        </div>
    }
</article>

@code {
    private const string LocalOutputSection = "LocalOutput";
    private const string AddPlanSection = "AddPlan";

    /// <summary>发布中心子路由片段；为空时展示默认“一键发布”首页。</summary>
    [Parameter]
    public string? Section { get; set; }

    /// <summary>发布方案编辑 id；为空表示新建方案。</summary>
    [Parameter]
    public int? PlanId { get; set; }

    /// <summary>一键发布运行中时禁用主操作，避免重复触发构建或远端发布。</summary>
    private bool _busy;

    /// <summary>当前页面触发的最近一次本地生成结果。</summary>
    private BuildResult? _lastResult;

    /// <summary>历史构建投影，来自 SQLite 状态库。</summary>
    private IReadOnlyList<BuildRunSummary>? _recent;

    /// <summary>最近发布运行投影，来自 Home Server EF 状态库。</summary>
    private IReadOnlyList<PublishRunRecord>? _publishRuns;

    /// <summary>发布方案列表；首页用它决定一键发布目标，发布方案区用它渲染空态或列表。</summary>
    private IReadOnlyList<PublishPlanRecord>? _publishPlans;

    /// <summary>Git provider 连接列表；发布方案向导可复用已有授权。</summary>
    private IReadOnlyList<GitProviderConnectionRecord>? _gitConnections;

    /// <summary>当前 GitHub 账号可选的 repository 列表；只在进入已有仓库选择时加载。</summary>
    private IReadOnlyList<GitHubRepository> _githubRepositories = [];

    /// <summary>已有 repository 选择器的搜索文本，同时允许输入 owner/repository 作为兜底。</summary>
    private string _githubRepositorySearch = string.Empty;

    /// <summary>repository 列表正在从 GitHub 加载。</summary>
    private bool _githubRepositoriesLoading;

    /// <summary>是否展开已有 repository 搜索下拉层。</summary>
    private bool _githubRepositoryPickerOpen;

    /// <summary>一键发布后的短状态消息。</summary>
    private string? _oneClickMessage;

    /// <summary>一键发布消息是否为失败态。</summary>
    private bool _oneClickMessageIsDanger;

    /// <summary>当前编辑的发布方案 id；为空表示新建。</summary>
    private int? _editingPlanId;

    /// <summary>发布方案名称，由用户定义，不使用渠道名代替。</summary>
    private string _planDisplayName = string.Empty;

    /// <summary>当前发布渠道；v1 只启用 GitHub Pages。</summary>
    private string _publishChannel = PublishPlanService.GitHubPagesChannel;

    /// <summary>当前选择的 Git provider 连接 id。</summary>
    private int? _selectedGitConnectionId;

    /// <summary>GitHub repository owner。</summary>
    private string _githubOwner = string.Empty;

    /// <summary>GitHub repository name。</summary>
    private string _githubRepository = string.Empty;

    /// <summary>创建发布专用 repository 时使用的名称。</summary>
    private string _githubNewRepository = "bocchi-site";

    /// <summary>是否创建 private repository；GitHub Pages 可用性取决于账号计划。</summary>
    private bool _githubCreatePrivateRepository;

    /// <summary>发布目标 repo 模式：create 或 existing。</summary>
    private string _githubDestinationMode = "create";

    /// <summary>GitHub Pages 输出 branch。</summary>
    private string _githubBranch = "gh-pages";

    /// <summary>是否发布后自动确保 GitHub Pages source 指向 branch 根目录。</summary>
    private bool _githubEnsurePagesSource = true;

    /// <summary>用户是否明确接管已有无 marker 的发布 branch。</summary>
    private bool _githubAllowBranchTakeover;

    /// <summary>GitHub Device Flow device code；只在授权流程中短暂保存。</summary>
    private string? _githubDeviceCode;

    /// <summary>GitHub Device Flow 用户验证码。</summary>
    private string? _githubUserCode;

    /// <summary>GitHub Device Flow 验证页面。</summary>
    private string? _githubVerificationUri;

    /// <summary>最近一次 branch 安全检查。</summary>
    private GitHubPublishBranchCheck? _githubBranchCheck;

    /// <summary>保存 GitHub Pages 配置时禁用按钮。</summary>
    private bool _githubSaving;

    /// <summary>GitHub Pages 配置面板的短状态消息。</summary>
    private string? _githubMessage;

    /// <summary>GitHub Pages 配置面板消息是否为失败态。</summary>
    private bool _githubMessageIsDanger;

    /// <summary>当前是否已经配置 GitHub OAuth App client id。</summary>
    private bool _githubAuthorizationConfigured;

    /// <summary>未启用 GitHub 授权时，把禁用按钮和解释文案关联起来。</summary>
    private string? GitHubAuthUnavailableNoticeId => _githubAuthorizationConfigured ? null : "github-auth-unavailable";

    /// <summary>规范化后的发布中心子页面。</summary>
    private string CurrentSection
    {
        get
        {
            if (string.Equals(Section, LocalOutputSection, StringComparison.OrdinalIgnoreCase))
            {
                return LocalOutputSection;
            }

            if (string.Equals(Section, AddPlanSection, StringComparison.OrdinalIgnoreCase))
            {
                return AddPlanSection;
            }

            return string.Empty;
        }
    }

    /// <summary>当前是否展示默认发布首页。</summary>
    private bool IsPublishHomeSection => string.IsNullOrEmpty(CurrentSection);

    /// <summary>当前是否展示本地输出子页面。</summary>
    private bool IsLocalOutputSection => CurrentSection == LocalOutputSection;

    /// <summary>当前是否展示添加发布方案子页面。</summary>
    private bool IsAddPlanSection => CurrentSection == AddPlanSection;

    /// <summary>默认发布方案；没有显式默认时使用列表第一项作为旧数据回退。</summary>
    private PublishPlanRecord? DefaultPublishPlan => _publishPlans?.FirstOrDefault(x => x.IsDefault) ?? _publishPlans?.FirstOrDefault();

    /// <summary>可用于发布向导的 GitHub 连接集合。</summary>
    private IEnumerable<GitProviderConnectionRecord> GitHubConnections
        => _gitConnections?.Where(x => x.ProviderKey == GitProviderKeys.GitHub)
            ?? Array.Empty<GitProviderConnectionRecord>();

    /// <summary>当前选中的 GitHub 连接；不存在时说明发布向导仍停留在授权步骤。</summary>
    private GitProviderConnectionRecord? SelectedGitHubConnection
        => _selectedGitConnectionId is null
            ? null
            : GitHubConnections.FirstOrDefault(x => x.Id == _selectedGitConnectionId.Value);

    /// <summary>是否已经有可用 GitHub 连接，决定仓库配置步骤是否展示。</summary>
    private bool HasSelectedGitHubConnection => SelectedGitHubConnection is not null;

    /// <summary>当前页面标题。</summary>
    private string CurrentPageTitle => CurrentSection switch
    {
        LocalOutputSection => I18n["publish.localOutput.pageTitle"],
        AddPlanSection => I18n["publish.addPlan.pageTitle"],
        _ => I18n["publish.page.title"],
    };

    /// <summary>当前页面 eyebrow。</summary>
    private string CurrentEyebrow => CurrentSection switch
    {
        LocalOutputSection => I18n["publish.localOutput.eyebrow"],
        AddPlanSection => I18n["publish.addPlan.eyebrow"],
        _ => I18n["publish.page.eyebrow"],
    };

    /// <summary>当前页面主标题。</summary>
    private string CurrentHeading => CurrentSection switch
    {
        LocalOutputSection => I18n["publish.localOutput.heading"],
        AddPlanSection => I18n["publish.addPlan.heading"],
        _ => I18n["publish.page.heading"],
    };

    /// <summary>当前页面说明。</summary>
    private string CurrentDescription => CurrentSection switch
    {
        LocalOutputSection => I18n["publish.localOutput.description"],
        AddPlanSection => I18n["publish.addPlan.description"],
        _ => I18n["publish.page.description"],
    };

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
        await LoadGitHubPublishAuthSettingsAsync();
        await LoadGitConnectionsAsync();
        await LoadPublishPlanEditorAsync();
    }

    /// <summary>读取近期生成记录和发布运行记录。</summary>
    private async Task RefreshAsync()
    {
        _recent = await Store.ListRecentRunsAsync(20, default);
        _publishRuns = await PublishExecution.ListRecentRunsAsync(20, default);
        _publishPlans = await PublishPlans.ListAsync(default);
    }

    /// <summary>读取 Git provider 连接，用于发布向导复用已有授权。</summary>
    private async Task LoadGitConnectionsAsync()
    {
        _gitConnections = await GitConnections.ListAsync(default);
        var githubConnections = GitHubConnections.ToArray();
        if (_selectedGitConnectionId is null || !githubConnections.Any(x => x.Id == _selectedGitConnectionId.Value))
        {
            _selectedGitConnectionId = githubConnections.FirstOrDefault()?.Id;
        }
    }

    /// <summary>读取 GitHub 发布授权设置，用于决定连接按钮是否可用。</summary>
    private async Task LoadGitHubPublishAuthSettingsAsync()
    {
        _githubAuthorizationConfigured = await GitHubFlow.IsConfiguredAsync(default);
    }

    /// <summary>发布首页：主操作、发布方案和辅助状态分栏展示，避免把配置表单压到第一屏。</summary>
    private RenderFragment RenderPublishDashboard() => @<div class="bocchi-publish-dashboard">
        <div class="bocchi-publish-main">
            @RenderOneClickCard()
            @RenderPublishPlans()
        </div>
        <aside class="bocchi-publish-aside" aria-label='@I18n["publish.side.aria"]'>
            @RenderSiteStatus()
            @RenderRecentActivity()
        </aside>
    </div>;

    /// <summary>渲染视觉中心的一键发布卡片；没有默认方案时退化为本地静态生成。</summary>
    private RenderFragment RenderOneClickCard() => @<section class="bocchi-panel bocchi-publish-hero" aria-labelledby="publish-one-click-heading">
        <span class="bocchi-publish-hero__icon" aria-hidden="true">
            <Blazicon Svg="Lucide.Send" />
        </span>
        <div class="bocchi-publish-hero__content">
            <div class="bocchi-publish-hero__heading">
                <h2 id="publish-one-click-heading">@I18n["publish.oneClick.title"]</h2>
                <BocchiStatusPill Tone="@OneClickTargetTone()">@OneClickTargetText()</BocchiStatusPill>
            </div>
            <p>@I18n["publish.oneClick.description"]</p>
            <form class="bocchi-publish-run-form" @onsubmit="PublishOneClickAsync" @onsubmit:preventDefault>
                <button type="submit" class="bocchi-publish-primary-action bocchi-publish-primary-action--hero" disabled="@_busy">
                    <Blazicon Svg="Lucide.Send" />
                    <span>@(_busy ? I18n["publish.action.publishing"] : I18n["publish.action.publishNow"])</span>
                </button>
                <div class="bocchi-publish-quick-actions">
                    <a class="bocchi-button secondary" href="/" target="_blank" rel="noopener">
                        <Blazicon Svg="Lucide.Eye" />
                        <span>@I18n["publish.action.preview"]</span>
                    </a>
                    <a class="bocchi-button secondary" href="/Admin/Publish/download" target="_blank" rel="noopener">
                        <Blazicon Svg="Lucide.Save" />
                        <span>@I18n["publish.action.downloadZip"]</span>
                    </a>
                </div>
            </form>
            @if (!string.IsNullOrWhiteSpace(_oneClickMessage))
            {
                <p class="@OneClickMessageClass()">@_oneClickMessage</p>
            }
            @RenderLastPublishMeta()
        </div>
    </section>;

    /// <summary>渲染发布方案区；无方案时只展示添加入口，不制造假渠道卡片。</summary>
    private RenderFragment RenderPublishPlans() => @<section class="bocchi-publish-plans" aria-labelledby="publish-plans-heading">
        <div class="bocchi-publish-section-heading">
            <div>
                <h2 id="publish-plans-heading">@I18n["publish.plans.title"]</h2>
                <p>@I18n["publish.plans.description"]</p>
            </div>
            <a class="bocchi-button secondary" href="/Admin/Publish/AddPlan">
                <Blazicon Svg="Lucide.Plus" />
                <span>@I18n["publish.plans.add"]</span>
            </a>
        </div>
        @if (_publishPlans is null)
        {
            <section class="bocchi-panel bocchi-publish-loading">
                <p>@I18n["publish.history.loading"]</p>
            </section>
        }
        else if (_publishPlans.Count == 0)
        {
            <div class="bocchi-panel bocchi-publish-plans-empty">
                <span aria-hidden="true"><Blazicon Svg="Lucide.Plus" /></span>
                <strong>@I18n["publish.plans.emptyTitle"]</strong>
                <p>@I18n["publish.plans.emptyDescription"]</p>
                <a class="bocchi-button bocchi-button--primary" href="/Admin/Publish/AddPlan">
                    <Blazicon Svg="Lucide.Plus" />
                    <span>@I18n["publish.plans.add"]</span>
                </a>
            </div>
        }
        else
        {
            <div class="bocchi-publish-plan-list">
                @foreach (var plan in _publishPlans)
                {
                    var editUrl = PlanEditUrl(plan);
                    <article class="bocchi-publish-plan-card">
                        <span class="bocchi-publish-plan-card__icon" aria-hidden="true">
                            @if (plan.Channel == PublishPlanService.GitHubPagesChannel)
                            {
                                <span class="bocchi-github-mark"></span>
                            }
                            else
                            {
                                <Blazicon Svg="@PlanChannelIcon(plan.Channel)" />
                            }
                        </span>
                        <div class="bocchi-publish-plan-card__main">
                            <strong>@plan.DisplayName</strong>
                            <span>@ChannelDisplayName(plan.Channel)</span>
                        </div>
                        @if (plan.IsDefault)
                        {
                            <BocchiStatusPill Tone="success">@I18n["publish.plans.default"]</BocchiStatusPill>
                        }
                        @if (editUrl is not null)
                        {
                            <a class="bocchi-publish-icon-link" href="@editUrl" title='@I18n["publish.plans.edit"]'>
                                <Blazicon Svg="Lucide.Pencil" />
                                <span class="bocchi-visually-hidden">@I18n["publish.plans.edit"]</span>
                            </a>
                        }
                    </article>
                }
            </div>
        }
    </section>;

    /// <summary>渲染添加发布方案向导；方案名、渠道和 GitHub 目标分层呈现。</summary>
    private RenderFragment RenderAddPlanWorkbench() => @<section class="bocchi-panel bocchi-publish-config" aria-labelledby="publish-add-plan-heading">
        <div class="bocchi-publish-output-heading">
            <span class="bocchi-publish-output-heading__icon" aria-hidden="true">
                <Blazicon Svg="Lucide.GitBranch" />
            </span>
            <div>
                <h2 id="publish-add-plan-heading">@I18n["publish.addPlan.formTitle"]</h2>
                <p>@I18n["publish.addPlan.formDescription"]</p>
            </div>
        </div>

        <form class="bocchi-form-grid bocchi-publish-github-form" @onsubmit="SaveGitHubPlanAsync" @onsubmit:preventDefault>
            <div class="bocchi-publish-github-fields">
                <label>@I18n["publish.plan.name"]
                    <input type="text" @bind="_planDisplayName" autocomplete="off" />
                </label>
                <label>@I18n["publish.plan.channel"]
                    <select @bind="_publishChannel">
                        <option value="@PublishPlanService.GitHubPagesChannel">@I18n["publish.channel.githubPages"]</option>
                    </select>
                </label>
            </div>

            @if (!HasSelectedGitHubConnection)
            {
                <div class="bocchi-publish-wizard-section">
                    <div class="bocchi-publish-wizard-section__heading">
                        <span class="bocchi-github-mark" aria-hidden="true"></span>
                        <div>
                            <strong>@I18n["publish.github.connectTitle"]</strong>
                            <span>@I18n["publish.github.connectDescription"]</span>
                        </div>
                    </div>
                    @if (!_githubAuthorizationConfigured)
                    {
                        <div id="github-auth-unavailable" class="bocchi-publish-provider-notice" role="status">
                            <Blazicon Svg="Lucide.ShieldAlert" />
                            <div>
                                <strong>@I18n["publish.github.authUnavailableTitle"]</strong>
                                <p>@I18n["publish.github.authUnavailableDescription"]</p>
                                <p>@I18n["publish.github.authUnavailableAction"]</p>
                                <a class="bocchi-publish-provider-notice__link" href="/Admin/Settings/Integrations/GitHub">
                                    <Blazicon Svg="Lucide.ExternalLink" />
                                    <span>@I18n["publish.github.openSetupHelp"]</span>
                                </a>
                            </div>
                        </div>
                    }
                    <div class="bocchi-publish-quick-actions">
                        <button type="button"
                                class="bocchi-button secondary"
                                @onclick="StartGitHubDeviceFlowAsync"
                                disabled="@(!_githubAuthorizationConfigured)"
                                aria-describedby="@GitHubAuthUnavailableNoticeId">
                            <span class="bocchi-github-mark" aria-hidden="true"></span>
                            <span>@I18n["publish.github.connect"]</span>
                        </button>
                        @if (!string.IsNullOrWhiteSpace(_githubUserCode) && !string.IsNullOrWhiteSpace(_githubVerificationUri))
                        {
                            <a class="bocchi-button secondary" href="@_githubVerificationUri" target="_blank" rel="noopener">
                                <Blazicon Svg="Lucide.ExternalLink" />
                                <span>@I18n["publish.github.openAuthorization"]</span>
                            </a>
                            <button type="button" class="bocchi-button secondary" @onclick="CompleteGitHubDeviceFlowAsync">
                                <Blazicon Svg="Lucide.Check" />
                                <span>@I18n["publish.github.completeAuthorization"]</span>
                            </button>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_githubUserCode))
                    {
                        <p class="bocchi-publish-remote-message">@string.Format(CultureInfo.CurrentCulture, I18n["publish.github.userCodeFormat"], _githubUserCode)</p>
                    }
                </div>
            }
            else
            {
                <div class="bocchi-publish-wizard-section">
                    <div class="bocchi-publish-wizard-section__heading">
                        <Blazicon Svg="Lucide.FolderGit2" />
                        <div>
                            <strong>@I18n["publish.github.repositoryTitle"]</strong>
                            <span>@I18n["publish.github.repositoryDescription"]</span>
                        </div>
                    </div>
                    <div class="bocchi-publish-connected-account">
                        <Blazicon Svg="Lucide.Check" />
                        <div>
                            <strong>@I18n["publish.github.connectedTitle"]</strong>
                            <label>@I18n["publish.github.connection"]
                                <select value="@_selectedGitConnectionId" @onchange="OnGitHubConnectionChanged">
                                    @foreach (var connection in GitHubConnections)
                                    {
                                        <option value="@connection.Id">@connection.AccountLogin</option>
                                    }
                                </select>
                            </label>
                        </div>
                    </div>
                    <label>@I18n["publish.github.destinationMode"]
                        <select value="@_githubDestinationMode" @onchange="OnGitHubDestinationModeChanged">
                            <option value="create">@I18n["publish.github.destinationCreate"]</option>
                            <option value="existing">@I18n["publish.github.destinationExisting"]</option>
                        </select>
                    </label>
                    @if (string.Equals(_githubDestinationMode, "create", StringComparison.Ordinal))
                    {
                        <div class="bocchi-publish-github-fields">
                            <label>@I18n["publish.github.newRepository"]
                                <input type="text" @bind="_githubNewRepository" autocomplete="off" />
                            </label>
                            <label>@I18n["publish.github.branch"]
                                <input type="text" @bind="_githubBranch" autocomplete="off" />
                            </label>
                        </div>
                        <label class="bocchi-checkbox bocchi-publish-github-check">
                            <input type="checkbox" @bind="_githubCreatePrivateRepository" />
                            @I18n["publish.github.privateRepository"]
                        </label>
                        <button type="button" class="bocchi-button secondary" @onclick="CreateGitHubRepositoryAsync" disabled="@(!HasSelectedGitHubConnection)">
                            <Blazicon Svg="Lucide.Plus" />
                            <span>@I18n["publish.github.createRepository"]</span>
                        </button>
                    }
                    else
                    {
                        <div class="bocchi-publish-github-fields bocchi-publish-github-fields--existing">
                            <div class="bocchi-publish-form-field bocchi-publish-form-field--wide">
                                <label for="github-repository-picker">@I18n["publish.github.repositoryPicker"]</label>
                                <div class="bocchi-publish-repo-picker">
                                    <div class="bocchi-publish-repo-picker__control">
                                        <Blazicon Svg="Lucide.Search" />
                                        <input id="github-repository-picker"
                                               type="search"
                                               value="@_githubRepositorySearch"
                                               @oninput="OnGitHubRepositorySearchInput"
                                               @onfocus="OpenGitHubRepositoryPickerAsync"
                                               role="combobox"
                                               aria-autocomplete="list"
                                               aria-expanded="@_githubRepositoryPickerOpen"
                                               aria-controls="github-repository-options"
                                               placeholder='@I18n["publish.github.repositorySearchPlaceholder"]'
                                               autocomplete="off" />
                                        <button type="button"
                                                class="secondary"
                                                title='@I18n["publish.github.refreshRepositories"]'
                                                aria-label='@I18n["publish.github.refreshRepositories"]'
                                                @onclick="RefreshGitHubRepositoriesAsync">
                                            <Blazicon Svg="Lucide.RefreshCw" />
                                        </button>
                                    </div>
                                    @if (_githubRepositoryPickerOpen)
                                    {
                                        <div id="github-repository-options" class="bocchi-publish-repo-picker__menu" role="listbox">
                                            @if (_githubRepositoriesLoading)
                                            {
                                                <p>@I18n["publish.github.repositoryPickerLoading"]</p>
                                            }
                                            else
                                            {
                                                var filteredRepositories = FilteredGitHubRepositories();
                                                if (filteredRepositories.Count == 0)
                                                {
                                                    <p>@I18n["publish.github.repositoryPickerEmpty"]</p>
                                                }
                                                else
                                                {
                                                    @foreach (var repository in filteredRepositories)
                                                    {
                                                        <button type="button"
                                                                class="bocchi-publish-repo-option"
                                                                role="option"
                                                                aria-selected="@string.Equals(repository.FullName, GitHubRepositoryFullName(), StringComparison.OrdinalIgnoreCase)"
                                                                @onclick="() => SelectGitHubRepository(repository)">
                                                            <span>@repository.FullName</span>
                                                            <small>@(repository.Private ? I18n["publish.github.repositoryPrivacyPrivate"] : I18n["publish.github.repositoryPrivacyPublic"])</small>
                                                        </button>
                                                    }
                                                }
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                            <label>@I18n["publish.github.branch"]
                                <input type="text" @bind="_githubBranch" autocomplete="off" />
                            </label>
                        </div>
                        <button type="button" class="bocchi-button secondary" @onclick="CheckGitHubBranchAsync" disabled="@(!HasSelectedGitHubConnection)">
                            <Blazicon Svg="Lucide.ShieldCheck" />
                            <span>@I18n["publish.github.checkBranch"]</span>
                        </button>
                        @if (_githubBranchCheck?.State == GitHubPublishBranchState.Occupied)
                        {
                            <label class="bocchi-checkbox bocchi-publish-github-check">
                                <input type="checkbox" @bind="_githubAllowBranchTakeover" />
                                @I18n["publish.github.allowTakeover"]
                            </label>
                        }
                    }
                </div>

                <label class="bocchi-checkbox bocchi-publish-github-check">
                    <input type="checkbox" @bind="_githubEnsurePagesSource" />
                    @I18n["publish.github.ensurePagesSource"]
                </label>
            }
            <div class="bocchi-publish-github-fields">
                <div class="bocchi-publish-quick-actions">
                    @if (HasSelectedGitHubConnection)
                    {
                        <button type="submit" class="bocchi-button bocchi-button--primary" disabled="@_githubSaving">
                            <Blazicon Svg="Lucide.Save" />
                            <span>@(_githubSaving ? I18n["publish.github.saving"] : I18n["publish.addPlan.save"])</span>
                        </button>
                    }
                    <a class="bocchi-button secondary" href="/Admin/Publish">
                        <Blazicon Svg="Lucide.ArrowLeft" />
                        <span>@I18n["publish.addPlan.back"]</span>
                    </a>
                </div>
            </div>
        </form>

        @if (!string.IsNullOrWhiteSpace(_githubMessage))
        {
            <p class="@GitHubMessageClass()">@_githubMessage</p>
        }
    </section>;

    /// <summary>渲染最近一次生成的轻量状态条，让用户知道主按钮上次是否成功。</summary>
    private RenderFragment RenderLastPublishMeta() => @<div class="bocchi-publish-run-meta">
        <span>@LatestPublishSummary()</span>
        <span>@LatestPublishArtifactSummary()</span>
