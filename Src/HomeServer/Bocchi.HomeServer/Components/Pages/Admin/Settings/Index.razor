@page "/Admin/Settings"
@page "/Admin/Settings/{Section}"
@using Bocchi.Workspace
@inject SiteProfileSettingsService SiteProfileSettings
@inject ExternalLoginSettingsService ExternalLogins
@inject LocalizationSettingsService LocalizationSettings
@inject ThemeMigrationService ThemeMigration
@inject NavigationManager Navigation
@inject DashboardLocalizationService I18n
@inject BocchiDataLayout Layout

<PageTitle>@CurrentPageTitle · Bocchi</PageTitle>

<article class="bocchi-shell bocchi-shell--dashboard bocchi-settings-shell">
    <header class="bocchi-page-intro">
        <span class="bocchi-eyebrow">@I18n["settings.page.eyebrow"]</span>
        <h1>@CurrentHeading</h1>
        <p>@CurrentDescription</p>
    </header>

    @if (IsSettingsHub)
    {
        <section class="bocchi-quick-actions bocchi-settings-hub" aria-label='@I18n["settings.nav.aria"]'>
            @foreach (var card in HubCards)
            {
                <a class="bocchi-quick-card bocchi-settings-hub-card" href="@card.Url">
                    <span class="bocchi-quick-card__icon bocchi-quick-card__icon--@card.Tone">
                        <Blazicon Svg="@card.Icon" />
                    </span>
                    <span class="bocchi-quick-card__body">
                        <strong>@I18n[card.TitleKey]</strong>
                        <span>@I18n[card.DescriptionKey]</span>
                    </span>
                </a>
            }
        </section>
    }
    else
    {
        <div class="bocchi-settings-layout">
            <BocchiSettingsNav ActiveSection="@CurrentSection" />

            <div class="bocchi-settings-stack">
                @switch (CurrentSection)
                {
                    case ProfileSection:
                        <section class="bocchi-panel bocchi-settings-section" aria-labelledby="settings-profile-heading">
                            <div class="bocchi-section-heading">
                                <h2 id="settings-profile-heading">@I18n["settings.profile.title"]</h2>
                                <p>@I18n["settings.profile.description"]</p>
                            </div>
                            <form class="bocchi-form-grid bocchi-settings-form" @onsubmit="SaveBasicInfoAsync" @onsubmit:preventDefault>
                                <label>
                                    @I18n["settings.profile.siteName"]
                                    <input type="text" @bind="_siteName" />
                                </label>
                                <label>
                                    @I18n["settings.profile.defaultTitle"]
                                    <input type="text" @bind="_defaultTitle" />
                                </label>
                                <label>
                                    @I18n["settings.profile.publicBaseUrl"]
                                    <input type="url" @bind="_publicBaseUrl" />
                                </label>
                                <label>
                                    @I18n["settings.profile.defaultTheme"]
                                    <input type="text" @bind="_siteDefaultThemeId" />
                                </label>
                                <label>
                                    @I18n["settings.profile.timeZone"]
                                    <input type="text" @bind="_siteTimeZone" />
                                </label>
                                <label>
                                    @I18n["settings.profile.descriptionField"]
                                    <input type="text" @bind="_siteDescription" />
                                </label>
                                <label>
                                    @I18n["settings.profile.copyright"]
                                    <input type="text" @bind="_copyrightNotice" />
                                </label>
                                <div class="bocchi-inline-actions">
                                    <button type="submit">
                                        <Blazicon Svg="Lucide.Save" />
                                        <span>@I18n["settings.profile.save"]</span>
                                    </button>
                                    @if (_basicSaved)
                                    {
                                        <BocchiStatusPill Tone="success">@I18n["settings.profile.saved"]</BocchiStatusPill>
                                    }
                                </div>
                            </form>
                        </section>
                        break;
                    case LocalizationSection:
                        <section class="bocchi-panel bocchi-settings-section" aria-labelledby="settings-localization-heading">
                <div class="bocchi-section-heading">
                    <h2 id="settings-localization-heading">@I18n["settings.localization.title"]</h2>
                    <p>@I18n["settings.localization.description"]</p>
                </div>

                <div class="bocchi-localization-grid">
                    <div class="bocchi-localization-card">
                        <h3>@I18n["settings.localization.dashboardTitle"]</h3>
                        <p>@I18n["settings.localization.dashboardDescription"]</p>
                        <form class="bocchi-form-grid" method="post" action="/Admin/Settings/Localization/UiLanguage">
                            <input type="hidden" name="returnUrl" value="/Admin/Settings/Localization" />
                            <label>
                                @I18n["settings.localization.dashboardTitle"]
                                <select name="uiLanguage" aria-label='@I18n["topbar.language.aria"]'>
                                    @foreach (var language in DashboardLocalizationService.SupportedDashboardLanguages)
                                    {
                                        <option value="@language.Code" selected="@IsCurrentDashboardLanguage(language.Code)">@language.DisplayName</option>
                                    }
                                </select>
                            </label>
                            <button type="submit" class="secondary">@I18n["settings.localization.saveUiLanguage"]</button>
                        </form>
                    </div>

                    <div class="bocchi-localization-card">
                        <h3>@I18n["settings.localization.siteTitle"]</h3>
                        <div class="bocchi-form-grid">
                            @{
                                var filteredLanguages = FilteredAvailableLanguages;
                                var enabledLanguages = EnabledLanguagesForDisplay;
                            }
                            <label>
                                @I18n["settings.localization.primaryLanguage"]
                                <select @bind="PrimaryLanguage">
                                    @foreach (var language in _availableLanguages)
                                    {
                                        <option value="@language.Code">@language.DisplayName</option>
                                    }
                                </select>
                            </label>

                            <div class="bocchi-language-picker" aria-label='@I18n["settings.localization.enabledLanguages"]'>
                                <span class="bocchi-language-picker__label">@I18n["settings.localization.enabledLanguages"]</span>
                                <div class="bocchi-language-picker__chips">
                                    @foreach (var language in enabledLanguages)
                                    {
                                        <span class="bocchi-language-chip @(IsPrimaryLanguage(language.Code) ? "is-primary" : null)">
                                            <strong>@language.NativeName</strong>
                                            <code>@language.Code</code>
                                            @if (!IsPrimaryLanguage(language.Code))
                                            {
                                                <button type="button" class="bocchi-language-chip__remove" aria-label='@I18n["settings.localization.disableLanguage"]' @onclick="() => DisableLanguage(language.Code)">
                                                    <Blazicon Svg="Lucide.X" />
                                                </button>
                                            }
                                        </span>
                                    }
                                    <details class="bocchi-language-picker__popover">
                                        <summary class="bocchi-language-chip bocchi-language-chip--add">
                                            <Blazicon Svg="Lucide.Plus" />
                                            <span>@I18n["settings.localization.addLanguage"]</span>
                                        </summary>
                                        <div class="bocchi-language-picker__menu" role="dialog">
                                            <input
                                                type="search"
                                                @bind="_languageSearch"
                                                @bind:event="oninput"
                                                placeholder='@I18n["settings.localization.searchLanguagesPlaceholder"]'
                                                aria-label='@I18n["settings.localization.searchLanguages"]' />
                                            <div class="bocchi-language-picker__list">
                                                @if (filteredLanguages.Count == 0)
                                                {
                                                    <p>@I18n["settings.localization.noLanguageResults"]</p>
                                                }
                                                @foreach (var language in filteredLanguages)
                                                {
                                                    <label class="bocchi-language-option">
                                                        <input
                                                            type="checkbox"
                                                            checked="@IsLanguageEnabled(language.Code)"
                                                            disabled="@IsPrimaryLanguage(language.Code)"
                                                            @onchange="args => ToggleEnabledLanguage(language.Code, args)" />
                                                        <span>
                                                            <strong>@language.NativeName</strong>
                                                            <small>@language.EnglishName · @language.Code</small>
                                                        </span>
                                                    </label>
                                                }
                                            </div>
                                            <p class="bocchi-language-picker__hint">@I18n["settings.localization.primaryIncluded"]</p>
                                        </div>
                                    </details>
                                </div>
                            </div>

                            <dl class="bocchi-meta-list">
                                <div>
                                    <dt>@I18n["settings.localization.urlPolicy"]</dt>
                                    <dd><code>@_urlPolicy</code> — @I18n["settings.localization.urlPolicyValue"]</dd>
                                </div>
                            </dl>

                            <button type="button" @onclick="SaveLocalizationAsync">@I18n["settings.localization.saveSite"]</button>
                            @if (!string.IsNullOrWhiteSpace(_localizationMessage))
                            {
                                <p class="bocchi-localization-message">
                                    <BocchiStatusPill Tone="@(_localizationSaved ? "success" : "warning")">@(_localizationSaved ? I18n["settings.localization.saved"] : I18n["settings.localization.needsAttention"])</BocchiStatusPill>
                                    @_localizationMessage
                                </p>
                            }
                        </div>
                    </div>

                    <div class="bocchi-localization-card bocchi-localization-card--wide">
                        <h3>@I18n["settings.localization.customTitle"]</h3>
                        <p>@I18n["settings.localization.customDescription"]</p>
                        <div class="bocchi-custom-language-form">
                            <label>
                                @I18n["settings.localization.customCode"]
                                <input type="text" @bind="_customLanguageCode" placeholder="en-GB" />
                            </label>
                            <label>
                                @I18n["settings.localization.customNativeName"]
                                <input type="text" @bind="_customLanguageNativeName" placeholder="English (UK)" />
                            </label>
                            <label>
                                @I18n["settings.localization.customEnglishName"]
                                <input type="text" @bind="_customLanguageEnglishName" placeholder="British English" />
                            </label>
                            <button type="button" class="secondary" @onclick="AddCustomLanguage">@I18n["settings.localization.addCustom"]</button>
                        </div>

                        @if (_customLanguages.Count > 0)
                        {
                            <div class="bocchi-language-chip-list">
                                @foreach (var language in _customLanguages)
                                {
                                    <span class="bocchi-language-chip">
                                        @language.DisplayName
                                        <button type="button" class="secondary" @onclick="() => RemoveCustomLanguage(language.Code)">@I18n["settings.localization.removeCustom"]</button>
                                    </span>
                                }
                            </div>
                        }
                    </div>

                    <div class="bocchi-localization-card bocchi-localization-card--wide">
                        <h3>@I18n["settings.localization.commonTextTitle"]</h3>
                        <p>@I18n["settings.localization.commonTextDescription"]</p>
                        @{
                            var commonKeys = FilteredCommonI18nKeys;
                            var selectedCommonKey = ResolveSelectedCommonKey(commonKeys);
                        }
                        <div class="bocchi-common-i18n">
                            <aside class="bocchi-common-i18n__list" aria-label='@I18n["settings.localization.commonTextTitle"]'>
                                <input
                                    type="search"
                                    @bind="_commonKeySearch"
                                    @bind:event="oninput"
                                    placeholder='@I18n["settings.localization.commonTextSearchPlaceholder"]'
                                    aria-label='@I18n["settings.localization.commonTextSearch"]' />
                                @if (commonKeys.Count == 0)
                                {
                                    <p class="bocchi-common-i18n__empty">@I18n["settings.localization.commonTextNoResults"]</p>
                                }
                                else
                                {
                                    <ul>
                                        @foreach (var key in commonKeys)
                                        {
                                            var isActive = string.Equals(key, selectedCommonKey, StringComparison.Ordinal);
                                            var translated = CountCommonTranslations(key);
                                            <li>
                                                <button type="button"
                                                        class="bocchi-common-i18n__key @(isActive ? "is-active" : null)"
                                                        @onclick="() => _selectedCommonKey = key">
                                                    <code>@key</code>
                                                    @if (translated > 0)
                                                    {
                                                        <span class="bocchi-common-i18n__count">
                                                            <Blazicon Svg="Lucide.Languages" />
                                                            <span>@translated</span>
                                                        </span>
                                                    }
                                                </button>
                                            </li>
                                        }
                                    </ul>
                                }
                            </aside>

                            <section class="bocchi-common-i18n__detail">
                                @if (selectedCommonKey is null)
                                {
                                    <div class="bocchi-common-i18n__placeholder">
                                        <Blazicon Svg="Lucide.Languages" />
                                        <p>@I18n["settings.localization.commonTextSelectKey"]</p>
                                    </div>
                                }
                                else
                                {
                                    <header class="bocchi-common-i18n__header">
                                        <code>@selectedCommonKey</code>
                                    </header>
                                    <BocchiLocalizedInput Mode="BocchiLocalizedInputMode.SingleLine"
                                                          Values="CommonTextValuesFor(selectedCommonKey)"
                                                          ValuesChanged="dict => OnCommonTextValuesChanged(selectedCommonKey, dict)"
                                                          PrimaryLanguageCode="@_primaryLanguage"
                                                          EnabledLanguageCodes="EnabledLanguageCodeList"
                                                          AvailableLanguages="_availableLanguages"
                                                          AriaLabel="@selectedCommonKey" />
                                }
                            </section>
                        </div>

                        <button type="button" class="secondary" @onclick="SaveCommonTextOverridesAsync">@I18n["settings.localization.commonTextSave"]</button>
                        @if (!string.IsNullOrWhiteSpace(_commonTextMessage))
                        {
                            <p class="bocchi-localization-message">
                                <BocchiStatusPill Tone="@(_commonTextSaved ? "success" : "warning")">@(_commonTextSaved ? I18n["settings.localization.saved"] : I18n["settings.localization.needsAttention"])</BocchiStatusPill>
                                @_commonTextMessage
                            </p>
                        }
                    </div>
                </div>
            </section>
                        break;
                    case LoginSection:
                        <section class="bocchi-panel bocchi-settings-section" aria-labelledby="settings-login-heading">
                            <div class="bocchi-section-heading">
                                <h2 id="settings-login-heading">@I18n["settings.login.title"]</h2>
                                <p>@I18n["settings.login.description"]</p>
                            </div>
                            <div class="bocchi-provider-grid">
                                <div class="bocchi-provider-card bocchi-provider-card--link">
                                    <h3>@I18n["settings.login.githubTitle"]</h3>
                                    <p>@I18n["settings.login.githubDescription"]</p>
                                    <a class="bocchi-button secondary" href="/Admin/Settings/Integrations/GitHub">
                                        <Blazicon Svg="Lucide.Link" />
                                        <span>@I18n["settings.login.openGitHubIntegration"]</span>
                                    </a>
                                </div>

                                <div class="bocchi-provider-card">
                                    <h3>OpenID Connect</h3>
                                    <label class="bocchi-checkbox"><input type="checkbox" @bind="_oidc.Enabled" />@I18n["settings.login.enabled"]</label>
                                    <label>@I18n["settings.login.displayName"]<input type="text" @bind="_oidc.DisplayName" /></label>
                                    <label>@I18n["settings.login.authority"]<input type="text" @bind="_oidc.Authority" /></label>
                                    <label>@I18n["settings.login.clientId"]<input type="text" @bind="_oidc.ClientId" /></label>
                                    <label>@I18n["settings.login.clientSecret"]<input type="password" @bind="_oidc.ClientSecret" placeholder='@I18n["settings.login.secretPlaceholder"]' /></label>
                                    <label>@I18n["settings.login.callbackPath"]<input type="text" @bind="_oidc.CallbackPath" /></label>
                                    <label>@I18n["settings.login.scopes"]<input type="text" @bind="_oidc.Scopes" /></label>
                                    <button type="button" class="secondary" @onclick="SaveOidcAsync">@I18n["settings.login.saveOidc"]</button>
                                </div>
                            </div>
                            @if (_loginSaved)
                            {
                                <p class="bocchi-settings-message">
                                    <BocchiStatusPill Tone="success">@I18n["settings.login.saved"]</BocchiStatusPill>
                                    @I18n["settings.login.savedDescription"]
                                </p>
                            }
                        </section>
                        break;
                    case SystemSection:
                        <div class="bocchi-settings-system-grid">
                            <section class="bocchi-panel bocchi-settings-section" aria-labelledby="settings-system-database-heading">
                                <div class="bocchi-section-heading">
                                    <h2 id="settings-system-database-heading">@I18n["settings.system.databaseTitle"]</h2>
                                    <p>@I18n["settings.system.databaseDescription"]</p>
                                </div>
                                <dl class="bocchi-meta-list">
                                    <div>
                                        <dt>SQLite</dt>
                                        <dd><code>@Layout.SqliteDatabasePath</code></dd>
                                    </div>
                                    <div>
                                        <dt>@I18n["settings.system.dataProtectionKeys"]</dt>
                                        <dd><code>@System.IO.Path.Combine(Layout.StateDirectory, "data-protection-keys")</code></dd>
                                    </div>
                                </dl>
                            </section>

                            <section class="bocchi-panel bocchi-settings-section" aria-labelledby="settings-system-data-heading">
                                <div class="bocchi-section-heading">
                                    <h2 id="settings-system-data-heading">@I18n["settings.system.dataTitle"]</h2>
                                    <p>@I18n["settings.system.dataDescription"]</p>
                                </div>
                                <dl class="bocchi-meta-list">
                                    <div>
                                        <dt>DataRoot</dt>
                                        <dd><code>@Layout.DataRoot</code></dd>
                                    </div>
                                    <div>
                                        <dt>Workspace</dt>
                                        <dd><code>@Layout.WorkspaceRoot</code></dd>
                                    </div>
                                    <div>
                                        <dt>@I18n["settings.system.output"]</dt>
                                        <dd><code>@Layout.PublicOutputDirectory</code></dd>
                                    </div>
                                </dl>
                            </section>
                        </div>
                        break;
                }
            </div>
        </div>
    }
</article>

@code {
    /// <summary>Settings 子路由片段；为空时展示 Settings hub。</summary>
    [Parameter] public string? Section { get; set; }

    /// <summary>站点资料子页路由片段。</summary>
    private const string ProfileSection = "profile";

    /// <summary>本地化子页路由片段。</summary>
    private const string LocalizationSection = "localization";

    /// <summary>登录设置子页路由片段。</summary>
    private const string LoginSection = "login";

    /// <summary>系统信息子页路由片段。</summary>
    private const string SystemSection = "system";

    /// <summary>Settings hub 卡片定义，复用 Overview quick-card 的正式视觉语言。</summary>
    private static readonly SettingsHubCard[] HubCards =
    [
        new("/Admin/Settings/Profile", "settings.nav.profile", "settings.nav.profileDescription", Lucide.SlidersHorizontal, "pink"),
        new("/Admin/Settings/Localization", "settings.nav.localization", "settings.nav.localizationDescription", Lucide.Languages, "lavender"),
        new("/Admin/Settings/Login", "settings.nav.login", "settings.nav.loginDescription", Lucide.KeyRound, "blue"),
        new("/Admin/Settings/Integrations/GitHub", "settings.nav.githubIntegration", "settings.nav.githubIntegrationDescription", Lucide.Link, "blue"),
        new("/Admin/Users", "settings.nav.users", "settings.nav.usersDescription", Lucide.Users, "green"),
        new("/Admin/Settings/System", "settings.nav.system", "settings.nav.systemDescription", Lucide.Database, "blue"),
        new("/Admin/Site/Theme", "nav.themeCustomization", "settings.nav.themeDescription", Lucide.SunMoon, "pink"),
    ];

    /// <summary>规范化后的当前 Settings section；未知片段回到 hub，避免空页面。</summary>
    private string CurrentSection => NormalizeSection(Section);

    /// <summary>当前是否展示 Settings hub。</summary>
    private bool IsSettingsHub => CurrentSection.Length == 0;

    /// <summary>当前浏览器标题。</summary>
    private string CurrentPageTitle => IsSettingsHub ? I18n["settings.page.title"] : I18n[$"settings.{CurrentSection}.title"];

    /// <summary>当前页主标题。</summary>
    private string CurrentHeading => IsSettingsHub ? I18n["settings.page.heading"] : I18n[$"settings.{CurrentSection}.title"];

    /// <summary>当前页说明文案。</summary>
    private string CurrentDescription => IsSettingsHub ? I18n["settings.page.description"] : I18n[$"settings.{CurrentSection}.description"];

    /// <summary>站点名称编辑缓冲区。</summary>
    private string _siteName = "Bocchi";

    /// <summary>默认前台标题编辑缓冲区。</summary>
    private string _defaultTitle = "Bocchi";

    /// <summary>站点描述编辑缓冲区。</summary>
    private string _siteDescription = string.Empty;

    /// <summary>公开前台 URL 编辑缓冲区。</summary>
    private string _publicBaseUrl = string.Empty;

    /// <summary>版权文案编辑缓冲区。</summary>
    private string _copyrightNotice = string.Empty;

    /// <summary>站点基础约定中的默认前台 Theme id。</summary>
    private string _siteDefaultThemeId = "default-static";

    /// <summary>站点默认时区编辑缓冲区。</summary>
    private string _siteTimeZone = "Asia/Shanghai";

    /// <summary>站点主要语言编辑缓冲区。</summary>
    private string _primaryLanguage = LocalizationSettingsService.DefaultPrimaryLanguage;

    /// <summary>站点主要语言双向绑定入口；变更时立即保证主要语言处于启用集合中。</summary>
    private string PrimaryLanguage
    {
        get => _primaryLanguage;
        set
        {
            _primaryLanguage = string.IsNullOrWhiteSpace(value)
                ? LocalizationSettingsService.DefaultPrimaryLanguage
                : value.Trim();
            _enabledLanguageCodes.Add(_primaryLanguage);
            _localizationSaved = false;
        }
    }

    /// <summary>站点启用语言编辑缓冲区。</summary>
    private HashSet<string> _enabledLanguageCodes = new(StringComparer.OrdinalIgnoreCase);

    /// <summary>自定义语言编辑缓冲区。</summary>
    private List<LanguageRecord> _customLanguages = [];

    /// <summary>Picklist 可用语言，内置语言在前，自定义语言在后。</summary>
    private IReadOnlyList<LanguageRecord> _availableLanguages = LocalizationSettingsService.BuiltInLanguages;

    /// <summary>Language Picklist 搜索词，匹配 code、nativeName 和 englishName。</summary>
    private string _languageSearch = string.Empty;

    /// <summary>Common i18n key 搜索词，用来让覆盖列表保持低密度。</summary>
    private string _commonKeySearch = string.Empty;

    /// <summary>右侧详情面板当前编辑的 Common i18n key；未选择时回退到列表第一项。</summary>
    private string? _selectedCommonKey;

    /// <summary>Common i18n 覆盖编辑缓冲区，形态为 key -> language -> plain text。</summary>
    private Dictionary<string, Dictionary<string, string>> _commonTextOverrides = new(StringComparer.Ordinal);

    /// <summary>URL policy 显示缓冲区；M6 固定为 PrimaryUnprefixed。</summary>
    private string _urlPolicy = LocalizationSettingsService.PrimaryUnprefixedUrlPolicy;

    /// <summary>自定义语言 code 输入。</summary>
    private string _customLanguageCode = string.Empty;

    /// <summary>自定义语言 nativeName 输入。</summary>
    private string _customLanguageNativeName = string.Empty;

    /// <summary>自定义语言 englishName 输入。</summary>
    private string _customLanguageEnglishName = string.Empty;

    /// <summary>OIDC Provider 表单状态。</summary>
    private ProviderForm _oidc = new();

    /// <summary>Basic Info 保存反馈。</summary>
    private bool _basicSaved;

    /// <summary>本地化设置保存反馈。</summary>
    private bool _localizationSaved;

    /// <summary>本地化设置保存后的说明文本。</summary>
    private string? _localizationMessage;

    /// <summary>第三方登录保存反馈。</summary>
    private bool _loginSaved;

    /// <summary>Common i18n 覆盖保存反馈。</summary>
    private bool _commonTextSaved;

    /// <summary>Common i18n 覆盖保存后的说明文本。</summary>
    private string? _commonTextMessage;

    protected override async Task OnInitializedAsync()
    {
        var site = await SiteProfileSettings.GetAsync();
        _siteName = site.SiteName;
        _defaultTitle = site.DefaultTitle;
        _siteDescription = site.Description;
        _publicBaseUrl = site.PublicBaseUrl;
        _copyrightNotice = site.CopyrightNotice;
        _siteDefaultThemeId = site.DefaultThemeId;
        _siteTimeZone = site.TimeZone;
        await LoadLocalizationAsync();

        foreach (var provider in await ExternalLogins.ListAsync())
        {
            var form = new ProviderForm
            {
                Enabled = provider.Enabled,
                DisplayName = provider.DisplayName,
                ClientId = provider.ClientId,
                CallbackPath = provider.CallbackPath,
                Authority = provider.Authority,
                Scopes = provider.Scopes,
            };
            if (provider.ProviderKey == "oidc")
            {
                _oidc = form;
            }
        }
    }

    /// <summary>保存站点基础约定；Dashboard 明暗外观已收敛到顶栏客户端控件。</summary>
    private async Task SaveBasicInfoAsync()
    {
        // 检测 Theme 是否变更；有 Menu 里的 i18n://theme@ 引用时跳转到迁移向导。
        var current = await SiteProfileSettings.GetAsync();
        var newTheme = (_siteDefaultThemeId ?? string.Empty).Trim();
        var oldTheme = current.DefaultThemeId;
        if (newTheme.Length > 0 && !string.Equals(newTheme, oldTheme, StringComparison.Ordinal))
        {
            var plan = await ThemeMigration.ScanAsync(oldTheme, newTheme);
            if (plan.Entries.Count > 0)
            {
                // 迁移向导会在其内部完成 SiteProfile.DefaultThemeId 保存；
                // 这里先保存其他字段，避免用户填入的内容丢失。
                _siteDefaultThemeId = oldTheme;
                await SiteProfileSettings.SaveAsync(BuildSiteProfileUpdate());
                Navigation.NavigateTo($"/Admin/Site/ThemeMigration?from={Uri.EscapeDataString(oldTheme)}&to={Uri.EscapeDataString(newTheme)}");
                return;
            }
        }
        await SiteProfileSettings.SaveAsync(BuildSiteProfileUpdate());
        _basicSaved = true;
    }

    /// <summary>保存站点本地化设置。</summary>
    private async Task SaveLocalizationAsync()
    {
        await LocalizationSettings.SaveAsync(_primaryLanguage, _enabledLanguageCodes, _customLanguages);
        await LoadLocalizationAsync();
        await SiteProfileSettings.SaveAsync(BuildSiteProfileUpdate());
        _localizationSaved = true;
        _localizationMessage = I18n["settings.localization.primaryIncluded"];
    }

    /// <summary>把 Settings 页缓冲区整理成 Home Server 站点基础设置保存输入。</summary>
    private SiteProfileSettingsUpdate BuildSiteProfileUpdate()
        => new()
        {
            SiteName = _siteName,
            DefaultTitle = _defaultTitle,
            Description = _siteDescription,
            PublicBaseUrl = _publicBaseUrl,
            CopyrightNotice = _copyrightNotice,
            Language = _primaryLanguage,
            TimeZone = _siteTimeZone,
            DefaultThemeId = _siteDefaultThemeId,
        };

    /// <summary>保存 Common i18n 覆盖；空输入会在服务层被丢弃。</summary>
    private async Task SaveCommonTextOverridesAsync()
    {
        var overrides = _commonTextOverrides.Select(x => new CommonI18nTextOverride
        {
            Key = x.Key,
            Values = x.Value,
        });
        await LocalizationSettings.SaveCommonTextOverridesAsync(overrides);
        await LoadLocalizationAsync();
        _commonTextSaved = true;
        _commonTextMessage = I18n["settings.localization.commonTextSaved"];
    }

    /// <summary>保存 OIDC Provider 设置。</summary>
    private async Task SaveOidcAsync()
    {
        await ExternalLogins.SaveOidcAsync(_oidc.Enabled, _oidc.DisplayName, _oidc.Authority, _oidc.ClientId, _oidc.ClientSecret, _oidc.CallbackPath, _oidc.Scopes);
        _loginSaved = true;
        _oidc.ClientSecret = string.Empty;
    }

    /// <summary>读取站点本地化设置并刷新 Settings 页缓冲区。</summary>
    private async Task LoadLocalizationAsync()
    {
        var localization = await LocalizationSettings.GetAsync();
        _primaryLanguage = localization.PrimaryLanguage.Code;
        _enabledLanguageCodes = new HashSet<string>(localization.EnabledLanguages.Select(x => x.Code), StringComparer.OrdinalIgnoreCase);
        _customLanguages = [.. localization.CustomLanguages];
        _commonTextOverrides = localization.CommonTextOverrides.ToDictionary(
            x => x.Key,
            x => new Dictionary<string, string>(x.Values, StringComparer.OrdinalIgnoreCase),
            StringComparer.Ordinal);
        _urlPolicy = localization.UrlPolicy;
        RefreshAvailableLanguages();
    }

    /// <summary>搜索后的 Picklist 语言列表；保持小范围内联计算，避免为当前页面拆出过早组件。</summary>
    private List<LanguageRecord> FilteredAvailableLanguages
    {
        get
        {
            var query = _languageSearch.Trim();
            if (query.Length == 0)
            {
                return [.. _availableLanguages];
            }

            return _availableLanguages
                .Where(language => LanguageMatchesSearch(language, query))
                .ToList();
        }
    }

    /// <summary>当前已启用语言的展示列表，按 Picklist 顺序显示，主语言由 setter 和服务层双重兜底。</summary>
    private List<LanguageRecord> EnabledLanguagesForDisplay
        => _availableLanguages
            .Where(language => IsLanguageEnabled(language.Code))
            .ToList();

    /// <summary>当前可编辑的 Common i18n key；包含内置 key 和已经保存过的自定义 key。</summary>
    private List<string> FilteredCommonI18nKeys
    {
        get
        {
            var query = _commonKeySearch.Trim();
            return LocalizationSettingsService.CommonI18nKeys
                .Concat(_commonTextOverrides.Keys)
                .Distinct(StringComparer.Ordinal)
                .Where(key => query.Length == 0 || key.Contains(query, StringComparison.OrdinalIgnoreCase))
                .OrderBy(key => key, StringComparer.Ordinal)
                .ToList();
        }
    }

    /// <summary>启用语言代码的稳定有序列表，嗂给 BocchiLocalizedInput；缓存可视情况引入，目前规模小直接现算。</summary>
    private IReadOnlyList<string> EnabledLanguageCodeList
        => EnabledLanguagesForDisplay.Select(language => language.Code).ToArray();

    /// <summary>列表当前应高亮的 key；优先使用用户选择，否则回退到列表第一项。</summary>
    private string? ResolveSelectedCommonKey(IReadOnlyList<string> visibleKeys)
    {
        if (_selectedCommonKey is not null && visibleKeys.Contains(_selectedCommonKey, StringComparer.Ordinal))
        {
            return _selectedCommonKey;
        }

        return visibleKeys.Count > 0 ? visibleKeys[0] : null;
    }

    /// <summary>统计某个 Common key 已有的翻译条数（仅计已启用语言），用于列表角标。</summary>
    private int CountCommonTranslations(string key)
    {
        if (!_commonTextOverrides.TryGetValue(key, out var values))
        {
            return 0;
        }

        return values.Count(pair => !string.IsNullOrWhiteSpace(pair.Value));
    }

    /// <summary>给 BocchiLocalizedInput 喂的 key 缓冲；不存在时懒初始化以保持引用稳定。</summary>
    private IReadOnlyDictionary<string, string> CommonTextValuesFor(string key)
    {
        if (!_commonTextOverrides.TryGetValue(key, out var values))
        {
            values = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
            _commonTextOverrides[key] = values;
        }

        return values;
    }

    /// <summary>组件回填时整体替换内部字典，保持引用稳定避免子组件下一轮重置。</summary>
    private void OnCommonTextValuesChanged(string key, IReadOnlyDictionary<string, string> next)
    {
        var dict = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        foreach (var pair in next)
        {
            dict[pair.Key] = pair.Value;
        }

        _commonTextOverrides[key] = dict;
        _commonTextSaved = false;
        _commonTextMessage = null;
    }

    /// <summary>把自定义语言加入当前编辑缓冲区。</summary>
    private void AddCustomLanguage()
    {
        if (string.IsNullOrWhiteSpace(_customLanguageCode)
            || string.IsNullOrWhiteSpace(_customLanguageNativeName)
            || string.IsNullOrWhiteSpace(_customLanguageEnglishName))
        {
            _localizationSaved = false;
            _localizationMessage = I18n["settings.localization.customIncomplete"];
            return;
        }

        var code = _customLanguageCode.Trim();
        if (_availableLanguages.Any(x => string.Equals(x.Code, code, StringComparison.OrdinalIgnoreCase)))
        {
            _localizationSaved = false;
            _localizationMessage = I18n["settings.localization.customDuplicate"];
            return;
        }

        _customLanguages.Add(new LanguageRecord
        {
            Code = code,
            NativeName = _customLanguageNativeName.Trim(),
            EnglishName = _customLanguageEnglishName.Trim(),
        });
        _enabledLanguageCodes.Add(code);
        _customLanguageCode = string.Empty;
        _customLanguageNativeName = string.Empty;
        _customLanguageEnglishName = string.Empty;
        _localizationSaved = false;
        _localizationMessage = null;
        RefreshAvailableLanguages();
    }

    /// <summary>从启用集合中关闭语言；主语言不能被关闭。</summary>
    private void DisableLanguage(string code)
    {
        if (IsPrimaryLanguage(code))
        {
            _enabledLanguageCodes.Add(code);
            return;
        }

        _enabledLanguageCodes.Remove(code);
        _localizationSaved = false;
        _localizationMessage = null;
    }

    /// <summary>从编辑缓冲区移除一个自定义语言。</summary>
    private void RemoveCustomLanguage(string code)
    {
        _customLanguages.RemoveAll(x => string.Equals(x.Code, code, StringComparison.OrdinalIgnoreCase));
        _enabledLanguageCodes.Remove(code);
        if (string.Equals(_primaryLanguage, code, StringComparison.OrdinalIgnoreCase))
        {
            _primaryLanguage = LocalizationSettingsService.DefaultPrimaryLanguage;
            _enabledLanguageCodes.Add(_primaryLanguage);
        }

        _localizationSaved = false;
        RefreshAvailableLanguages();
    }

    /// <summary>切换站点启用语言；主要语言始终保持启用。</summary>
    private void ToggleEnabledLanguage(string code, ChangeEventArgs args)
    {
        if (IsPrimaryLanguage(code))
        {
            _enabledLanguageCodes.Add(code);
            return;
        }

        if (args.Value is bool enabled && enabled)
        {
            _enabledLanguageCodes.Add(code);
        }
        else
        {
            _enabledLanguageCodes.Remove(code);
        }

        _localizationSaved = false;
    }

    /// <summary>判断站点语言是否处于启用状态。</summary>
    private bool IsLanguageEnabled(string code)
        => IsPrimaryLanguage(code) || _enabledLanguageCodes.Contains(code);

    /// <summary>判断语言是否为当前站点主要语言。</summary>
    private bool IsPrimaryLanguage(string code)
        => string.Equals(_primaryLanguage, code, StringComparison.OrdinalIgnoreCase);

    /// <summary>判断 Dashboard 语言选项是否为当前 UI culture。</summary>
    private bool IsCurrentDashboardLanguage(string code)
        => string.Equals(I18n.CurrentLanguage.Code, code, StringComparison.OrdinalIgnoreCase);

    /// <summary>刷新 Picklist 数据源，保持内置语言在前、自定义语言在后。</summary>
    private void RefreshAvailableLanguages()
    {
        _availableLanguages = [.. LocalizationSettingsService.BuiltInLanguages, .. _customLanguages];
        _enabledLanguageCodes.Add(_primaryLanguage);
    }

    /// <summary>按 code、nativeName 和 englishName 搜索语言，覆盖中英文后台下的常见查找方式。</summary>
    private static bool LanguageMatchesSearch(LanguageRecord language, string query)
        => language.Code.Contains(query, StringComparison.OrdinalIgnoreCase)
            || language.NativeName.Contains(query, StringComparison.OrdinalIgnoreCase)
            || language.EnglishName.Contains(query, StringComparison.OrdinalIgnoreCase);

    /// <summary>把路由片段收敛到明确支持的 Settings section。</summary>
    private static string NormalizeSection(string? section)
        => section?.Trim().ToLowerInvariant() switch
        {
            ProfileSection => ProfileSection,
            LocalizationSection => LocalizationSection,
            LoginSection => LoginSection,
            SystemSection => SystemSection,
            _ => string.Empty,
        };

    /// <summary>Settings hub 卡片定义。</summary>
    private sealed record SettingsHubCard(string Url, string TitleKey, string DescriptionKey, SvgIcon Icon, string Tone);

    /// <summary>Provider 表单缓冲区，不直接暴露受保护 secret。</summary>
    private sealed class ProviderForm
    {
        /// <summary>是否启用 Provider。</summary>
        public bool Enabled { get; set; }

        /// <summary>登录页显示名称。</summary>
        public string DisplayName { get; set; } = string.Empty;

        /// <summary>Provider authority，仅 OIDC 使用。</summary>
        public string? Authority { get; set; }

        /// <summary>Client ID。</summary>
        public string? ClientId { get; set; }

        /// <summary>Client secret 输入框；留空表示不覆盖现有 secret。</summary>
        public string? ClientSecret { get; set; }

        /// <summary>回调路径。</summary>
        public string? CallbackPath { get; set; }

        /// <summary>OIDC scopes。</summary>
        public string? Scopes { get; set; } = "openid profile email";
    }
}
