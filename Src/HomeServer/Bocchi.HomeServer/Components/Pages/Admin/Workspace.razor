@page "/Admin/Content"
@using Bocchi.ContentModel
@using Bocchi.Workspace
@using Bocchi.Workspace.Git
@using Bocchi.Workspace.Scanning
@using Bocchi.Workspace.State
@using Bocchi.HomeServer.Data
@using Bocchi.HomeServer.Services.Git
@inject BocchiDataLayout Layout
@inject IContentStateStore Store
@inject IContentRepository Repository
@inject ContentScanner Scanner
@inject ContentWorkspaceRemoteService WorkspaceRemotes
@inject GitProviderConnectionService GitConnections
@inject GitHubDeviceFlowService GitHubFlow
@inject DashboardLocalizationService I18n
@inject LocalizationSettingsService Localization

<PageTitle>Content · Bocchi</PageTitle>

<article class="bocchi-shell">
    <header class="bocchi-page-heading">
        <span class="bocchi-page-heading__eyebrow">Content space</span>
        <h1>工作区</h1>
        <p>用轻量列表查看内容、扫描结果和 Git 状态。技术诊断仍然保留，但默认收在高级详情里。</p>
    </header>

    <div class="bocchi-two-column">
        <section aria-labelledby="content-heading" class="bocchi-panel">
            <div class="bocchi-inline-actions">
                <h2 id="content-heading">Content</h2>
                <label class="bocchi-compact-field">
                    <span>Type</span>
                    <select @bind="KindFilter">
                        <option value="">All</option>
                        <option value="Post">Posts</option>
                        <option value="Page">Pages</option>
                        <option value="Work">Works</option>
                        <option value="Note">Notes</option>
                        <option value="FriendLink">Friends</option>
                        <option value="SiteSettings">Site Settings</option>
                    </select>
                </label>
                <button type="button" class="secondary" @onclick="RescanAsync" disabled="@_busy">@(_busy ? "Checking..." : "Check now")</button>
            </div>

            @if (_summaries.Count == 0)
            {
                <BocchiListRow Kicker="Empty" Title="还没有扫描到内容">
                    <ChildContent>
                        <p>先确认 workspace 里有 Markdown、site.yaml 或 friends.yaml，然后点一次 Check now。</p>
                    </ChildContent>
                    <Metadata>
                        <BocchiStatusPill Tone="warning">Needs a quick look</BocchiStatusPill>
                        <span><code>workspace/</code></span>
                    </Metadata>
                </BocchiListRow>
            }
            else
            {
                @foreach (var group in FilteredSummaryGroups)
                {
                    var item = group.Representative;
                    <BocchiListRow Kicker="@item.Kind.ToString()" Title="@(item.Title ?? item.ContentId)">
                        <ChildContent>
                            <p><code>@group.DisplayRelativePath</code></p>
                            @if (group.HasMultipleVariants)
                            {
                                <details class="bocchi-workspace-variants">
                                    <summary>@FormatText("kind.index.localization.versionsFormat", group.Variants.Length)</summary>
                                    <div class="bocchi-workspace-variants__list">
                                        @foreach (var variant in group.Variants)
                                        {
                                            <a href="@ContentEditingService.EditUrl(variant.RelativePath)">
                                                <span>@LanguageLabel(variant)</span>
                                                <strong>@(variant.Title ?? variant.ContentId)</strong>
                                                <span class="bocchi-workspace-variants__badges">
                                                    @if (IsPrimaryLanguage(variant))
                                                    {
                                                        <small class="bocchi-tooltip bocchi-workspace-variants__badge bocchi-workspace-variants__badge--primary"
                                                               data-bocchi-tooltip='@I18n["kind.index.localization.primaryLanguageTitle"]'
                                                               aria-label='@I18n["kind.index.localization.primaryLanguageTitle"]'>
                                                            @I18n["kind.index.localization.primaryLanguage"]
                                                        </small>
                                                    }
                                                    <small class="bocchi-tooltip bocchi-workspace-variants__badge"
                                                           data-bocchi-tooltip="@VariantKindTitle(variant)"
                                                           aria-label="@VariantKindTitle(variant)">
                                                        @VariantKindLabel(variant)
                                                    </small>
                                                </span>
                                            </a>
                                        }
                                    </div>
                                </details>
                            }
                        </ChildContent>
                        <Metadata>
                            <BocchiStatusPill Tone="@ContentStatusTone(item.Status)">@ContentStatusLabel(item.Status)</BocchiStatusPill>
                            @if (item.Year is not null)
                            {
                                <span>@item.Year</span>
                            }
                            <span>@ContentTimeLabel(item)</span>
                        </Metadata>
                        <Action>
                            @if (IsMarkdownPath(item.RelativePath))
                            {
                                <a class="bocchi-button secondary" href="@ContentEditingService.EditUrl(item.RelativePath)">Edit</a>
                            }
                        </Action>
                    </BocchiListRow>
                }
            }
        </section>

        <aside class="bocchi-panel bocchi-panel--soft" aria-labelledby="status-heading">
            <h2 id="status-heading">Site check</h2>
            <dl class="bocchi-meta-list">
                <div>
                    <dt>最近运行</dt>
                    <dd>@(_lastRun is null ? "No check yet" : $"#{_lastRun.Id} · {_lastRun.Status}")</dd>
                </div>
                <div>
                    <dt>文件 / 内容项</dt>
                    <dd>@(_lastRun is null ? "—" : $"{_lastRun.FilesScanned} / {_lastRun.ItemsLoaded}")</dd>
                </div>
                <div>
                    <dt>错误 / 警告</dt>
                    <dd>@(_lastRun is null ? "—" : $"{_lastRun.ErrorCount} / {_lastRun.WarningCount}")</dd>
                </div>
                <div>
                    <dt>Git</dt>
                    <dd>@GitStatusLabel()</dd>
                </div>
            </dl>

            @if (_gitStatus is not null && !_gitStatus.IsRepository)
            {
                <p>Workspace 还不是 Git 仓库。</p>
                <button type="button" @onclick="InitGitAsync" disabled="@_busy">Init Git</button>
            }
        </aside>
    </div>

    <section class="bocchi-panel" aria-labelledby="workspace-remote-heading">
        <div class="bocchi-inline-actions">
            <h2 id="workspace-remote-heading">@I18n["workspace.remote.title"]</h2>
            @if (_workspaceRemotes.Count > 0)
            {
                <BocchiStatusPill Tone="info">@_workspaceRemotes[0].RemoteName</BocchiStatusPill>
            }
        </div>
        <p class="bocchi-muted-copy">@I18n["workspace.remote.description"]</p>
        <div class="bocchi-form-grid">
            <label>@I18n["workspace.remote.mode"]
                <select @bind="_remoteMode">
                    <option value="create">@I18n["workspace.remote.mode.create"]</option>
                    <option value="connect">@I18n["workspace.remote.mode.connect"]</option>
                    <option value="import">@I18n["workspace.remote.mode.import"]</option>
                    <option value="generic">@I18n["workspace.remote.mode.generic"]</option>
                </select>
            </label>
            <label>@I18n["workspace.remote.name"]
                <input type="text" @bind="_remoteName" autocomplete="off" />
            </label>
            <label>@I18n["workspace.remote.branch"]
                <input type="text" @bind="_remoteBranch" autocomplete="off" />
            </label>
            @if (string.Equals(_remoteMode, "create", StringComparison.Ordinal))
            {
                <label>@I18n["workspace.remote.repositoryName"]
                    <input type="text" @bind="_remoteRepositoryName" autocomplete="off" />
                </label>
            }
            else
            {
                <label>@I18n["workspace.remote.url"]
                    <input type="url" @bind="_remoteUrl" autocomplete="off" />
                </label>
            }
            @if (_gitConnections.Any(x => x.ProviderKey == GitProviderKeys.GitHub))
            {
                <label>@I18n["workspace.remote.githubAccount"]
                    <select @bind="_selectedGitConnectionId">
                        <option value="">@I18n["workspace.remote.noAccount"]</option>
                        @foreach (var connection in _gitConnections.Where(x => x.ProviderKey == GitProviderKeys.GitHub))
                        {
                            <option value="@connection.Id">@connection.AccountLogin</option>
                        }
                    </select>
                </label>
            }
        </div>
        @if (string.Equals(_remoteMode, "create", StringComparison.Ordinal))
        {
            <label class="bocchi-checkbox bocchi-publish-github-check">
                <input type="checkbox" @bind="_remoteCreatePrivate" />
                @I18n["workspace.remote.privateRepository"]
            </label>
        }
        <div class="bocchi-inline-actions">
            @if (string.Equals(_remoteMode, "create", StringComparison.Ordinal))
            {
                <button type="button" class="secondary" @onclick="CreateContentRepositoryAsync" disabled="@_busy">@I18n["workspace.remote.createAndConnect"]</button>
            }
            else
            {
                <button type="button" class="secondary" @onclick="SaveRemoteAsync" disabled="@_busy">@I18n["workspace.remote.save"]</button>
            }
            @if (_workspaceRemotes.Count > 0)
            {
                <button type="button" class="secondary" @onclick="PullRemoteAsync" disabled="@_busy">@I18n["workspace.remote.pull"]</button>
                <button type="button" class="secondary" @onclick="PushRemoteAsync" disabled="@_busy">@I18n["workspace.remote.push"]</button>
                <button type="button" class="secondary" @onclick="ImportRemoteAsync" disabled="@_busy">@I18n["workspace.remote.import"]</button>
            }
        </div>
        @if (!string.IsNullOrWhiteSpace(_remoteMessage))
        {
            <p class="@RemoteMessageClass()">@_remoteMessage</p>
        }
    </section>

    <details class="bocchi-advanced-details">
        <summary>Workspace paths</summary>
        <dl class="bocchi-meta-list">
            <div>
                <dt>DataRoot</dt>
                <dd><code>@Layout.DataRoot</code></dd>
            </div>
            <div>
                <dt>Workspace</dt>
                <dd><code>@Layout.WorkspaceRoot</code></dd>
            </div>
            <div>
                <dt>SQLite</dt>
                <dd><code>@Layout.SqliteDatabasePath</code></dd>
            </div>
            <div>
                <dt>日志</dt>
                <dd><code>@Layout.LogsDirectory</code></dd>
            </div>
        </dl>
    </details>

    <details class="bocchi-advanced-details">
        <summary>Diagnostics (@_errors.Count)</summary>
        @if (_errors.Count == 0)
        {
            <p>暂无诊断信息。</p>
        }
        else
        {
            @foreach (var e in _errors)
            {
                <BocchiListRow Kicker="@(e.Kind?.ToString() ?? "Workspace")" Title="@e.Message">
                    <Metadata>
                        <BocchiStatusPill Tone="@ErrorTone(e.Severity)">@e.Severity</BocchiStatusPill>
                        <span><code>@e.Code</code></span>
                        <span><code>@e.RelativePath</code></span>
                    </Metadata>
                </BocchiListRow>
            }
        }
    </details>
</article>

@code {
    /// <summary>页面正在执行扫描或初始化动作时用于禁用按钮。</summary>
    private bool _busy;

    /// <summary>内容 workspace Git 状态。</summary>
    private ContentRepositoryStatus? _gitStatus;

    /// <summary>最近一次内容扫描运行。</summary>
    private ScanRunRecord? _lastRun;

    /// <summary>最近一次扫描产生的诊断信息。</summary>
    private IReadOnlyList<ContentValidationError> _errors = [];

    /// <summary>SQLite 中的内容摘要，主列表不读取正文。</summary>
    private IReadOnlyList<ContentSummary> _summaries = [];

    /// <summary>站点可用语言的展示名索引，用于 Workspace 中的语言版本展开层。</summary>
    private IReadOnlyDictionary<string, string> _languageLabels = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

    /// <summary>站点主语言，用于选择 Workspace 内容组代表 variant。</summary>
    private string _sitePrimaryLanguage = LocalizationSettingsService.DefaultPrimaryLanguage;

    /// <summary>当前 Dashboard UI 语言，优先作为内容组代表 variant。</summary>
    private string _dashboardLanguage = LocalizationSettingsService.DefaultPrimaryLanguage;

    /// <summary>内容 workspace remote 配置列表。</summary>
    private IReadOnlyList<ContentWorkspaceRemoteRecord> _workspaceRemotes = [];

    /// <summary>可复用的 Git provider 账号连接。</summary>
    private IReadOnlyList<GitProviderConnectionRecord> _gitConnections = [];

    /// <summary>内容 remote 入口模式。</summary>
    private string _remoteMode = "generic";

    /// <summary>创建内容仓库时使用的新 repository 名称。</summary>
    private string _remoteRepositoryName = "bocchi-content";

    /// <summary>创建内容仓库时默认 private，避免把未发布内容公开。</summary>
    private bool _remoteCreatePrivate = true;

    /// <summary>内容 remote 名称。</summary>
    private string _remoteName = "origin";

    /// <summary>内容 remote URL；必须是不含凭据的普通 URL。</summary>
    private string _remoteUrl = string.Empty;

    /// <summary>内容 remote branch。</summary>
    private string _remoteBranch = "main";

    /// <summary>当前内容 remote 复用的 Git provider connection。</summary>
    private int? _selectedGitConnectionId;

    /// <summary>内容 remote 操作消息。</summary>
    private string? _remoteMessage;

    /// <summary>内容 remote 操作消息是否为失败态。</summary>
    private bool _remoteMessageIsDanger;

    /// <summary>内容类型筛选值；空字符串表示全部。</summary>
    [SupplyParameterFromQuery(Name = "kind")]
    private string KindFilter { get; set; } = string.Empty;

    /// <summary>顶部搜索框传入的内容关键词，用于按标题、路径或内容 id 过滤列表。</summary>
    [SupplyParameterFromQuery(Name = "q")]
    private string? SearchTerm { get; set; }

    /// <summary>根据当前 UI 筛选返回主列表内容。</summary>
    private IEnumerable<ContentSummary> FilteredSummaries => _summaries
        .Where(x => string.IsNullOrWhiteSpace(KindFilter) || x.Kind.ToString() == KindFilter)
        .Where(MatchesSearch)
        .OrderByDescending(x => x.UpdatedAt ?? x.PublishedAt)
        .ThenBy(x => x.Title ?? x.ContentId);

    /// <summary>根据筛选结果按 localization group 收口，避免 Workspace 总览把同一内容 variant 平铺成多行。</summary>
    private IEnumerable<WorkspaceContentGroup> FilteredSummaryGroups
        => BuildSummaryGroups(FilteredSummaries.ToArray());

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    /// <summary>刷新 Git、扫描摘要、诊断和内容列表。</summary>
    private async Task RefreshAsync()
    {
        _gitStatus = await Repository.GetStatusAsync();
        _lastRun = await Store.GetLatestScanRunAsync();
        _errors = _lastRun is null
            ? []
            : (await Store.ListErrorsAsync(_lastRun.Id)).Take(50).ToList();
        _summaries = await Store.ListContentSummariesAsync(null);
        var localization = await Localization.GetAsync();
        _sitePrimaryLanguage = localization.PrimaryLanguage.Code;
        _dashboardLanguage = string.IsNullOrWhiteSpace(System.Globalization.CultureInfo.CurrentUICulture.Name)
            ? System.Globalization.CultureInfo.CurrentCulture.Name
            : System.Globalization.CultureInfo.CurrentUICulture.Name;
        _languageLabels = localization.EnabledLanguages.ToDictionary(
            language => language.Code,
            FormatLanguageDisplayName,
            StringComparer.OrdinalIgnoreCase);
        _workspaceRemotes = await WorkspaceRemotes.ListAsync();
        _gitConnections = await GitConnections.ListAsync();
        _selectedGitConnectionId ??= _gitConnections.FirstOrDefault(x => x.ProviderKey == GitProviderKeys.GitHub)?.Id;
        if (_workspaceRemotes.FirstOrDefault() is { } remote)
        {
            _remoteName = remote.RemoteName;
            _remoteUrl = remote.RemoteUrl;
            _remoteBranch = remote.Branch;
            _selectedGitConnectionId = remote.GitProviderConnectionId ?? _selectedGitConnectionId;
        }
    }

    /// <summary>把内容 workspace 初始化为独立 Git 仓库。</summary>
    private async Task InitGitAsync()
    {
        _busy = true;
        try
        {
            await Repository.InitializeAsync();
            await RefreshAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    /// <summary>重新扫描内容 workspace 并刷新页面投影。</summary>
    private async Task RescanAsync()
    {
        _busy = true;
        try
        {
            await Scanner.ScanAsync();
            await RefreshAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    /// <summary>保存并配置内容 workspace remote；不会自动 push/pull。</summary>
    private async Task SaveRemoteAsync()
    {
        await RunRemoteActionAsync(async () =>
        {
            var saved = await WorkspaceRemotes.ConnectAsync(CreateRemoteInput());
            _remoteMessage = string.Format(System.Globalization.CultureInfo.CurrentCulture, I18n["workspace.remote.savedFormat"], saved.RemoteName);
        });
    }

    /// <summary>通过 GitHub 授权创建空内容仓库，并保存为 content remote。</summary>
    private async Task CreateContentRepositoryAsync()
    {
        await RunRemoteActionAsync(async () =>
        {
            if (_selectedGitConnectionId is null)
            {
                throw new InvalidOperationException(I18n["workspace.remote.connectionRequired"]);
            }

            if (string.IsNullOrWhiteSpace(_remoteRepositoryName))
            {
                throw new InvalidOperationException(I18n["workspace.remote.repositoryRequired"]);
            }

            var connection = await GitConnections.GetAsync(_selectedGitConnectionId.Value)
                ?? throw new InvalidOperationException(I18n["workspace.remote.connectionRequired"]);
            var credential = GitHubOAuthCredential.FromJson(GitConnections.UnprotectCredentialJson(connection));
            var repository = await GitHubFlow.CreateRepositoryAsync(
                credential.AccessToken,
                _remoteRepositoryName,
                _remoteCreatePrivate,
                autoInit: false);

            _remoteUrl = $"https://github.com/{repository.FullName}.git";
            var saved = await WorkspaceRemotes.ConnectAsync(CreateRemoteInput());
            _remoteMessage = string.Format(System.Globalization.CultureInfo.CurrentCulture, I18n["workspace.remote.createdFormat"], repository.FullName, saved.Branch);
        });
    }

    /// <summary>fast-forward 拉取内容 remote。</summary>
    private async Task PullRemoteAsync()
    {
        if (_workspaceRemotes.FirstOrDefault() is not { } remote)
        {
            return;
        }

        await RunRemoteActionAsync(async () =>
        {
            var result = await WorkspaceRemotes.PullFastForwardAsync(remote.Id);
            _remoteMessage = result.Message;
        });
    }

    /// <summary>推送内容 workspace 到 remote。</summary>
    private async Task PushRemoteAsync()
    {
        if (_workspaceRemotes.FirstOrDefault() is not { } remote)
        {
            return;
        }

        await RunRemoteActionAsync(async () =>
        {
            var result = await WorkspaceRemotes.PushAsync(remote.Id);
            _remoteMessage = result.Message;
        });
    }

    /// <summary>导入已有内容仓库；服务层会先备份当前 workspace。</summary>
    private async Task ImportRemoteAsync()
    {
        if (_workspaceRemotes.FirstOrDefault() is not { } remote)
        {
            return;
        }

        await RunRemoteActionAsync(async () =>
        {
            var result = await WorkspaceRemotes.ImportExistingAsync(remote.Id);
            _remoteMessage = result.Message;
        });
    }

    /// <summary>执行内容 remote 动作并刷新页面状态。</summary>
    private async Task RunRemoteActionAsync(Func<Task> action)
    {
        _busy = true;
        _remoteMessageIsDanger = false;
        try
        {
            await action();
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            _remoteMessageIsDanger = true;
            _remoteMessage = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    /// <summary>把页面表单转换为内容 remote 保存输入。</summary>
    private ContentWorkspaceRemoteSaveInput CreateRemoteInput()
    {
        var existingId = _workspaceRemotes.FirstOrDefault()?.Id;
        var connectionId = string.Equals(_remoteMode, "generic", StringComparison.Ordinal)
            ? null
            : _selectedGitConnectionId;
        return new ContentWorkspaceRemoteSaveInput(existingId, _remoteName, _remoteUrl, _remoteBranch, connectionId);
    }

    /// <summary>内容 remote 操作消息 class。</summary>
    private string RemoteMessageClass()
        => _remoteMessageIsDanger
            ? "bocchi-publish-remote-message bocchi-publish-remote-message--danger"
            : "bocchi-publish-remote-message";

    /// <summary>把内容发布状态转成普通用户能理解的标签。</summary>
    private static string ContentStatusLabel(ContentStatus status)
        => status switch
        {
            ContentStatus.Published => "Ready",
            ContentStatus.Archived => "Archived",
            _ => "Draft",
        };

    /// <summary>把内容发布状态映射到柔和状态色。</summary>
    private static string ContentStatusTone(ContentStatus status)
        => status switch
        {
            ContentStatus.Published => "success",
            ContentStatus.Archived => "neutral",
            _ => "warning",
        };

    /// <summary>优先显示更新时间，其次显示发布时间。</summary>
    private static string ContentTimeLabel(ContentSummary summary)
        => (summary.UpdatedAt ?? summary.PublishedAt)?.ToString("yyyy-MM-dd") ?? "No date";

    /// <summary>按内容语言组生成 Workspace 展示行；不支持语言版本的内容保持一项一行。</summary>
    private WorkspaceContentGroup[] BuildSummaryGroups(IReadOnlyList<ContentSummary> summaries)
        => summaries
            .GroupBy(SummaryGroupKey, StringComparer.OrdinalIgnoreCase)
            .Select(group =>
            {
                var variants = group
                    .OrderBy(item => LanguageSort(item.Language))
                    .ThenByDescending(item => item.UpdatedAt ?? item.PublishedAt)
                    .ThenBy(item => item.Title ?? item.ContentId)
                    .ToArray();
                return new WorkspaceContentGroup(group.Key, SelectRepresentative(variants), variants);
            })
            .OrderByDescending(group => group.Representative.UpdatedAt ?? group.Representative.PublishedAt)
            .ThenBy(group => group.Representative.Title ?? group.Representative.ContentId)
            .ToArray();

    /// <summary>Workspace 总览跨类型展示，group key 需要包含 kind，避免不同内容类型误折叠。</summary>
    private static string SummaryGroupKey(ContentSummary summary)
        => summary.Kind is ContentKind.Post or ContentKind.Page or ContentKind.Work &&
            !string.IsNullOrWhiteSpace(summary.LocalizationGroup)
            ? $"{summary.Kind}:{summary.LocalizationGroup}"
            : $"{summary.Kind}:{summary.RelativePath}";

    /// <summary>选择 Workspace 内容组代表 variant，顺序与分类型列表保持一致。</summary>
    private ContentSummary SelectRepresentative(IReadOnlyList<ContentSummary> variants)
        => variants.FirstOrDefault(item => SameLanguage(item.Language, _dashboardLanguage))
            ?? variants.FirstOrDefault(item => SameLanguage(item.Language, _sitePrimaryLanguage))
            ?? variants[0];

    /// <summary>变体展开层排序优先当前 Dashboard 语言，其次站点主语言。</summary>
    private int LanguageSort(string? language)
    {
        if (SameLanguage(language, _dashboardLanguage))
        {
            return 0;
        }

        return SameLanguage(language, _sitePrimaryLanguage) ? 1 : 2;
    }

    /// <summary>把 language code 映射为用户可读名称。</summary>
    private string LanguageLabel(ContentSummary summary)
    {
        if (string.IsNullOrWhiteSpace(summary.Language))
        {
            return I18n["kind.index.localization.unknownLanguage"];
        }

        return _languageLabels.TryGetValue(summary.Language, out var label) ? label : summary.Language;
    }

    /// <summary>展示当前 variant 的角色；Translation 同时标明来源语言。</summary>
    private string VariantKindLabel(ContentSummary summary)
    {
        if (!summary.IsTranslation)
        {
            return I18n["kind.index.localization.nativeShort"];
        }

        if (string.IsNullOrWhiteSpace(summary.SourceLanguage))
        {
            return I18n["kind.index.localization.translation"];
        }

        var sourceLabel = _languageLabels.TryGetValue(summary.SourceLanguage, out var label) ? label : summary.SourceLanguage;
        return FormatText("kind.index.localization.translationFromFormat", sourceLabel);
    }

    /// <summary>为 variant 角色 badge 提供 hover 解释。</summary>
    private string VariantKindTitle(ContentSummary summary)
        => summary.IsTranslation ? VariantKindLabel(summary) : I18n["kind.index.localization.nativeTitle"];

    /// <summary>判断当前 variant 是否为站点主语言。</summary>
    private bool IsPrimaryLanguage(ContentSummary summary)
        => SameLanguage(summary.Language, _sitePrimaryLanguage);

    /// <summary>格式化 Dashboard 文案资源，复用当前 culture 的数字和短句规则。</summary>
    private string FormatText(string key, params object[] args)
        => string.Format(System.Globalization.CultureInfo.CurrentCulture, I18n[key], args);

    /// <summary>列表使用紧凑语言名；native name 缺失时回退英文名。</summary>
    private static string FormatLanguageDisplayName(LanguageRecord language)
        => string.IsNullOrWhiteSpace(language.NativeName) ? language.EnglishName : language.NativeName;

    /// <summary>以大小写不敏感方式比较语言代码。</summary>
    private static bool SameLanguage(string? left, string? right)
        => !string.IsNullOrWhiteSpace(left) &&
            !string.IsNullOrWhiteSpace(right) &&
            string.Equals(left, right, StringComparison.OrdinalIgnoreCase);

    /// <summary>执行普通用户入口的轻量搜索；不读取正文，只匹配列表投影字段。</summary>
    private bool MatchesSearch(ContentSummary summary)
    {
        if (string.IsNullOrWhiteSpace(SearchTerm))
        {
            return true;
        }

        var term = SearchTerm.Trim();
        return Contains(summary.Title, term)
            || Contains(summary.RelativePath, term)
            || Contains(summary.ContentId, term);
    }

    /// <summary>统一大小写不敏感的列表文本匹配。</summary>
    private static bool Contains(string? value, string term)
        => value?.Contains(term, StringComparison.OrdinalIgnoreCase) == true;

    /// <summary>完整编辑器只处理 Markdown 内容；YAML 配置应走专门表单，避免误把结构化配置当正文保存。</summary>
    private static bool IsMarkdownPath(string relativePath)
        => relativePath.EndsWith(".md", StringComparison.OrdinalIgnoreCase);

    /// <summary>把扫描诊断级别映射到柔和状态色。</summary>
    private static string ErrorTone(ContentErrorSeverity severity)
        => severity switch
        {
            ContentErrorSeverity.Error => "danger",
            ContentErrorSeverity.Warning => "warning",
            _ => "info",
        };

    /// <summary>把 Git 状态翻译成首页可读的一句话。</summary>
    private string GitStatusLabel()
    {
        if (_gitStatus is null)
        {
            return "Checking...";
        }

        if (!_gitStatus.IsRepository)
        {
            return "Not initialized";
        }

        return _gitStatus.DirtyFileCount == 0
            ? "Clean"
            : $"{_gitStatus.DirtyFileCount} changed files";
    }

    /// <summary>Workspace 总览中的内容展示组。</summary>
    private sealed record WorkspaceContentGroup(
        string Key,
        ContentSummary Representative,
        ContentSummary[] Variants)
    {
        /// <summary>是否存在多个语言版本，用于决定是否显示展开入口。</summary>
        public bool HasMultipleVariants => Variants.Length > 1;

        /// <summary>总览主行展示路径；多语言组显示内容文件夹，避免误指向单个 variant 文件。</summary>
        public string DisplayRelativePath => HasMultipleVariants ? ContainingFolderPath(Representative.RelativePath) : Representative.RelativePath;

        /// <summary>从具体 Markdown 文件路径取父级内容文件夹。</summary>
        private static string ContainingFolderPath(string relativePath)
        {
            var normalizedPath = relativePath.Replace('\\', '/');
            var slashIndex = normalizedPath.LastIndexOf('/');
            return slashIndex > 0 ? normalizedPath[..slashIndex] : normalizedPath;
        }
    }
}
