@page "/Admin/Publish"
@using Bocchi.Generator.Pipeline
@using Bocchi.Generator.State
@using Bocchi.HomeServer.Build
@using Bocchi.Workspace
@inject BocchiDataLayout Layout
@inject BuildOrchestrator Orchestrator
@inject IBuildStateStore Store

<PageTitle>Publish · Bocchi</PageTitle>

<article class="bocchi-shell">
    <header class="bocchi-page-intro">
        <span class="bocchi-eyebrow">站点 / 发布</span>
        <h1>发布站点</h1>
        <p>把内容 workspace 生成为静态站点，输出到 <code>output/public/</code>。日常发布只看顶部状态即可，详细日志和产物清单收纳在折叠区。</p>
    </header>

    <div class="bocchi-two-column">
        <section aria-labelledby="publish-heading" class="bocchi-panel">
            <h2 id="publish-heading">运行发布</h2>
            <form class="bocchi-form-grid" @onsubmit="RunAsync" @onsubmit:preventDefault>
                <label>
                    前台 Theme id（可选）
                    <input type="text" @bind="_frontendThemeId" placeholder="留空则使用 site.yaml 的 defaultThemeId" />
                </label>

                <label>
                    构建环境
                    <input type="text" @bind="_environmentName" />
                </label>

                <label class="bocchi-checkbox">
                    <input type="checkbox" @bind="_includeDrafts" />
                    包含草稿
                </label>

                <div class="bocchi-inline-actions">
                    <button type="submit" disabled="@_busy">@(_busy ? "发布中..." : "立即发布")</button>
                    <a class="bocchi-button secondary" href="/Admin/Publish/download" target="_blank" rel="noopener">下载 Zip</a>
                </div>
            </form>

            @if (_lastResult is not null)
            {
                <BocchiListRow Kicker="最近一次" Title="@PublishResultTitle(_lastResult.Status)">
                    <ChildContent>
                        <p>@PublishResultDescription(_lastResult)</p>
                    </ChildContent>
                    <Metadata>
                        <BocchiStatusPill Tone="@BuildStatusTone(_lastResult.Status)">@_lastResult.Status</BocchiStatusPill>
                        <span>@_lastResult.Duration.TotalSeconds.ToString("F2")s</span>
                        <span>@_lastResult.Artifacts.Count 个产物</span>
                        @if (_lastResult.Fingerprint is not null)
                        {
                            <span><code>@ShortFingerprint(_lastResult.Fingerprint.Value)</code></span>
                        }
                    </Metadata>
                </BocchiListRow>

                <details class="bocchi-advanced-details">
                    <summary>详细日志（@_lastResult.Logs.Count）</summary>
                    <pre>@string.Join('\n', _lastResult.Logs.Select(l => $"[{l.OccurredAt:HH:mm:ss}] {l.Level,-7} {l.Stage,-28} {l.Message}"))</pre>
                </details>

                <details class="bocchi-advanced-details">
                    <summary>产物清单（@_lastResult.Artifacts.Count）</summary>
                    @foreach (var artifact in _lastResult.Artifacts)
                    {
                        <BocchiListRow Kicker="@artifact.Kind.ToString()" Title="@artifact.Path">
                            <Metadata>
                                <span>@artifact.SizeBytes 字节</span>
                            </Metadata>
                        </BocchiListRow>
                    }
                </details>
            }
        </section>

        <aside class="bocchi-panel bocchi-panel--soft" aria-labelledby="paths-heading">
            <h2 id="paths-heading">输出路径</h2>
            <dl class="bocchi-meta-list">
                <div>
                    <dt>Theme 输入</dt>
                    <dd><code>@Layout.ThemeInputDirectory</code></dd>
                </div>
                <div>
                    <dt>静态站点</dt>
                    <dd><code>@Layout.PublicOutputDirectory</code></dd>
                </div>
            </dl>
        </aside>
    </div>

    <section aria-labelledby="history-heading" class="bocchi-panel">
        <h2 id="history-heading">近期发布记录</h2>
        @if (_recent is null)
        {
            <p>读取中…</p>
        }
        else if (_recent.Count == 0)
        {
            <BocchiListRow Kicker="空" Title="还没有发布记录">
                <ChildContent>
                    <p>跑一次发布后，这里会用简单列表展示最近结果。</p>
                </ChildContent>
                <Metadata>
                    <BocchiStatusPill Tone="info">随时可以发布</BocchiStatusPill>
                </Metadata>
            </BocchiListRow>
        }
        else
        {
            @foreach (var run in _recent)
            {
                <BocchiListRow Kicker="@run.Mode" Title="@($"#{run.Id}")">
                    <ChildContent>
                        <p>@(run.Reason ?? "一次发布记录。")</p>
                    </ChildContent>
                    <Metadata>
                        <BocchiStatusPill Tone="@BuildStatusTone(run.Status)">@run.Status</BocchiStatusPill>
                        <span>@run.StartedAt.ToString("yyyy-MM-dd HH:mm")</span>
                        @if (!string.IsNullOrEmpty(run.ThemeId))
                        {
                            <span>前台 Theme: @run.ThemeId</span>
                        }
                        @if (!string.IsNullOrEmpty(run.Fingerprint))
                        {
                            <span><code>@run.Fingerprint[..Math.Min(12, run.Fingerprint.Length)]</code></span>
                        }
                    </Metadata>
                </BocchiListRow>
            }
        }
    </section>
</article>

@code {
    /// <summary>前台业务 Theme id，属于 Theme Contract，不是 Dashboard 明暗外观。</summary>
    private string? _frontendThemeId;

    /// <summary>构建环境名称。</summary>
    private string _environmentName = "production";

    /// <summary>是否把草稿纳入本次构建。</summary>
    private bool _includeDrafts;

    /// <summary>构建运行中时禁用提交按钮。</summary>
    private bool _busy;

    /// <summary>当前页面触发的最近一次构建结果。</summary>
    private BuildResult? _lastResult;

    /// <summary>历史构建投影，来自 SQLite 状态库。</summary>
    private IReadOnlyList<BuildRunSummary>? _recent;

    protected override async Task OnInitializedAsync()
    {
        _recent = await Store.ListRecentRunsAsync(20, default);
    }

    /// <summary>触发一次 Full Build，并刷新发布历史。</summary>
    private async Task RunAsync()
    {
        if (_busy)
        {
            return;
        }

        _busy = true;
        try
        {
            var options = new BuildOptions
            {
                Mode = BuildMode.FullBuild,
                Environment = string.IsNullOrWhiteSpace(_environmentName) ? "production" : _environmentName,
                IncludeDrafts = _includeDrafts,
            };
            _lastResult = await Orchestrator.RunFullBuildAsync(
                options,
                string.IsNullOrWhiteSpace(_frontendThemeId) ? null : _frontendThemeId,
                default);
            _recent = await Store.ListRecentRunsAsync(20, default);
        }
        finally
        {
            _busy = false;
        }
    }

    /// <summary>把构建状态映射为普通发布语言。</summary>
    private static string PublishResultTitle(BuildStatus status)
        => status switch
        {
            BuildStatus.Succeeded => "发布成功",
            BuildStatus.Skipped => "内容没有变化",
            _ => "需要检查一下",
        };

    /// <summary>为最近一次构建生成轻量说明。</summary>
    private static string PublishResultDescription(BuildResult result)
        => result.Status switch
        {
            BuildStatus.Succeeded => "站点文件已经准备好，可以下载或继续预览。",
            BuildStatus.Skipped => result.Reason ?? "内容没有变化，所以这次跳过了重复构建。",
            _ => result.Reason ?? "有一步没有完成，打开高级日志可以定位具体阶段。",
        };

    /// <summary>把构建状态映射到柔和状态色。</summary>
    private static string BuildStatusTone(BuildStatus status)
        => status switch
        {
            BuildStatus.Succeeded => "success",
            BuildStatus.Skipped => "info",
            _ => "danger",
        };

    /// <summary>把 SHA-256 构建指纹缩短到适合列表展示的长度。</summary>
    private static string ShortFingerprint(BuildFingerprint fingerprint)
        => fingerprint.Value[..Math.Min(12, fingerprint.Value.Length)];
}
