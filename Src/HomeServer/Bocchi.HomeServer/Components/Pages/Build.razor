@page "/Admin/Publish"
@page "/Admin/Publish/{Section}"
@using System.Globalization
@using Bocchi.Generator.Pipeline
@using Bocchi.Generator.State
@using Bocchi.HomeServer.Build
@inject BuildOrchestrator Orchestrator
@inject IBuildStateStore Store
@inject DashboardLocalizationService I18n

<PageTitle>@CurrentPageTitle · Bocchi</PageTitle>

<article class="bocchi-shell bocchi-publish-shell">
    <header class="bocchi-page-intro">
        <span class="bocchi-eyebrow">@CurrentEyebrow</span>
        <h1>@CurrentHeading</h1>
        <p>@CurrentDescription</p>
    </header>

    <div class="bocchi-publish-layout">
        <BocchiPublishNav ActiveSection="@CurrentSection" />

        <div class="bocchi-publish-stack">
            @if (IsLocalOutputSection)
            {
                <section class="bocchi-panel bocchi-publish-local-output" aria-labelledby="publish-local-output-heading">
                    <span class="bocchi-publish-local-output__icon" aria-hidden="true">
                        <Blazicon Svg="Lucide.FolderOpen" />
                    </span>
                    <div>
                        <h2 id="publish-local-output-heading">@I18n["publish.localOutput.title"]</h2>
                        <p>@I18n["publish.localOutput.emptyDescription"]</p>
                    </div>
                </section>
            }
            else if (_recent is null)
            {
                <section class="bocchi-panel bocchi-publish-loading">
                    <p>@I18n["publish.loading"]</p>
                </section>
            }
            else
            {
                @RenderStaticOutputWorkbench()
            }
        </div>
    </div>
</article>

@code {
    private const string LocalOutputSection = "LocalOutput";

    /// <summary>
    /// 后续远端发布目标接入后再恢复为用户可配置的发布方案入口；当前阶段不要在 UI 中展示未实现渠道。
    /// </summary>
    // private static readonly IReadOnlyList<string> FuturePublishTargetChannels =
    // [
    //     PublishPlanService.GitHubPagesChannel,
    //     PublishPlanService.CloudflarePagesChannel,
    //     PublishPlanService.LocalDirectoryChannel,
    //     PublishPlanService.CustomChannel,
    // ];

    /// <summary>发布中心子路由片段；为空时展示默认“发布”子页。</summary>
    [Parameter]
    public string? Section { get; set; }

    /// <summary>静态输出生成中时禁用主操作。</summary>
    private bool _busy;

    /// <summary>当前页面触发的最近一次构建结果。</summary>
    private BuildResult? _lastResult;

    /// <summary>历史构建投影，来自 SQLite 状态库。</summary>
    private IReadOnlyList<BuildRunSummary>? _recent;

    /// <summary>规范化后的发布中心子页面。</summary>
    private string CurrentSection => string.Equals(Section, LocalOutputSection, StringComparison.OrdinalIgnoreCase)
        ? LocalOutputSection
        : string.Empty;

    /// <summary>当前是否展示本地输出子页面。</summary>
    private bool IsLocalOutputSection => CurrentSection == LocalOutputSection;

    /// <summary>当前页面标题。</summary>
    private string CurrentPageTitle => IsLocalOutputSection ? I18n["publish.localOutput.pageTitle"] : I18n["publish.page.title"];

    /// <summary>当前页面 eyebrow。</summary>
    private string CurrentEyebrow => IsLocalOutputSection ? I18n["publish.localOutput.eyebrow"] : I18n["publish.page.eyebrow"];

    /// <summary>当前页面主标题。</summary>
    private string CurrentHeading => IsLocalOutputSection ? I18n["publish.localOutput.heading"] : I18n["publish.page.heading"];

    /// <summary>当前页面说明。</summary>
    private string CurrentDescription => IsLocalOutputSection ? I18n["publish.localOutput.description"] : I18n["publish.page.description"];

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    /// <summary>读取近期生成记录；当前页面不读取发布方案，因为本地静态输出是内置产物。</summary>
    private async Task RefreshAsync()
    {
        _recent = await Store.ListRecentRunsAsync(20, default);
    }

    /// <summary>当前发布页主工作台：只暴露真实可执行的本地静态输出能力。</summary>
    private RenderFragment RenderStaticOutputWorkbench() => @<div class="bocchi-publish-workbench">
        <section class="bocchi-panel bocchi-publish-output-card" aria-labelledby="publish-run-heading">
            <div class="bocchi-publish-output-heading">
                <span class="bocchi-publish-output-heading__icon" aria-hidden="true">
                    <Blazicon Svg="Lucide.FolderOpen" />
                </span>
                <div>
                    <h2 id="publish-run-heading">@I18n["publish.output.title"]</h2>
                    <p>@I18n["publish.output.description"]</p>
                </div>
            </div>

            <div class="bocchi-publish-ready">
                <span aria-hidden="true"><Blazicon Svg="Lucide.Check" /></span>
                <div>
                    <strong>@I18n["publish.output.readyTitle"]</strong>
                    <p>@I18n["publish.output.readyDescription"]</p>
                </div>
            </div>

            <form class="bocchi-publish-run-form" @onsubmit="RunAsync" @onsubmit:preventDefault>
                <button type="submit" class="bocchi-publish-primary-action" disabled="@_busy">
                    <Blazicon Svg="Lucide.Send" />
                    <span>@(_busy ? I18n["publish.action.generating"] : I18n["publish.action.generateStaticSite"])</span>
                </button>
                <div class="bocchi-publish-quick-actions">
                    <a class="bocchi-button secondary" href="/" target="_blank" rel="noopener">
                        <Blazicon Svg="Lucide.Eye" />
                        <span>@I18n["publish.action.preview"]</span>
                    </a>
                    <a class="bocchi-button secondary" href="/Admin/Publish/download" target="_blank" rel="noopener">@I18n["publish.action.downloadZip"]</a>
                </div>

            </form>

            @RenderLastPublishMeta()
        </section>

        <section class="bocchi-panel bocchi-publish-history" aria-labelledby="history-heading">
            <h2 id="history-heading">@I18n["publish.history.title"]</h2>
            @RenderHistory()
            @RenderLastResult()
        </section>
    </div>;

    /// <summary>渲染最近一次生成的轻量状态条，让用户知道主按钮上次是否成功。</summary>
    private RenderFragment RenderLastPublishMeta() => @<div class="bocchi-publish-run-meta">
        <span>@LatestPublishSummary()</span>
        <span>@LatestPublishArtifactSummary()</span>
    </div>;

    /// <summary>渲染高级日志与产物清单；默认折叠，避免干扰普通发布路径。</summary>
    private RenderFragment RenderLastResult() => @<details class="bocchi-publish-advanced-strip bocchi-publish-result">
        <summary>
            <span>@I18n["publish.advanced.logManifest"]</span>
            <Blazicon Svg="Lucide.ChevronDown" />
        </summary>
        @if (_lastResult is null)
        {
            <p>@I18n["publish.advanced.emptyLogManifest"]</p>
        }
        else
        {
            <div class="bocchi-publish-result-summary">
                <BocchiStatusPill Tone="@BuildStatusTone(_lastResult.Status)">@BuildStatusText(_lastResult.Status)</BocchiStatusPill>
                <span>@PublishResultDescription(_lastResult)</span>
                <span>@string.Format(CultureInfo.CurrentCulture, I18n["publish.result.durationFormat"], _lastResult.Duration.TotalSeconds.ToString("F2", CultureInfo.CurrentCulture))</span>
                <span>@string.Format(CultureInfo.CurrentCulture, I18n["publish.result.artifactCountFormat"], _lastResult.Artifacts.Count)</span>
            </div>
            <pre>@string.Join('\n', _lastResult.Logs.Select(l => $"[{l.OccurredAt:HH:mm:ss}] {l.Level,-7} {l.Stage,-28} {l.Message}"))</pre>
            <div class="bocchi-publish-artifact-list">
                @foreach (var artifact in _lastResult.Artifacts)
                {
                    <div>
                        <code>@artifact.Path</code>
                        <span>@string.Format(CultureInfo.CurrentCulture, I18n["publish.advanced.bytesFormat"], artifact.SizeBytes)</span>
                    </div>
                }
            </div>
        }
    </details>;

    /// <summary>渲染近期生成记录；表格形态更接近发布后台，而不是内容列表。</summary>
    private RenderFragment RenderHistory() => @<div class="bocchi-publish-history-table-wrap">
        @if (_recent is null)
        {
            <p>@I18n["publish.history.loading"]</p>
        }
        else
        {
            <table class="bocchi-publish-history-table">
                <thead>
                    <tr>
                        <th>@I18n["publish.history.columnOutput"]</th>
                        <th>@I18n["publish.history.columnStatus"]</th>
                        <th>@I18n["publish.history.columnTime"]</th>
                        <th>@I18n["publish.history.columnDuration"]</th>
                        <th>@I18n["publish.history.columnFiles"]</th>
                        <th>@I18n["publish.history.columnAction"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_recent.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="bocchi-publish-history-table__empty">@I18n["publish.history.emptyDescription"]</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var run in _recent.Take(8))
                        {
                            <tr>
                                <td>
                                    <span class="bocchi-publish-history-output">
                                        <Blazicon Svg="Lucide.FolderOpen" />
                                        @I18n["publish.output.historyLabel"]
                                    </span>
                                </td>
                                <td><BocchiStatusPill Tone="@BuildStatusTone(run.Status)">@BuildStatusText(run.Status)</BocchiStatusPill></td>
                                <td>@run.StartedAt.ToString("yyyy-MM-dd HH:mm", CultureInfo.CurrentCulture)</td>
                                <td>@I18n["publish.history.unavailable"]</td>
                                <td>@I18n["publish.history.unavailable"]</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(run.Fingerprint))
                                    {
                                        <code>@run.Fingerprint[..Math.Min(8, run.Fingerprint.Length)]</code>
                                    }
                                    else
                                    {
                                        <span>@I18n["publish.history.unavailable"]</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        }
    </div>;

    /// <summary>触发一次 Full Build，并刷新发布历史。</summary>
    private async Task RunAsync()
    {
        if (_busy)
        {
            return;
        }

        _busy = true;
        try
        {
            var options = new BuildOptions
            {
                Mode = BuildMode.FullBuild,
                Environment = "production",
                IncludeDrafts = false,
            };
            _lastResult = await Orchestrator.RunFullBuildAsync(
                options,
                themeId: null,
                default);
            _recent = await Store.ListRecentRunsAsync(20, default);
        }
        finally
        {
            _busy = false;
        }
    }

    /// <summary>最近一次生成摘要；没有历史时保持安静，不制造虚假的成功状态。</summary>
    private string LatestPublishSummary()
    {
        if (_lastResult is not null)
        {
            return string.Format(
                CultureInfo.CurrentCulture,
                I18n["publish.last.currentRunFormat"],
                BuildStatusText(_lastResult.Status),
                _lastResult.Duration.TotalSeconds.ToString("F1", CultureInfo.CurrentCulture));
        }

        var latest = _recent?.FirstOrDefault();
        if (latest is null)
        {
            return I18n["publish.last.none"];
        }

        return string.Format(
            CultureInfo.CurrentCulture,
            I18n["publish.last.historyRunFormat"],
            BuildStatusText(latest.Status),
            latest.StartedAt.ToString("yyyy-MM-dd HH:mm", CultureInfo.CurrentCulture));
    }

    /// <summary>最近一次生成产物摘要；历史投影没有文件数量时展示稳定占位。</summary>
    private string LatestPublishArtifactSummary()
    {
        if (_lastResult is not null)
        {
            return string.Format(CultureInfo.CurrentCulture, I18n["publish.result.artifactCountFormat"], _lastResult.Artifacts.Count);
        }

        return I18n["publish.last.artifactsPending"];
    }

    /// <summary>为最近一次构建生成轻量说明。</summary>
    private string PublishResultDescription(BuildResult result)
        => result.Status switch
        {
            BuildStatus.Succeeded => I18n["publish.result.succeededDescription"],
            BuildStatus.Skipped => result.Reason ?? I18n["publish.result.skippedDescription"],
            _ => result.Reason ?? I18n["publish.result.failedDescription"],
        };

    /// <summary>把构建状态映射到柔和状态色。</summary>
    private static string BuildStatusTone(BuildStatus status)
        => status switch
        {
            BuildStatus.Succeeded => "success",
            BuildStatus.Skipped => "info",
            _ => "danger",
        };

    /// <summary>把构建状态映射为本地化文案。</summary>
    private string BuildStatusText(BuildStatus status)
        => status switch
        {
            BuildStatus.Succeeded => I18n["publish.status.succeeded"],
            BuildStatus.Skipped => I18n["publish.status.skipped"],
            _ => I18n["publish.status.failed"],
        };
}
