@page "/Admin"

<PageTitle>Home · Bocchi</PageTitle>

<article class="bocchi-shell bocchi-shell--dashboard">
    <section class="bocchi-home-hero" aria-labelledby="home-heading">
        <div>
            <span class="bocchi-page-heading__eyebrow">Bocchi Home Server</span>
            <h1 id="home-heading">Good to see you.</h1>
            <p>Here is what is happening with your site. Keep writing, preview softly, and publish when everything looks okay.</p>
        </div>
        <div class="bocchi-hero-illustration" aria-hidden="true">
            <Blazicon Svg="Lucide.BookOpen" />
            <span></span>
        </div>
    </section>

    <div class="bocchi-dashboard-board">
        <section class="bocchi-content-feed" aria-labelledby="feed-heading">
            <div class="bocchi-feed-toolbar">
                <div class="bocchi-feed-tabs" aria-label="Content filters">
                    <a class="active" href="/Admin/Content">All</a>
                    <a href="/Admin/Content?kind=Post">Posts</a>
                    <a href="/Admin/Content?kind=Page">Pages</a>
                    <a href="/Admin/Content?kind=Note">Notes</a>
                    <a href="/Admin/Content?kind=Work">Works</a>
                </div>
                <a class="bocchi-sort-button" href="/Admin/Content">
                    <Blazicon Svg="Lucide.ListFilter" />
                    <span>Sort: Latest</span>
                </a>
            </div>

            <h2 id="feed-heading" class="bocchi-visually-hidden">Recent content</h2>
            <div class="bocchi-content-list">
                <a class="bocchi-content-item" href="/Admin/Content/Edit">
                    <span class="bocchi-content-item__icon bocchi-content-item__icon--pink">
                        <Blazicon Svg="Lucide.FileText" />
                    </span>
                    <span class="bocchi-content-item__main">
                        <strong>Why I Write on Sundays</strong>
                        <small>/posts/why-i-write-on-sundays</small>
                    </span>
                    <BocchiStatusPill Tone="success">Ready</BocchiStatusPill>
                    <span class="bocchi-content-item__date">Today</span>
                    <span class="bocchi-content-item__action">Preview</span>
                </a>

                <a class="bocchi-content-item" href="/Admin/Content/Edit">
                    <span class="bocchi-content-item__icon bocchi-content-item__icon--lavender">
                        <Blazicon Svg="Lucide.PenLine" />
                    </span>
                    <span class="bocchi-content-item__main">
                        <strong>Bedroom Studio Tour</strong>
                        <small>/posts/bedroom-studio-tour</small>
                    </span>
                    <BocchiStatusPill Tone="warning">Draft</BocchiStatusPill>
                    <span class="bocchi-content-item__date">Yesterday</span>
                    <span class="bocchi-content-item__action">Continue</span>
                </a>

                <a class="bocchi-content-item" href="/Admin/Content/Edit">
                    <span class="bocchi-content-item__icon bocchi-content-item__icon--blue">
                        <Blazicon Svg="Lucide.BookOpen" />
                    </span>
                    <span class="bocchi-content-item__main">
                        <strong>About This Blog</strong>
                        <small>/about</small>
                    </span>
                    <BocchiStatusPill Tone="success">Ready</BocchiStatusPill>
                    <span class="bocchi-content-item__date">May 10</span>
                    <span class="bocchi-content-item__action">Preview</span>
                </a>

                <a class="bocchi-content-item" href="/Admin/Content/Edit">
                    <span class="bocchi-content-item__icon bocchi-content-item__icon--amber">
                        <Blazicon Svg="Lucide.FolderOpen" />
                    </span>
                    <span class="bocchi-content-item__main">
                        <strong>My Favorite Albums</strong>
                        <small>/works/favorite-albums</small>
                    </span>
                    <BocchiStatusPill Tone="warning">Needs a look</BocchiStatusPill>
                    <span class="bocchi-content-item__date">May 9</span>
                    <span class="bocchi-content-item__action">Preview</span>
                </a>
            </div>
        </section>

        <aside class="bocchi-home-side" aria-label="Preview and publish readiness">
            <section class="bocchi-preview-card">
                <div class="bocchi-card-heading">
                    <Blazicon Svg="Lucide.Monitor" />
                    <h2>Site preview</h2>
                    <a href="/" target="_blank" rel="noopener">Open site</a>
                </div>
                <div class="bocchi-preview-frame">
                    <div class="bocchi-preview-sky"></div>
                    <div class="bocchi-preview-desk"></div>
                    <strong>soft notes from Bocchi</strong>
                </div>
                <p><Blazicon Svg="Lucide.LockKeyhole" /> Password-protected</p>
            </section>

            <section class="bocchi-readiness-card">
                <div class="bocchi-card-heading">
                    <Blazicon Svg="Lucide.Sun" />
                    <h2>Publish readiness</h2>
                </div>
                <ul>
                    <li><Blazicon Svg="Lucide.CircleCheck" />Content looks good</li>
                    <li><Blazicon Svg="Lucide.CircleCheck" />Images look good</li>
                    <li><Blazicon Svg="Lucide.TriangleAlert" />One link needs review</li>
                    <li><Blazicon Svg="Lucide.CircleCheck" />Settings are set</li>
                </ul>
                <a class="bocchi-readiness-card__action" href="/Admin/Publish">Everything looks good</a>
            </section>
        </aside>
    </div>
</article>
