@page "/Admin"
@using System.Globalization
@using Bocchi.ContentModel
@using Bocchi.HomeServer.Data
@using Bocchi.HomeServer.Services
@using Bocchi.Workspace.State
@inject DashboardLocalizationService I18n
@inject IContentStateStore Store
@inject DashboardGuideService Guides

<PageTitle>@I18n["home.page.title"] · Bocchi</PageTitle>

<article class="bocchi-shell bocchi-shell--dashboard">
    <header class="bocchi-page-intro">
        <span class="bocchi-eyebrow">@I18n["home.page.eyebrow"]</span>
        <h1>@I18n["home.page.heading"]</h1>
        <p>@I18n["home.page.description"]</p>
    </header>

    @* Note 发布的全局提示：错误用警告色，成功不抢戏。 *@
    @if (!string.IsNullOrEmpty(NoteError))
    {
        <div class="bocchi-banner bocchi-banner--warning" role="alert">
            @string.Format(CultureInfo.CurrentCulture, I18n["home.composer.publishFailed"], NoteError)
        </div>
    }

    @* Guide 卡堆栈：当前仅显示顶层卡片，底部用圆点提示总数。 *@
    @if (_guides.Count > 0)
    {
        <section class="bocchi-guide-stack" aria-label="@I18n[$"home.guide.{_guides[0].Key}.title"]">
            <article @key="_guides[0].Key" class="bocchi-guide-stack__top">
                <div class="bocchi-guide-stack__body">
                    <strong>@I18n[$"home.guide.{_guides[0].Key}.title"]</strong>
                    <p>@I18n[$"home.guide.{_guides[0].Key}.body"]</p>
                    @if (GuideAction(_guides[0].Key) is { } act)
                    {
                        <a class="bocchi-link-pill" href="@act.Url">
                            <span>@I18n[$"home.guide.{_guides[0].Key}.action"]</span>
                            <Blazicon Svg="Lucide.ArrowRight" />
                        </a>
                    }
                </div>
                <button type="button"
                        class="bocchi-icon-button bocchi-guide-stack__dismiss"
                        aria-label='@I18n["home.guide.dismiss.aria"]'
                        disabled="@_guideDismissInFlight"
                        @onclick="DismissCurrentGuideAsync">
                    <Blazicon Svg="Lucide.X" />
                </button>
            </article>
            @if (_guides.Count > 1)
            {
                <div class="bocchi-guide-stack__dots" aria-hidden="true">
                    @for (var i = 0; i < _guides.Count; i++)
                    {
                        <span class="@(i == 0 ? "bocchi-guide-stack__dot bocchi-guide-stack__dot--active" : "bocchi-guide-stack__dot")"></span>
                    }
                </div>
            }
        </section>
    }

    @* 快捷动作：4 张大色块卡。 *@
    <section class="bocchi-quick-actions" aria-label="@I18n["home.page.heading"]">
        @foreach (var q in QuickActions)
        {
            <a class="bocchi-quick-card" href="@q.Url">
                <span class="bocchi-quick-card__icon bocchi-quick-card__icon--@q.Tone">
                    <Blazicon Svg="@q.Icon" />
                </span>
                <span class="bocchi-quick-card__body">
                    <strong>@I18n[q.TitleKey]</strong>
                    <span>@I18n[q.SubtitleKey]</span>
                </span>
            </a>
        }
    </section>

    @* 主体两栏：左侧 Composer，右侧站点预览卡。 *@
    <div class="bocchi-home-grid">
        <BocchiNoteComposer ReturnUrl="/Admin" />

        <aside class="bocchi-preview-card bocchi-preview-card--home">
            <div class="bocchi-card-heading">
                <Blazicon Svg="Lucide.Monitor" />
                <h2>@I18n["home.preview.title"]</h2>
            </div>
            <p class="bocchi-card-copy">@I18n["home.preview.description"]</p>
            <a class="bocchi-button" href="/" target="_blank" rel="noopener">
                <span>@I18n["home.preview.open"]</span>
                <Blazicon Svg="Lucide.ExternalLink" />
            </a>
        </aside>
    </div>

    @* 最近内容：只放文章、短文、作品，避免站点配置和固定页面混入创作流。 *@
    <section class="bocchi-recent" aria-labelledby="recent-heading">
        <header class="bocchi-recent__head">
            <h2 id="recent-heading">@I18n["home.recent.title"]</h2>
            <a class="bocchi-link-pill" href="/Admin/Content">
                <span>@I18n["home.recent.viewAll"]</span>
                <Blazicon Svg="Lucide.ArrowRight" />
            </a>
        </header>

        @if (_recentContent.Count == 0)
        {
            <div class="bocchi-home-empty">
                <span class="bocchi-home-empty__icon">
                    <Blazicon Svg="Lucide.FileText" />
                </span>
                <div>
                    <strong>@I18n["home.recent.emptyTitle"]</strong>
                    <p>@I18n["home.recent.emptyDescription"]</p>
                </div>
            </div>
        }
        else
        {
            <div class="bocchi-content-list">
                @foreach (var item in _recentContent)
                {
                    <a class="bocchi-content-item" href="@ContentEditingService.EditUrl(item.RelativePath)">
                        <span class="bocchi-content-item__icon @ContentIconClass(item.Kind)">
                            <Blazicon Svg="@ContentIcon(item.Kind)" />
                        </span>
                        <span class="bocchi-content-item__main">
                            <strong>@ContentTitle(item)</strong>
                            <small>@KindLabel(item.Kind) · @item.RelativePath</small>
                        </span>
                        <BocchiStatusPill Tone="@ContentStatusTone(item.Status)">@ContentStatusLabel(item.Status)</BocchiStatusPill>
                        <span class="bocchi-content-item__date">@ContentTimeLabel(item)</span>
                        <span class="bocchi-content-item__action">@ContentActionLabel(item.Status)</span>
                    </a>
                }
            </div>
        }
    </section>
</article>

@code {
    /// <summary>Note 发布失败时由查询参数传入的错误文案。</summary>
    [SupplyParameterFromQuery(Name = "noteError")] public string? NoteError { get; set; }

    /// <summary>最近内容投影。</summary>
    private IReadOnlyList<ContentSummary> _recentContent = [];

    /// <summary>当前激活的 Guide 卡片。</summary>
    private List<DashboardGuideCardRecord> _guides = [];

    /// <summary>防止连续点击关闭按钮时重复提交同一张 Guide 卡。</summary>
    private bool _guideDismissInFlight;

    /// <summary>首页 4 张快捷动作的元数据。Tone 对应 quick-card 配色变体。</summary>
    private static readonly QuickAction[] QuickActions =
    [
        new("home.quick.writePost.title", "home.quick.writePost.subtitle", "/Admin/Content/Edit?kind=post", Lucide.FileText, "pink"),
        new("home.quick.writeNote.title", "home.quick.writeNote.subtitle", "#bocchi-composer", Lucide.PenLine, "lavender"),
        new("home.quick.editPage.title", "home.quick.editPage.subtitle", "/Admin/Pages", Lucide.BookOpen, "blue"),
        new("home.quick.publish.title", "home.quick.publish.subtitle", "/Admin/Publish", Lucide.Send, "green"),
    ];

    protected override async Task OnInitializedAsync()
    {
        var summaries = await Store.ListContentSummariesAsync(null);
        _recentContent = summaries
            .Where(x => IsRecentContentKind(x.Kind))
            .OrderByDescending(x => x.UpdatedAt ?? x.PublishedAt)
            .ThenBy(x => x.Title ?? x.ContentId)
            .Take(6)
            .ToList();
        _guides = [.. await Guides.ListActiveAsync()];
    }

    /// <summary>把 Guide 卡映射到具体的跳转目标；缺省时不渲染 action。</summary>
    private static (string Url, string Hint)? GuideAction(string key)
        => key switch
        {
            DashboardGuideService.SiteLanguageKey => ("/Admin/Settings/Localization", "settings"),
            DashboardGuideService.SiteThemeKey => ("/Admin/Site/Theme", "settings"),
            DashboardGuideService.EditPageKey => ("/Admin/Pages", "pages"),
            DashboardGuideService.WelcomeKey => ("/Admin/Settings", "settings"),
            _ => null,
        };

    /// <summary>关闭当前 Guide 卡并直接切到下一张，避免传统 form post 带来的整页刷新。</summary>
    private async Task DismissCurrentGuideAsync()
    {
        if (_guideDismissInFlight || _guides.Count == 0)
        {
            return;
        }

        var dismissed = _guides[0];
        _guides.RemoveAt(0);
        _guideDismissInFlight = true;

        try
        {
            await Guides.DismissAsync(dismissed.Key);
        }
        finally
        {
            _guideDismissInFlight = false;
        }
    }

    private static string ContentTitle(ContentSummary item)
        => string.IsNullOrWhiteSpace(item.Title) ? item.ContentId : item.Title;

    private string ContentStatusLabel(ContentStatus status)
        => status switch
        {
            ContentStatus.Published => I18n["home.status.ready"],
            ContentStatus.Archived => I18n["home.status.archived"],
            _ => I18n["home.status.draft"],
        };

    private static string ContentStatusTone(ContentStatus status)
        => status switch
        {
            ContentStatus.Published => "success",
            ContentStatus.Archived => "neutral",
            _ => "warning",
        };

    private string ContentActionLabel(ContentStatus status)
        => status == ContentStatus.Draft ? I18n["home.action.continue"] : I18n["home.action.edit"];

    private static string ContentTimeLabel(ContentSummary item)
        => (item.UpdatedAt ?? item.PublishedAt)?.ToString("yyyy-MM-dd", CultureInfo.CurrentCulture) ?? "-";

    /// <summary>首页最近内容只展示面向读者的创作内容，不展示页面、友链和站点配置。</summary>
    private static bool IsRecentContentKind(ContentKind kind)
        => kind is ContentKind.Post or ContentKind.Note or ContentKind.Work;

    private string KindLabel(ContentKind kind)
        => kind switch
        {
            ContentKind.Page => I18n["home.kind.page"],
            ContentKind.Work => I18n["home.kind.work"],
            ContentKind.Note => I18n["home.kind.note"],
            _ => I18n["home.kind.post"],
        };

    private static SvgIcon ContentIcon(ContentKind kind)
        => kind switch
        {
            ContentKind.Page => Lucide.BookOpen,
            ContentKind.Work => Lucide.FolderOpen,
            ContentKind.Note => Lucide.PenLine,
            _ => Lucide.FileText,
        };

    private static string ContentIconClass(ContentKind kind)
        => kind switch
        {
            ContentKind.Page => "bocchi-content-item__icon--blue",
            ContentKind.Work => "bocchi-content-item__icon--amber",
            ContentKind.Note => "bocchi-content-item__icon--lavender",
            _ => "bocchi-content-item__icon--pink",
        };

    /// <summary>首页快捷动作卡片的不可变描述。</summary>
    private sealed record QuickAction(string TitleKey, string SubtitleKey, string Url, SvgIcon Icon, string Tone);

}
