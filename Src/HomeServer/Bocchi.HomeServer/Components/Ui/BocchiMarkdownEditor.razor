@implements IAsyncDisposable
@inject IJSRuntime Js
@inject DashboardLocalizationService I18n

<section @ref="_root" class="@EditorRootClass" data-view="@ViewModeCss">
    @* 工具栏与视图切换同一行；嵌入 ContentEditor 时去掉外层卡片感。 *@
    <div class="bocchi-markdown-editor__chrome">
        @if (ShowDocumentHeader)
        {
            <div class="bocchi-markdown-editor__title">
                <span>@ResolvedContentKindLabel</span>
                <h2>@ResolvedTitle</h2>
            </div>
        }

        <div class="bocchi-markdown-toolbar" role="toolbar" aria-label='@I18n["markdownEditor.toolbar.aria"]'>
        <div class="bocchi-markdown-toolbar__group">
            <button type="button" title='@I18n["markdownEditor.toolbar.heading"]' aria-label='@I18n["markdownEditor.toolbar.heading"]' @onclick='() => ApplyAsync("heading")'>
                <Blazicon Svg="Lucide.Heading2" />
            </button>
            <button type="button" title='@I18n["markdownEditor.toolbar.bold"]' aria-label='@I18n["markdownEditor.toolbar.bold"]' @onclick='() => ApplyAsync("bold")'>
                <Blazicon Svg="Lucide.Bold" />
            </button>
            <button type="button" title='@I18n["markdownEditor.toolbar.italic"]' aria-label='@I18n["markdownEditor.toolbar.italic"]' @onclick='() => ApplyAsync("italic")'>
                <Blazicon Svg="Lucide.Italic" />
            </button>
            <button type="button" title='@I18n["markdownEditor.toolbar.quote"]' aria-label='@I18n["markdownEditor.toolbar.quote"]' @onclick='() => ApplyAsync("quote")'>
                <Blazicon Svg="Lucide.Quote" />
            </button>
            <button type="button" title='@I18n["markdownEditor.toolbar.list"]' aria-label='@I18n["markdownEditor.toolbar.list"]' @onclick='() => ApplyAsync("list")'>
                <Blazicon Svg="Lucide.List" />
            </button>
            <button type="button" title='@I18n["markdownEditor.toolbar.ordered"]' aria-label='@I18n["markdownEditor.toolbar.ordered"]' @onclick='() => ApplyAsync("ordered")'>
                <Blazicon Svg="Lucide.ListOrdered" />
            </button>
            <button type="button" title='@I18n["markdownEditor.toolbar.code"]' aria-label='@I18n["markdownEditor.toolbar.code"]' @onclick='() => ApplyAsync("code")'>
                <Blazicon Svg="Lucide.Code" />
            </button>
        </div>
        <div class="bocchi-markdown-toolbar__group">
            <button type="button" title='@I18n["markdownEditor.toolbar.link"]' aria-label='@I18n["markdownEditor.toolbar.link"]' @onclick='() => ApplyAsync("link")'>
                <Blazicon Svg="Lucide.Link" />
            </button>
            <button type="button"
                    title='@I18n["markdownEditor.toolbar.image"]'
                    aria-label='@I18n["markdownEditor.toolbar.image"]'
                    data-bocchi-markdown-image-mode="@ImageUploadMode"
                    @onclick="InsertImageAsync">
                <Blazicon Svg="Lucide.Image" />
            </button>
            <button type="button" title='@I18n["markdownEditor.toolbar.formula"]' aria-label='@I18n["markdownEditor.toolbar.formula"]' @onclick='() => ApplyAsync("formula")'>
                <Blazicon Svg="Lucide.Sigma" />
            </button>
            <button type="button" title='@I18n["markdownEditor.toolbar.video"]' aria-label='@I18n["markdownEditor.toolbar.video"]' @onclick='() => ApplyAsync("video")'>
                <Blazicon Svg="Lucide.Video" />
            </button>
            <button type="button" title='@I18n["markdownEditor.toolbar.linkCard"]' aria-label='@I18n["markdownEditor.toolbar.linkCard"]' @onclick='() => ApplyAsync("link-card")'>
                <Blazicon Svg="Lucide.SquareDashedText" />
            </button>
        </div>
        </div>

        <div class="bocchi-markdown-editor__view" role="group" aria-label='@I18n["markdownEditor.view.aria"]'>
            <button type="button"
                    class="@ViewButtonClass(EditorViewMode.Write)"
                    aria-pressed="@AriaPressed(_viewMode == EditorViewMode.Write)"
                    title='@I18n["markdownEditor.view.write"]'
                    aria-label='@I18n["markdownEditor.view.write"]'
                    @onclick="() => SetViewModeAsync(EditorViewMode.Write)">
                <Blazicon Svg="Lucide.Pencil" />
            </button>
            <button type="button"
                    class="@ViewButtonClass(EditorViewMode.Split)"
                    aria-pressed="@AriaPressed(_viewMode == EditorViewMode.Split)"
                    title='@I18n["markdownEditor.view.split"]'
                    aria-label='@I18n["markdownEditor.view.split"]'
                    @onclick="() => SetViewModeAsync(EditorViewMode.Split)">
                <Blazicon Svg="Lucide.Columns2" />
            </button>
            <button type="button"
                    class="@ViewButtonClass(EditorViewMode.Preview)"
                    aria-pressed="@AriaPressed(_viewMode == EditorViewMode.Preview)"
                    title='@I18n["markdownEditor.view.preview"]'
                    aria-label='@I18n["markdownEditor.view.preview"]'
                    @onclick="() => SetViewModeAsync(EditorViewMode.Preview)">
                <Blazicon Svg="Lucide.Eye" />
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_assetUploadError))
    {
        <p class="bocchi-markdown-editor__asset-error" role="alert">@_assetUploadError</p>
    }

    <div class="bocchi-markdown-editor__body">
        <div class="bocchi-markdown-editor__pane bocchi-markdown-editor__pane--write">
            <span class="bocchi-visually-hidden">@ResolvedTitle</span>
            <div class="bocchi-codemirror-host" data-bocchi-codemirror-host></div>
        </div>

        <aside class="bocchi-markdown-editor__pane bocchi-markdown-editor__pane--preview" aria-label='@I18n["markdownEditor.preview.aria"]'>
            @if (string.IsNullOrWhiteSpace(PreviewHtml))
            {
                <div class="bocchi-markdown-editor__empty">@I18n["markdownEditor.preview.empty"]</div>
            }
            else
            {
                <div class="bocchi-markdown-preview">@((MarkupString)PreviewHtml)</div>
            }
        </aside>
    </div>
</section>

@code {
    /// <summary>编辑器上方的小标签；新调用点优先使用 <see cref="ContentKindLabel"/>。</summary>
    [Parameter]
    public string Kicker { get; set; } = "Markdown";

    /// <summary>当前内容类型标签，例如文章、页面或作品。</summary>
    [Parameter]
    public string? ContentKindLabel { get; set; }

    /// <summary>编辑器标题。</summary>
    [Parameter]
    public string? Title { get; set; }

    /// <summary>Markdown 正文。</summary>
    [Parameter]
    public string Value { get; set; } = string.Empty;

    /// <summary>Markdown 正文变化回调，父组件负责更新预览 HTML。</summary>
    [Parameter]
    public EventCallback<string> ValueChanged { get; set; }

    /// <summary>已经由统一 Markdown pipeline 渲染好的预览 HTML。</summary>
    [Parameter]
    public string PreviewHtml { get; set; } = string.Empty;

    /// <summary>正文为空时显示的轻提示。</summary>
    [Parameter]
    public string? Placeholder { get; set; }

    /// <summary>默认视图模式：write、split 或 preview。</summary>
    [Parameter]
    public string DefaultViewMode { get; set; } = "write";

    /// <summary>是否显示编辑器顶部的类型与标题栏；ContentEditor 等宿主页面已有上下文时设为 false。</summary>
    [Parameter]
    public bool ShowDocumentHeader { get; set; } = true;

    /// <summary>浏览器通过 paste、drop 或文件选择拿到图片后，调用父组件上传到当前内容组 assets/。</summary>
    [Parameter]
    public Func<MarkdownEditorImageUploadRequest, Task<MarkdownEditorAssetUploadResult>>? OnImageUploadAsync { get; set; }

    /// <summary>承载 CodeMirror 实例的组件根元素。</summary>
    private ElementReference _root;

    /// <summary>Blazor 到 JavaScript 的回调引用，用于接收 CodeMirror 文档变化。</summary>
    private DotNetObjectReference<BocchiMarkdownEditor>? _dotNetReference;

    /// <summary>JavaScript 编辑器是否已经挂载。</summary>
    private bool _mounted;

    /// <summary>避免 Blazor 参数回写与 CodeMirror input 回调互相覆盖。</summary>
    private string _lastEditorValue = string.Empty;

    /// <summary>当前编辑视图，默认只显示编辑区，让移动端首屏更聚焦。</summary>
    private EditorViewMode _viewMode;

    /// <summary>默认视图只在首次渲染前读取一次，避免父组件重渲染时打断用户切换。</summary>
    private bool _viewModeInitialized;

    /// <summary>单张图片的读取上限，避免浏览器把意外的大文件塞进 Blazor circuit。</summary>
    private const long MaxImageUploadBytes = 20 * 1024 * 1024;

    /// <summary>图片上传失败时在编辑器本体内展示的短提示。</summary>
    private string? _assetUploadError;

    private string ResolvedContentKindLabel => string.IsNullOrWhiteSpace(ContentKindLabel) ? Kicker : ContentKindLabel;

    /// <summary>编辑器标题为空时回退到 Dashboard 当前语言的默认正文标题。</summary>
    private string ResolvedTitle => string.IsNullOrWhiteSpace(Title) ? I18n["markdownEditor.title"] : Title!;

    /// <summary>CodeMirror placeholder 为空时回退到 Dashboard 当前语言的默认提示。</summary>
    private string ResolvedPlaceholder => string.IsNullOrWhiteSpace(Placeholder) ? I18n["markdownEditor.placeholder"] : Placeholder!;

    /// <summary>图片按钮当前是打开上传选择器，还是只插入 Markdown snippet。</summary>
    private string ImageUploadMode => OnImageUploadAsync is null ? "snippet" : "upload";

    /// <summary>传给 JavaScript 插入命令的本地化占位文本。</summary>
    private IReadOnlyDictionary<string, string> MarkdownSnippets => new Dictionary<string, string>(StringComparer.Ordinal)
    {
        ["heading"] = I18n["markdownEditor.snippet.heading"],
        ["bold"] = I18n["markdownEditor.snippet.bold"],
        ["italic"] = I18n["markdownEditor.snippet.italic"],
        ["quote"] = I18n["markdownEditor.snippet.quote"],
        ["list"] = I18n["markdownEditor.snippet.list"],
        ["ordered"] = I18n["markdownEditor.snippet.ordered"],
        ["link"] = I18n["markdownEditor.snippet.link"],
        ["image"] = I18n["markdownEditor.snippet.image"],
    };

    private string ViewModeCss => _viewMode switch
    {
        EditorViewMode.Preview => "preview",
        EditorViewMode.Split => "split",
        _ => "write",
    };

    /// <summary>嵌入 ContentEditor 时使用紧凑根 class，去掉独立卡片 chrome。</summary>
    private string EditorRootClass => ShowDocumentHeader
        ? "bocchi-markdown-editor"
        : "bocchi-markdown-editor bocchi-markdown-editor--embedded";

    protected override void OnParametersSet()
    {
        if (!_viewModeInitialized)
        {
            _viewMode = ParseViewMode(DefaultViewMode);
            _viewModeInitialized = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_mounted)
        {
            _dotNetReference = DotNetObjectReference.Create(this);
            await Js.InvokeVoidAsync("bocchiMarkdownEditor.mount", _root, _dotNetReference, new
            {
                value = Value,
                placeholder = ResolvedPlaceholder,
                defaultViewMode = ViewModeCss,
                snippets = MarkdownSnippets,
            });
            _lastEditorValue = Value;
            _mounted = true;
            return;
        }

        if (!string.Equals(Value, _lastEditorValue, StringComparison.Ordinal))
        {
            await Js.InvokeVoidAsync("bocchiMarkdownEditor.setValue", _root, Value);
            _lastEditorValue = Value;
        }
    }

    /// <summary>接收 CodeMirror 文档变化并转交给父组件。</summary>
    [JSInvokable]
    public async Task HandleEditorInputAsync(string value)
    {
        _lastEditorValue = value;
        await ValueChanged.InvokeAsync(value);
    }

    /// <summary>接收浏览器图片文件，并委托父组件写入当前内容组 assets/。</summary>
    [JSInvokable]
    public async Task<MarkdownEditorAssetUploadResult> HandleImageUploadAsync(
        string? fileName,
        string? contentType,
        IJSStreamReference content)
    {
        if (OnImageUploadAsync is null)
        {
            var unavailable = I18n["markdownEditor.asset.uploadUnavailable"];
            _assetUploadError = unavailable;
            await InvokeAsync(StateHasChanged);
            return MarkdownEditorAssetUploadResult.Failure(unavailable);
        }

        try
        {
            await using var stream = await content.OpenReadStreamAsync(MaxImageUploadBytes);
            var result = await OnImageUploadAsync(new MarkdownEditorImageUploadRequest
            {
                FileName = fileName,
                ContentType = contentType,
                Content = stream,
            });
            _assetUploadError = string.IsNullOrWhiteSpace(result.Error) ? null : result.Error;
            await InvokeAsync(StateHasChanged);
            return result;
        }
        catch (Exception ex) when (ex is IOException or InvalidOperationException or JSException)
        {
            var failed = I18n["markdownEditor.asset.uploadFailed"];
            _assetUploadError = failed;
            await InvokeAsync(StateHasChanged);
            return MarkdownEditorAssetUploadResult.Failure(failed);
        }
    }

    /// <summary>JS 桥接层自身失败时展示 Dashboard 当前语言下的错误。</summary>
    [JSInvokable]
    public async Task HandleImageUploadFailureAsync(string? detail)
    {
        _assetUploadError = string.IsNullOrWhiteSpace(detail)
            ? I18n["markdownEditor.asset.uploadFailed"]
            : string.Format(System.Globalization.CultureInfo.CurrentCulture, I18n["markdownEditor.asset.uploadFailedWithDetailFormat"], detail);
        await InvokeAsync(StateHasChanged);
    }

    private static string ViewButtonClass(EditorViewMode mode)
        => mode == EditorViewMode.Split ? "split" : mode.ToString().ToLowerInvariant();

    private async Task SetViewModeAsync(EditorViewMode mode)
    {
        _viewMode = mode;
        if (_mounted)
        {
            await Js.InvokeVoidAsync("bocchiMarkdownEditor.setViewMode", _root, ViewModeCss);
        }
    }

    /// <summary>父组件（ContentEditor 窄屏预览 tab）切换 write / split / preview。</summary>
    public Task SetEditorViewModeAsync(string mode)
        => SetViewModeAsync(ParseViewMode(mode));

    private async Task ApplyAsync(string action)
    {
        if (_mounted)
        {
            await Js.InvokeVoidAsync("bocchiMarkdownEditor.insert", _root, action);
        }
    }

    private async Task InsertImageAsync()
    {
        if (!_mounted)
        {
            return;
        }

        if (OnImageUploadAsync is null)
        {
            await ApplyAsync("image");
            return;
        }

        await Js.InvokeVoidAsync("bocchiMarkdownEditor.pickImages", _root);
    }

    private static string AriaPressed(bool pressed) => pressed ? "true" : "false";

    private static EditorViewMode ParseViewMode(string? value)
        => value?.ToLowerInvariant() switch
        {
            "preview" => EditorViewMode.Preview,
            "split" => EditorViewMode.Split,
            _ => EditorViewMode.Write,
        };

    public async ValueTask DisposeAsync()
    {
        if (_mounted)
        {
            try
            {
                await Js.InvokeVoidAsync("bocchiMarkdownEditor.dispose", _root);
            }
            catch (JSDisconnectedException)
            {
                // 组件随 Blazor circuit 断开时无需再访问浏览器实例。
            }
        }

        _dotNetReference?.Dispose();
    }

    /// <summary>编辑器视图模式。</summary>
    private enum EditorViewMode
    {
        Write,
        Split,
        Preview,
    }
}
