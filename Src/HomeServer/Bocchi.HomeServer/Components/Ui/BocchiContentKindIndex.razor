@using System.Globalization
@using Bocchi.ContentModel
@using Bocchi.HomeServer.Services
@using Bocchi.Workspace.Scanning
@using Bocchi.Workspace.State
@inject DashboardLocalizationService I18n
@inject IContentStateStore Store
@inject ContentEditingService Editor
@inject ContentScanner Scanner

<article class="bocchi-shell bocchi-shell--dashboard">
    <header class="bocchi-page-intro">
        <span class="bocchi-eyebrow">@I18n["nav." + KindSlug]</span>
        <h1>@I18n[$"kind.{KindSlug}.title"]</h1>
        <p>@I18n[$"kind.{KindSlug}.description"]</p>
    </header>

    @if (Kind == ContentKind.Note)
    {
        <BocchiNoteComposer ReturnUrl="/Admin/Notes" />
    }

    <section class="bocchi-kind-actions" aria-label='@I18n["kind.index.actions.aria"]'>
        @if (Kind != ContentKind.Note)
        {
            <a class="bocchi-kind-action bocchi-kind-action--primary" href="@CreateUrl">
                <Blazicon Svg="Lucide.Plus" />
                <span>@I18n["kind.index.actions.create"]</span>
            </a>
            @if (HasTaxonomy)
            {
                <div class="bocchi-kind-action-group" role="group" aria-label='@I18n["kind.index.taxonomy.aria"]'>
                    @* 类别树现在是独立页面（/Admin/Site/Categories），不再在列表页内嵌展开。 *@
                    <a class="bocchi-kind-action bocchi-kind-action--grouped"
                       href="@CategoriesUrl">
                        @I18n["kind.index.actions.categories"]
                    </a>
                    <button type="button" class="bocchi-kind-action bocchi-kind-action--grouped">@I18n["kind.index.actions.tags"]</button>
                </div>
            }
        }
        <button type="button"
                class="bocchi-kind-action bocchi-kind-action--refresh"
                title='@I18n["kind.index.actions.refreshTitle"]'
                aria-label='@I18n["kind.index.actions.refreshTitle"]'
                disabled="@_refreshing"
                @onclick="RefreshWorkspaceAsync">
            <Blazicon Svg="Lucide.Repeat2" />
            <span>@(_refreshing ? I18n["kind.index.actions.refreshing"] : I18n["kind.index.actions.refresh"])</span>
        </button>
    </section>

    @if (_items.Count == 0)
    {
        <div class="bocchi-kind-empty">
            <div class="bocchi-kind-empty__body">
                <strong>@string.Format(CultureInfo.CurrentCulture, I18n["kind.index.empty.titleFormat"], I18n[$"kind.{KindSlug}.title"])</strong>
                <p>@I18n["kind.index.empty.description"]</p>
                @if (Kind != ContentKind.Note)
                {
                    <a class="bocchi-kind-action bocchi-kind-action--primary" href="@CreateUrl">
                        <Blazicon Svg="Lucide.Plus" />
                        <span>@I18n["kind.index.empty.action"]</span>
                    </a>
                }
            </div>
        </div>
    }
    else
    {
        <section aria-label='@I18n["kind.index.aria.list"]'>
            <div class="bocchi-content-list bocchi-content-list--actions">
                @foreach (var item in _items)
                {
                    <div class="bocchi-content-item">
                        <span class="bocchi-content-item__icon @KindIconClass">
                            <Blazicon Svg="@KindIcon" />
                        </span>
                        <a class="bocchi-content-item__main" href="@ContentEditingService.EditUrl(item.RelativePath)">
                            <strong>@(string.IsNullOrWhiteSpace(item.Title) ? item.ContentId : item.Title)</strong>
                            <small>@item.RelativePath</small>
                        </a>
                        <BocchiStatusPill Tone="@StatusTone(item.Status)">@StatusLabel(item.Status)</BocchiStatusPill>
                        <span class="bocchi-content-item__date">@TimeLabel(item)</span>
                        <span class="bocchi-content-item__actions">
                            <a class="bocchi-row-icon-button"
                               href="@ContentEditingService.EditUrl(item.RelativePath)"
                               aria-label='@I18n["home.action.edit"]'
                               title='@I18n["home.action.edit"]'>
                                <Blazicon Svg="Lucide.Pencil" />
                            </a>
                            <details class="bocchi-row-delete">
                                <summary class="bocchi-row-icon-button"
                                         aria-label='@I18n["kind.index.delete"]'
                                         title='@I18n["kind.index.delete"]'>
                                    <Blazicon Svg="Lucide.Trash2" />
                                </summary>
                                <div class="bocchi-row-delete__popup" role="dialog" aria-label='@I18n["kind.index.delete.confirm"]'>
                                    <strong>@I18n["kind.index.delete.confirm"]</strong>
                                    <div class="bocchi-row-delete__actions">
                                        <button type="button" data-bocchi-close-delete>@I18n["kind.index.delete.cancel"]</button>
                                        <button type="button"
                                                class="bocchi-row-delete__danger"
                                                disabled="@IsDeleting(item.RelativePath)"
                                                @onclick="() => DeleteAsync(item.RelativePath)">
                                            @I18n["kind.index.delete.confirmAction"]
                                        </button>
                                    </div>
                                </div>
                            </details>
                        </span>
                    </div>
                }
            </div>
        </section>
    }
</article>

@code {
    /// <summary>当前页面对应的内容类型，决定列表过滤与图标配色。</summary>
    [Parameter, EditorRequired] public ContentKind Kind { get; set; }

    /// <summary>i18n key 用的复数 slug（posts/notes/works/pages），由调用方传入避免运行期映射。</summary>
    [Parameter, EditorRequired] public string KindSlug { get; set; } = "posts";

    /// <summary>列表图标。</summary>
    [Parameter, EditorRequired] public SvgIcon KindIcon { get; set; } = default!;

    /// <summary>列表图标的颜色 modifier，例如 <c>bocchi-content-item__icon--pink</c>。</summary>
    [Parameter, EditorRequired] public string KindIconClass { get; set; } = "bocchi-content-item__icon--pink";

    private IReadOnlyList<ContentSummary> _items = [];

    /// <summary>刷新按钮的忙碌状态；扫描期间禁用按钮，避免重复写入 ScanRun。</summary>
    private bool _refreshing;

    /// <summary>正在删除的源文件路径，用于防止重复点击确认按钮。</summary>
    private string? _deletingPath;

    protected override async Task OnInitializedAsync()
        => await LoadItemsAsync();

    /// <summary>按当前内容类型重新读取数据库索引，保持列表排序逻辑集中。</summary>
    private async Task LoadItemsAsync()
    {
        var summaries = await Store.ListContentSummariesAsync(Kind);
        _items = summaries
            .OrderByDescending(x => x.UpdatedAt ?? x.PublishedAt)
            .ThenBy(x => x.Title ?? x.ContentId)
            .ToList();
    }

    /// <summary>手动重扫整个 workspace，用于外部修改文件或重建数据库后刷新内容索引。</summary>
    private async Task RefreshWorkspaceAsync()
    {
        if (_refreshing)
        {
            return;
        }

        _refreshing = true;
        try
        {
            await Scanner.ScanAsync();
            await LoadItemsAsync();
        }
        finally
        {
            _refreshing = false;
        }
    }

    private string StatusLabel(ContentStatus status) => status switch
    {
        ContentStatus.Published => I18n["home.status.ready"],
        ContentStatus.Archived => I18n["home.status.archived"],
        _ => I18n["home.status.draft"],
    };

    private static string StatusTone(ContentStatus status) => status switch
    {
        ContentStatus.Published => "success",
        ContentStatus.Archived => "neutral",
        _ => "warning",
    };

    private static string TimeLabel(ContentSummary item)
        => (item.UpdatedAt ?? item.PublishedAt)?.ToString("yyyy-MM-dd", CultureInfo.CurrentCulture) ?? "-";

    /// <summary>删除源文件和状态索引，然后从当前列表移除该行。</summary>
    private async Task DeleteAsync(string relativePath)
    {
        if (string.IsNullOrWhiteSpace(relativePath) || _deletingPath is not null)
        {
            return;
        }

        _deletingPath = relativePath;
        try
        {
            await Editor.DeleteAsync(relativePath);
            await Store.DeleteContentBySourcePathAsync(relativePath);
            _items = _items
                .Where(x => !string.Equals(x.RelativePath, relativePath, StringComparison.Ordinal))
                .ToList();
        }
        finally
        {
            _deletingPath = null;
        }
    }

    private bool IsDeleting(string relativePath)
        => string.Equals(_deletingPath, relativePath, StringComparison.Ordinal);

    /// <summary>新建入口需要带上 kind，避免从分类型列表进入编辑器时丢失上下文。</summary>
    private string CreateUrl => $"/Admin/Content/Edit?kind={CreateKindValue}";

    private string CreateKindValue => Kind switch
    {
        ContentKind.Note => "note",
        ContentKind.Work => "work",
        ContentKind.Page => "page",
        _ => "post",
    };

    /// <summary>只有文章和作品有类别、标签管理；短文保持轻量发布模型。</summary>
    private bool HasTaxonomy => Kind is ContentKind.Post or ContentKind.Work;

    /// <summary>跳转到独立类别树页时，透传当前 kind，让该页默认选中对应分档。</summary>
    private string CategoriesUrl => $"/Admin/Site/Categories?kind={CreateKindValue}";
}
