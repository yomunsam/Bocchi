@using System.Globalization
@using Bocchi.ContentModel
@inject CategoryTreeService Categories
@inject DashboardLocalizationService I18n

<section class="bocchi-category-editor" aria-labelledby="@HeadingId">
    <header class="bocchi-category-editor__header">
        <div>
            <span class="bocchi-category-editor__eyebrow">@I18n["category.editor.eyebrow"]</span>
            <h2 id="@HeadingId">@I18n["category.editor.title"]</h2>
        </div>
        <div class="bocchi-category-editor__actions">
            <span class="bocchi-category-editor__limit">
                @string.Format(CultureInfo.CurrentCulture, I18n["category.editor.maxDepthFormat"], CategoryTreeService.MaxDepth)
            </span>
            <button type="button" class="secondary" @onclick="AddRoot">
                <Blazicon Svg="Lucide.Plus" />
                <span>@I18n["category.editor.addRoot"]</span>
            </button>
            <button type="button" disabled="@(!CanSave)" @onclick="SaveAsync">
                <Blazicon Svg="Lucide.Save" />
                <span>@(_busy ? I18n["category.editor.saving"] : I18n["category.editor.save"])</span>
            </button>
        </div>
    </header>

    @if (!_loaded)
    {
        <p class="bocchi-category-editor__status">@I18n["category.editor.loading"]</p>
    }
    else
    {
        @if (_roots.Count == 0)
        {
            <div class="bocchi-category-editor__empty">
                <strong>@I18n["category.editor.empty"]</strong>
                <button type="button" class="secondary" @onclick="AddRoot">@I18n["category.editor.addRoot"]</button>
            </div>
        }
        else
        {
            <div class="bocchi-category-editor__roots">
                @foreach (var root in _roots)
                {
                    <BocchiCategoryTreeNodeEditor Node="root"
                                                  Level="0"
                                                  AddChild="AddChild"
                                                  Remove="RemoveNode"
                                                  Changed="MarkDirty" />
                }
            </div>
        }

        @if (HasInvalidNames)
        {
            <p class="bocchi-category-editor__status bocchi-category-editor__status--warning">
                @I18n["category.editor.validation.emptyName"]
            </p>
        }
        else if (_saved)
        {
            <p class="bocchi-category-editor__status bocchi-category-editor__status--success">
                @I18n["category.editor.saved"]
            </p>
        }
    }
</section>

@code {
    /// <summary>分类树所属内容类型；当前只会从文章和作品列表入口传入。</summary>
    [Parameter, EditorRequired] public ContentKind Kind { get; set; }

    private readonly List<CategoryTreeEditorNode> _roots = [];
    private ContentKind? _loadedKind;
    private bool _loaded;
    private bool _dirty;
    private bool _busy;
    private bool _saved;

    private string HeadingId => $"bocchi-category-editor-{Kind.ToString().ToLowerInvariant()}";

    private bool HasInvalidNames => _roots.Any(HasInvalidName);

    private bool CanSave => _loaded && _dirty && !_busy && !HasInvalidNames;

    protected override async Task OnParametersSetAsync()
    {
        if (_loadedKind == Kind && _loaded)
        {
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loaded = false;
        _saved = false;
        _roots.Clear();
        var tree = await Categories.GetAsync(Kind);
        _roots.AddRange(tree.Roots.Select(ToEditorNode));
        _loadedKind = Kind;
        _dirty = false;
        _loaded = true;
    }

    private void AddRoot()
    {
        _roots.Add(new CategoryTreeEditorNode());
        MarkDirty();
    }

    private void AddChild(CategoryTreeEditorNode parent)
    {
        parent.Children.Add(new CategoryTreeEditorNode());
        MarkDirty();
    }

    private void RemoveNode(CategoryTreeEditorNode node)
    {
        if (RemoveFrom(_roots, node))
        {
            MarkDirty();
        }
    }

    private void MarkDirty()
    {
        _dirty = true;
        _saved = false;
    }

    private async Task SaveAsync()
    {
        if (!CanSave)
        {
            return;
        }

        _busy = true;
        try
        {
            await Categories.SaveAsync(Kind, _roots.Select(ToServiceNode));
            _dirty = false;
            _saved = true;
        }
        finally
        {
            _busy = false;
        }
    }

    private static bool RemoveFrom(List<CategoryTreeEditorNode> nodes, CategoryTreeEditorNode target)
    {
        if (nodes.Remove(target))
        {
            return true;
        }

        foreach (var node in nodes)
        {
            if (RemoveFrom(node.Children, target))
            {
                return true;
            }
        }

        return false;
    }

    private static bool HasInvalidName(CategoryTreeEditorNode node)
        => string.IsNullOrWhiteSpace(node.Name) || node.Children.Any(HasInvalidName);

    private static CategoryTreeEditorNode ToEditorNode(CategoryTreeNode node)
    {
        var editorNode = new CategoryTreeEditorNode
        {
            Id = node.Id,
            Name = node.Name,
        };
        editorNode.Children.AddRange(node.Children.Select(ToEditorNode));
        return editorNode;
    }

    private static CategoryTreeNode ToServiceNode(CategoryTreeEditorNode node)
        => new(
            node.Id,
            node.Name,
            node.Children.Select(ToServiceNode).ToList());
}
