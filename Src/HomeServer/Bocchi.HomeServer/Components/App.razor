<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="icon" href="@Assets["favicon.ico"]" sizes="any" />
    <link rel="icon" type="image/png" sizes="16x16" href="@Assets["favicon-16x16.png"]" />
    <link rel="icon" type="image/png" sizes="32x32" href="@Assets["favicon-32x32.png"]" />
    <link rel="icon" type="image/png" sizes="48x48" href="@Assets["favicon-48x48.png"]" />
    <link rel="apple-touch-icon" sizes="180x180" href="@Assets["apple-touch-icon.png"]" />
    <link rel="manifest" href="@Assets["site.webmanifest"]" />
    <meta name="theme-color" content="#f8f7fc" />
    <script>
        (() => {
            const storageKey = "bocchi.dashboard.appearance";
            const root = document.documentElement;
            let mode = "auto";
            try {
                const stored = localStorage.getItem(storageKey);
                mode = stored === "light" || stored === "dark" ? stored : "auto";
            } catch {
                mode = "auto";
            }

            const prefersDark = window.matchMedia?.("(prefers-color-scheme: dark)").matches === true;
            const effective = mode === "auto" ? (prefersDark ? "dark" : "light") : mode;
            root.dataset.bocchiAppearance = mode;
            root.dataset.bocchiEffectiveAppearance = effective;
            root.style.colorScheme = effective;
        })();
    </script>
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["app.min.css"]" />
    <link rel="stylesheet" href="@Assets["Bocchi.HomeServer.styles.css"]" />
    <ImportMap />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <ReconnectModal />
    <script src="@Assets["bocchi-appearance.js"]"></script>
    <script src="@Assets["bocchi-ai.js"]"></script>
    <script src="@Assets["bocchi-markdown-editor.min.js"]"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>
