<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <script>
        (() => {
            const storageKey = "bocchi.dashboard.appearance";
            const root = document.documentElement;
            let mode = "auto";
            try {
                const stored = localStorage.getItem(storageKey);
                mode = stored === "light" || stored === "dark" ? stored : "auto";
            } catch {
                mode = "auto";
            }

            const prefersDark = window.matchMedia?.("(prefers-color-scheme: dark)").matches === true;
            const effective = mode === "auto" ? (prefersDark ? "dark" : "light") : mode;
            root.dataset.bocchiAppearance = mode;
            root.dataset.bocchiEffectiveAppearance = effective;
            root.style.colorScheme = effective;
        })();
    </script>
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["css/admin-home.css"]" />
    <link rel="stylesheet" href="@Assets["Bocchi.HomeServer.styles.css"]" />
    <ImportMap />
    <HeadOutlet />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <ReconnectModal />
    <script src="@Assets["bocchi-appearance.js"]"></script>
    <script src="@Assets["bocchi-ai.js"]"></script>
    <script src="@Assets["bocchi-markdown-editor.js"]"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>
