@inherits LayoutComponentBase
@inject DashboardLocalizationService I18n
@inject NavigationManager Navigation

<div class="bocchi-admin-shell">
    <aside class="bocchi-sidebar" aria-label="Dashboard navigation">
        <a class="bocchi-logo" href="/Admin" aria-label="Bocchi Admin">Bocchi</a>

        <nav class="bocchi-primary-nav">
            <NavLink href="/Admin" Match="NavLinkMatch.All">
                <Blazicon Svg="Lucide.House" />
                <span>@I18n["nav.overview"]</span>
            </NavLink>
            <NavLink href="/Admin/Posts">
                <Blazicon Svg="Lucide.FileText" />
                <span>@I18n["nav.posts"]</span>
            </NavLink>
            <NavLink href="/Admin/Notes">
                <Blazicon Svg="Lucide.PenLine" />
                <span>@I18n["nav.notes"]</span>
            </NavLink>
            <NavLink href="/Admin/Works">
                <Blazicon Svg="Lucide.FolderOpen" />
                <span>@I18n["nav.works"]</span>
            </NavLink>
            <NavLink href="/Admin/Pages">
                <Blazicon Svg="Lucide.BookOpen" />
                <span>@I18n["nav.pages"]</span>
            </NavLink>
            <NavLink href="/Admin/Publish">
                <Blazicon Svg="Lucide.Send" />
                <span>@I18n["nav.publish"]</span>
            </NavLink>
            <NavLink href="/Admin/Settings">
                <Blazicon Svg="Lucide.Settings" />
                <span>@I18n["nav.settings"]</span>
            </NavLink>
        </nav>
    </aside>

    <div class="bocchi-workbench">
        <header class="bocchi-topbar">
            <form class="bocchi-command-search" method="get" action="/Admin/Content" role="search" onclick="this.querySelector('input')?.focus()">
                <Blazicon Svg="Lucide.Search" />
                <input name="q" type="search" placeholder='@I18n["topbar.search.placeholder"]' aria-label='@I18n["topbar.search.aria"]' />
            </form>

            <div class="bocchi-topbar__actions">
                <details class="bocchi-menu-control bocchi-menu-control--language">
                    <summary aria-label='@I18n["topbar.language.aria"]'>
                        <Blazicon Svg="Lucide.Languages" />
                        <span>@I18n.CurrentLanguage.NativeName</span>
                        <Blazicon Svg="Lucide.ChevronDown" />
                    </summary>
                    <form class="bocchi-menu-control__menu" method="post" action="/Admin/Settings/Localization/UiLanguage">
                        <input type="hidden" name="returnUrl" value="@CurrentReturnUrl" />
                        @* 语言切换需要走 HTTP 端点写 culture cookie，所以每个选项直接提交表单。 *@
                        <div class="bocchi-menu-control__option-list">
                            @foreach (var language in DashboardLocalizationService.SupportedDashboardLanguages)
                            {
                                <button type="submit"
                                        name="uiLanguage"
                                        value="@language.Code"
                                        class="@LanguageOptionClass(language.Code)">
                                    <span class="bocchi-menu-control__check" aria-hidden="true">
                                        <Blazicon Svg="Lucide.Check" />
                                    </span>
                                    <span>@language.NativeName</span>
                                </button>
                            }
                        </div>
                    </form>
                </details>
                <details class="bocchi-menu-control bocchi-menu-control--appearance" id="bocchi-appearance-control">
                    <summary aria-label='@I18n["topbar.appearance.aria"]'>
                        <Blazicon Svg="Lucide.SunMoon" />
                        <span data-bocchi-appearance-label>@I18n["topbar.appearance.auto"]</span>
                        <Blazicon Svg="Lucide.ChevronDown" />
                    </summary>
                    <div class="bocchi-menu-control__menu" role="menu" aria-label='@I18n["topbar.appearance.aria"]'>
                        @* Dashboard 外观是纯客户端偏好；按钮由 bocchi-appearance.js 同步选中态。 *@
                        <button type="button"
                                class="bocchi-menu-control__option"
                                data-bocchi-appearance-option="auto"
                                data-bocchi-appearance-label-text='@I18n["topbar.appearance.auto"]'
                                aria-current="true"
                                onclick="window.bocchiAppearance?.set('auto')">
                            <span class="bocchi-menu-control__check" aria-hidden="true">
                                <Blazicon Svg="Lucide.Check" />
                            </span>
                            <span>@I18n["topbar.appearance.auto"]</span>
                        </button>
                        <button type="button"
                                class="bocchi-menu-control__option"
                                data-bocchi-appearance-option="light"
                                data-bocchi-appearance-label-text='@I18n["topbar.appearance.light"]'
                                aria-current="false"
                                onclick="window.bocchiAppearance?.set('light')">
                            <span class="bocchi-menu-control__check" aria-hidden="true">
                                <Blazicon Svg="Lucide.Check" />
                            </span>
                            <span>@I18n["topbar.appearance.light"]</span>
                        </button>
                        <button type="button"
                                class="bocchi-menu-control__option"
                                data-bocchi-appearance-option="dark"
                                data-bocchi-appearance-label-text='@I18n["topbar.appearance.dark"]'
                                aria-current="false"
                                onclick="window.bocchiAppearance?.set('dark')">
                            <span class="bocchi-menu-control__check" aria-hidden="true">
                                <Blazicon Svg="Lucide.Check" />
                            </span>
                            <span>@I18n["topbar.appearance.dark"]</span>
                        </button>
                    </div>
                </details>
                <a class="bocchi-account-avatar" href="/Admin/Users" aria-label='@I18n["topbar.account.aria"]'>
                    <Blazicon Svg="Lucide.CircleUserRound" />
                </a>
                <form method="post" action="/Account/Logout">
                    <button type="submit" class="bocchi-icon-button" aria-label='@I18n["topbar.logout.aria"]'>
                        <Blazicon Svg="Lucide.LogOut" />
                    </button>
                </form>
            </div>
        </header>

        <main class="bocchi-page">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">×</span>
</div>

@code {
    /// <summary>语言切换后返回当前 Dashboard 路由，避免用户从编辑页被带离。</summary>
    private string CurrentReturnUrl
    {
        get
        {
            var relative = Navigation.ToBaseRelativePath(Navigation.Uri);
            return string.IsNullOrWhiteSpace(relative) ? "/" : "/" + relative;
        }
    }

    /// <summary>判断语言选项是否为当前 culture cookie 解析出的 UI 语言。</summary>
    private bool IsCurrentDashboardLanguage(string code)
        => string.Equals(I18n.CurrentLanguage.Code, code, StringComparison.OrdinalIgnoreCase);

    /// <summary>生成语言菜单选项 class，当前语言需要显示 check 图标。</summary>
    private string LanguageOptionClass(string code)
        => IsCurrentDashboardLanguage(code)
            ? "bocchi-menu-control__option bocchi-menu-control__option--active"
            : "bocchi-menu-control__option";
}
